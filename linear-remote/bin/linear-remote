#!/usr/bin/env python3
"""
linear-remote — read-first CLI wrapper around the Linear GraphQL API.

One call returns the full issue/comments/relations/state tree so the agent
doesn't burn context chaining `get_issue` + `list_comments` + `get_team`
+ `list_issue_labels` per issue.

Commands (all emit JSON; --pretty for indented):
  issues get <id-or-query> [--include-comments] [--include-relations]
  issues list [--project ...] [--state ...] [--assignee ...] [--team ...] [--label ...]
              [--limit 25] [--cursor <c>]
  issues search <query> [--limit 25]
  issues create --title <t> --team <name> [--project <n>] [--body <text|@file>]
                [--labels a,b] [--priority 0-4] [--assignee <email>]
  issues create --from-markdown <path> [--team <name>]          # killer feature
  issues update <id> [--title ...] [--state ...] [--assignee ...]
                     [--labels a,b] [--priority N] [--project ...]
  issues move <id> <state-name> [--wait] [--timeout 60]
  issues assign <id> <assignee>

  comments add <issue-id> <body>                    # <body> accepts @path for file input
  comments list <issue-id>

  projects list [--team <name>]
  projects overview <name> [--bucket-limit 25]

  teams list
  states <team-name>
  labels [--team <name>]
  cycles <team-name>

Hard safety rules:
  1. LINEAR_API_KEY is NEVER written to stdout/stderr.
  2. All API responses pass through _scrub() before emission to strip
     `apiKey`, `token`, `secret`, `webhookSecret`, `password` fields.
  3. Write operations are explicit. Read-only by default.
  4. Name resolution ambiguity fails with candidates — never silent.

Config precedence (highest first):
  1. --api-key / --team CLI flags
  2. --env-file path
  3. project .env.local / .env (walked up from cwd)
  4. shell env

Requires: LINEAR_API_KEY. Optional: LINEAR_TEAM_ID (team UUID or human key like "LOA").
"""

from __future__ import annotations

import argparse
import functools
import json
import os
import re
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any, Optional

# ──────────────────────────── constants ────────────────────────────

API_URL = "https://api.linear.app/graphql"
USER_AGENT = "linear-remote/0.1.0 (+https://github.com/osouthgate/agent-plus)"

DEFAULT_LIST_LIMIT = 25
MAX_LIST_LIMIT = 100
DEFAULT_BUCKET_LIMIT = 25
MAX_BUCKET_LIMIT = 100
DEFAULT_ACTIVITY_LIMIT = 10

# --wait polling contract (seconds). Scoped to webhook-driven transitions.
WAIT_DEFAULT_TIMEOUT = 60
WAIT_POLL_INTERVAL = 3

HTTP_TIMEOUT = 30
HTTP_RETRY_ON = {429, 500, 502, 503, 504}
HTTP_MAX_RETRIES = 3

# Issue human-key pattern: TEAM-123 (uppercase team prefix + number).
HUMAN_KEY_RE = re.compile(r"^[A-Z][A-Z0-9_]{0,9}-\d+$")
# UUIDs: 8-4-4-4-12 hex.
UUID_RE = re.compile(r"^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$", re.IGNORECASE)

# Secret-bearing keys stripped from every response before emission.
# Conservative — prefer over-redaction to leakage.
SECRET_KEYS = frozenset({
    "apikey",
    "token",
    "secret",
    "webhooksecret",
    "password",
    "accesstoken",
    "refreshtoken",
})

# Keys preserved even if they share a prefix with SECRET_KEYS (metadata).
SECRET_ALLOWLIST = frozenset({
    "tokenCount",
    "secretLabel",
})


# ──────────────────────────── errors ────────────────────────────


class LinearError(Exception):
    """Raised on API errors with a user-friendly message."""


def die(msg: str, *, code: int = 1) -> None:
    sys.stderr.write(f"linear-remote: {msg}\n")
    sys.exit(code)


# ──────────────────────────── config loading ────────────────────────────


def _find_env_files(start: Path) -> list[Path]:
    """Walk up from `start` collecting .env.local and .env (closest first)."""
    found: list[Path] = []
    cur = start.resolve()
    while True:
        for name in (".env.local", ".env"):
            p = cur / name
            if p.is_file():
                found.append(p)
        if cur.parent == cur:
            break
        cur = cur.parent
    return found


def _parse_env_file(path: Path) -> dict[str, str]:
    out: dict[str, str] = {}
    try:
        for raw in path.read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if "=" not in line:
                continue
            k, v = line.split("=", 1)
            k = k.strip()
            v = v.strip().strip('"').strip("'")
            if k and k.startswith("LINEAR_"):
                out[k] = v
    except OSError:
        pass
    return out


def load_config(*, env_file: Optional[str] = None) -> dict[str, str]:
    """Load LINEAR_* config with layered precedence.

    Order (lowest first, so later overwrites):
      4. shell env
      3. project .env / .env.local walked up (closest wins)
      2. explicit --env-file (highest among file sources)
    """
    cfg: dict[str, str] = {}
    for k, v in os.environ.items():
        if k.startswith("LINEAR_"):
            cfg[k] = v
    env_files = _find_env_files(Path.cwd())
    # reversed: outermost first, so closest (first in list) overwrites last.
    for p in reversed(env_files):
        cfg.update(_parse_env_file(p))
    if env_file:
        p = Path(env_file)
        if not p.is_file():
            die(f"--env-file not found: {env_file}")
        cfg.update(_parse_env_file(p))
    return cfg


def require_api_key(cfg: dict[str, str]) -> str:
    key = cfg.get("LINEAR_API_KEY", "").strip()
    if not key:
        die(
            "LINEAR_API_KEY not set.\n"
            "  Set in project .env or .env.local (keys prefixed LINEAR_),\n"
            "  or in ~/.claude/settings.json (env block),\n"
            "  or via shell: export LINEAR_API_KEY=lin_api_...\n"
            "  Get one: https://linear.app/settings/api"
        )
    return key


# ──────────────────────────── scrub ────────────────────────────


def _scrub(obj: Any) -> Any:
    """Recursively strip secret-bearing keys from API responses.

    Rules:
      - Dict keys matching SECRET_KEYS (case-insensitive): replaced with "[REDACTED]".
      - SECRET_ALLOWLIST keys (exact match) are preserved and recursed into.
      - Lists are walked element-wise. Primitives pass through.

    INVARIANT: no value from a redacted key ever appears in output.
    """
    if isinstance(obj, dict):
        out: dict[str, Any] = {}
        for k, v in obj.items():
            if k in SECRET_ALLOWLIST:
                out[k] = _scrub(v)
                continue
            k_lower = str(k).lower()
            if k_lower in SECRET_KEYS:
                out[k] = "[REDACTED]"
                continue
            out[k] = _scrub(v)
        return out
    if isinstance(obj, list):
        return [_scrub(x) for x in obj]
    return obj


# ──────────────────────────── markdown helpers ────────────────────────────


FRONTMATTER_RE = re.compile(r"\A---\s*\n(.*?)\n---\s*\n?(.*)\Z", re.DOTALL)
HTML_COMMENT_RE = re.compile(r"<!--.*?-->", re.DOTALL)


def _parse_frontmatter(text: str) -> tuple[dict[str, Any], str]:
    """Parse minimal YAML frontmatter. Returns (meta, body).

    Supports scalar (`key: value`), list (`key: [a, b]` or `key:\\n  - a\\n  - b`),
    and bare values. No nested maps — frontmatter for this plugin is flat.
    If no frontmatter, returns ({}, text).
    """
    m = FRONTMATTER_RE.match(text)
    if not m:
        return {}, text
    raw, body = m.group(1), m.group(2)
    meta: dict[str, Any] = {}
    cur_key: Optional[str] = None
    cur_list: Optional[list[str]] = None
    for raw_line in raw.splitlines():
        line = raw_line.rstrip()
        if not line or line.lstrip().startswith("#"):
            continue
        # YAML list continuation: "  - item"
        stripped = line.lstrip()
        if stripped.startswith("- ") and cur_key is not None and cur_list is not None:
            cur_list.append(stripped[2:].strip().strip('"').strip("'"))
            continue
        # New key.
        if ":" in line:
            # Close any open list.
            cur_list = None
            k, _, v = line.partition(":")
            k = k.strip()
            v = v.strip()
            if not v:
                # Might be a list on next lines.
                cur_list = []
                meta[k] = cur_list
                cur_key = k
                continue
            # Inline list: `labels: [a, b, c]`
            if v.startswith("[") and v.endswith("]"):
                inner = v[1:-1]
                items = [s.strip().strip('"').strip("'") for s in inner.split(",") if s.strip()]
                meta[k] = items
                cur_key = k
                cur_list = None
                continue
            # Scalar.
            meta[k] = v.strip('"').strip("'")
            cur_key = k
            cur_list = None
    return meta, body


def _normalise_markdown(text: str) -> str:
    """Linear-specific markdown quirks:

      - Strip YAML frontmatter (metadata for us, not Linear content).
      - Strip HTML comments — Linear renders `<!-- -->` as visible text.
      - Preserve TEAM-N autolinks untouched.
      - Task lists, code fences, standard markdown pass through.
    """
    if not text:
        return text
    _, body = _parse_frontmatter(text)
    body = HTML_COMMENT_RE.sub("", body)
    return body.strip()


def _extract_title_and_body(text: str) -> tuple[str, str]:
    """For --from-markdown: first H1 is title, remainder is body.

    If no H1, the first non-blank line is title (stripped of leading `#`s).
    """
    lines = text.splitlines()
    title = ""
    body_start = 0
    for i, line in enumerate(lines):
        stripped = line.strip()
        if not stripped:
            continue
        if stripped.startswith("# "):
            title = stripped[2:].strip()
            body_start = i + 1
            break
        # No H1 anywhere — fall through.
        title = stripped.lstrip("#").strip()
        body_start = i + 1
        break
    body = "\n".join(lines[body_start:]).strip()
    return title, body


def _load_body_arg(value: str) -> str:
    """Accept @path for file input; otherwise return as-is."""
    if value.startswith("@"):
        path = Path(value[1:])
        if not path.is_file():
            die(f"body file not found: {value[1:]}")
        return path.read_text(encoding="utf-8")
    return value


# ──────────────────────────── ID format ────────────────────────────


def _is_human_key(ref: str) -> bool:
    return bool(HUMAN_KEY_RE.match(ref))


def _is_uuid(ref: str) -> bool:
    return bool(UUID_RE.match(ref))


# ──────────────────────────── GraphQL client ────────────────────────────


def _gql(
    query: str,
    variables: Optional[dict[str, Any]] = None,
    *,
    cfg: dict[str, str],
    timeout: int = HTTP_TIMEOUT,
) -> Any:
    """POST a GraphQL request. Handles auth, retry on 429/5xx, GraphQL error unwrap.

    Auth header: `Authorization: <api-key>` — NO `Bearer` prefix. Linear personal
    API keys are passed raw. This is the #1 verify-with-curl item.

    Raises LinearError on transport or GraphQL-level errors.
    """
    api_key = require_api_key(cfg)
    body_bytes = json.dumps({"query": query, "variables": variables or {}}).encode("utf-8")

    headers = {
        "Authorization": api_key,  # NO Bearer prefix.
        "Content-Type": "application/json",
        "User-Agent": USER_AGENT,
        "Accept": "application/json",
    }

    last_err: Optional[str] = None
    for attempt in range(HTTP_MAX_RETRIES):
        req = urllib.request.Request(API_URL, data=body_bytes, method="POST", headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=timeout) as resp:
                raw = resp.read().decode("utf-8")
                if not raw:
                    return {}
                parsed = json.loads(raw)
                errors = parsed.get("errors")
                if errors:
                    # Surface the first GraphQL error with path + message.
                    msg_parts = []
                    for err in errors:
                        path = err.get("path") or []
                        path_s = ".".join(str(x) for x in path) if path else "<root>"
                        m = err.get("message", "<no message>")
                        msg_parts.append(f"{path_s}: {m}")
                    raise LinearError(
                        "GraphQL error(s): " + "; ".join(msg_parts)
                        + "\n  Fix: check the field path in your request — Linear's GraphQL surfaces"
                        + " field-level validation verbatim.\n"
                        + "  Link: https://developers.linear.app/docs/graphql/working-with-the-graphql-api"
                    )
                return parsed.get("data", {})
        except urllib.error.HTTPError as e:
            status = e.code
            try:
                err_body = e.read().decode("utf-8")
            except Exception:
                err_body = ""
            if status in HTTP_RETRY_ON and attempt < HTTP_MAX_RETRIES - 1:
                retry_after = e.headers.get("Retry-After") if e.headers else None
                delay = min(30, 2 ** attempt)
                if retry_after:
                    try:
                        delay = min(60, int(retry_after))
                    except ValueError:
                        pass
                time.sleep(delay)
                continue
            msg = f"HTTP {status} on POST {API_URL}"
            if err_body:
                try:
                    parsed = json.loads(err_body)
                    err_msg = parsed.get("message") or parsed.get("error") or err_body
                    msg = f"{msg}: {err_msg}"
                except json.JSONDecodeError:
                    msg = f"{msg}: {err_body[:200]}"
            if status == 401:
                msg += (
                    "\n  API key rejected. Check for whitespace/truncation in LINEAR_API_KEY.\n"
                    "  Fix: rotate the key at https://linear.app/settings/api"
                )
            elif status == 403:
                msg += (
                    "\n  Key lacks access to this workspace or resource.\n"
                    "  Fix: confirm you're a member of the workspace and the key belongs to it.\n"
                    "  Link: https://linear.app/settings/api"
                )
            elif status == 429:
                ra = e.headers.get("Retry-After") if e.headers else None
                msg += (
                    f"\n  Rate-limited by Linear. Retry after {ra or '~30'}s (Retry-After header).\n"
                    "  Linear's complexity budget is ~1500/hr for personal keys — back off."
                )
            raise LinearError(msg)
        except urllib.error.URLError as e:
            last_err = str(e)
            if attempt < HTTP_MAX_RETRIES - 1:
                time.sleep(2 ** attempt)
                continue
            raise LinearError(f"network error: {last_err}")
    raise LinearError("exhausted retries on GraphQL request")


# ──────────────────────────── resolvers (lru-cached) ────────────────────────────
#
# Per-process caches keyed on (cfg_key, name). Since argparse rebuilds cfg once
# per invocation, we freeze a tuple of (api_key, team_id) as the cache key so
# `issues update + issues move` in one invocation doesn't re-query enums.


def _cache_key(cfg: dict[str, str]) -> tuple[str, str]:
    return (cfg.get("LINEAR_API_KEY", ""), cfg.get("LINEAR_TEAM_ID", ""))


@functools.lru_cache(maxsize=32)
def _cached_teams(cache_key: tuple[str, str]) -> tuple[dict[str, Any], ...]:
    # cache_key is unused; its purpose is to bind caching to a stable tuple.
    # The real cfg flows via closure in the caller; we pass it explicitly.
    return tuple()  # overridden by the wrapper below.


def _list_teams(cfg: dict[str, str]) -> list[dict[str, Any]]:
    """All teams accessible to the key. Cached per-process per cfg."""
    key = _cache_key(cfg)
    cached = _teams_cache.get(key)
    if cached is not None:
        return cached
    query = """
    query Teams {
      teams(first: 250) {
        nodes { id key name }
      }
    }
    """
    data = _gql(query, cfg=cfg)
    nodes = ((data or {}).get("teams") or {}).get("nodes") or []
    _teams_cache[key] = nodes
    return nodes


_teams_cache: dict[tuple[str, str], list[dict[str, Any]]] = {}
_states_cache: dict[tuple[tuple[str, str], str], list[dict[str, Any]]] = {}
_labels_cache: dict[tuple[tuple[str, str], Optional[str]], list[dict[str, Any]]] = {}
_users_cache: dict[tuple[str, str], list[dict[str, Any]]] = {}
_projects_cache: dict[tuple[tuple[str, str], Optional[str]], list[dict[str, Any]]] = {}


def resolve_team(name: str, cfg: dict[str, str]) -> dict[str, Any]:
    """Resolve a team by UUID, key (e.g. 'LOA'), name, or substring."""
    if not name:
        # Fall back to LINEAR_TEAM_ID.
        name = cfg.get("LINEAR_TEAM_ID", "").strip()
        if not name:
            die("no team specified — pass --team or set LINEAR_TEAM_ID")
    teams = _list_teams(cfg)
    # UUID exact.
    if _is_uuid(name):
        for t in teams:
            if t.get("id") == name:
                return t
        die(f"team UUID not found: {name}")
    # Key exact (case-insensitive).
    nu = name.upper()
    key_matches = [t for t in teams if (t.get("key") or "").upper() == nu]
    if len(key_matches) == 1:
        return key_matches[0]
    # Name exact.
    nl = name.lower()
    name_exact = [t for t in teams if (t.get("name") or "").lower() == nl]
    if len(name_exact) == 1:
        return name_exact[0]
    # Substring.
    subs = [t for t in teams if nl in (t.get("name") or "").lower()]
    if len(subs) == 1:
        return subs[0]
    if not subs and not name_exact:
        die(f"team not found: {name}. Available: {', '.join(sorted((t.get('key') or t.get('name') or '?') for t in teams))}")
    candidates = sorted(f"{t.get('key')}:{t.get('name')}" for t in (subs or name_exact))
    die(f'Ambiguous team "{name}". Candidates: {", ".join(candidates)}. Use exact name or ID.')
    return {}  # unreachable


def _list_states(team_id: str, cfg: dict[str, str]) -> list[dict[str, Any]]:
    key = (_cache_key(cfg), team_id)
    cached = _states_cache.get(key)
    if cached is not None:
        return cached
    query = """
    query States($teamId: ID!) {
      workflowStates(filter: { team: { id: { eq: $teamId } } }, first: 100) {
        nodes { id name type color position }
      }
    }
    """
    data = _gql(query, {"teamId": team_id}, cfg=cfg)
    nodes = ((data or {}).get("workflowStates") or {}).get("nodes") or []
    _states_cache[key] = nodes
    return nodes


def resolve_state(name: str, team_id: str, cfg: dict[str, str]) -> dict[str, Any]:
    states = _list_states(team_id, cfg)
    if _is_uuid(name):
        for s in states:
            if s.get("id") == name:
                return s
        die(f"state UUID not found: {name}")
    nl = name.lower()
    exact = [s for s in states if (s.get("name") or "").lower() == nl]
    if len(exact) == 1:
        return exact[0]
    subs = [s for s in states if nl in (s.get("name") or "").lower()]
    if len(subs) == 1:
        return subs[0]
    avail = ", ".join(sorted(s.get("name") or "?" for s in states))
    if not subs and not exact:
        die(f'state not found: "{name}". Available in this team: {avail}')
    candidates = sorted(s.get("name") or "?" for s in (subs or exact))
    die(f'Ambiguous state "{name}". Candidates: {", ".join(candidates)}. Use exact name.')
    return {}


def _list_labels(team_id: Optional[str], cfg: dict[str, str]) -> list[dict[str, Any]]:
    key = (_cache_key(cfg), team_id)
    cached = _labels_cache.get(key)
    if cached is not None:
        return cached
    if team_id:
        query = """
        query Labels($teamId: ID!) {
          issueLabels(filter: { team: { id: { eq: $teamId } } }, first: 250) {
            nodes { id name color team { id key } }
          }
        }
        """
        data = _gql(query, {"teamId": team_id}, cfg=cfg)
    else:
        query = """
        query Labels {
          issueLabels(first: 250) { nodes { id name color team { id key } } }
        }
        """
        data = _gql(query, cfg=cfg)
    nodes = ((data or {}).get("issueLabels") or {}).get("nodes") or []
    _labels_cache[key] = nodes
    return nodes


def resolve_labels(names: list[str], team_id: Optional[str], cfg: dict[str, str]) -> list[str]:
    if not names:
        return []
    labels = _list_labels(team_id, cfg)
    resolved: list[str] = []
    for raw in names:
        name = raw.strip()
        if not name:
            continue
        if _is_uuid(name):
            resolved.append(name)
            continue
        nl = name.lower()
        exact = [lb for lb in labels if (lb.get("name") or "").lower() == nl]
        if len(exact) == 1:
            resolved.append(exact[0]["id"])
            continue
        subs = [lb for lb in labels if nl in (lb.get("name") or "").lower()]
        if len(subs) == 1:
            resolved.append(subs[0]["id"])
            continue
        candidates = ", ".join(sorted(lb.get("name") or "?" for lb in (subs or exact))) or "(none)"
        die(f'label not resolved: "{name}". Candidates: {candidates}. Use exact name.')
    return resolved


def _list_users(cfg: dict[str, str]) -> list[dict[str, Any]]:
    key = _cache_key(cfg)
    cached = _users_cache.get(key)
    if cached is not None:
        return cached
    query = """
    query Users {
      users(first: 250) { nodes { id name email displayName active } }
    }
    """
    data = _gql(query, cfg=cfg)
    nodes = ((data or {}).get("users") or {}).get("nodes") or []
    _users_cache[key] = nodes
    return nodes


def resolve_user(identifier: str, cfg: dict[str, str]) -> dict[str, Any]:
    if not identifier:
        die("no assignee specified")
    users = _list_users(cfg)
    if _is_uuid(identifier):
        for u in users:
            if u.get("id") == identifier:
                return u
        die(f"user UUID not found: {identifier}")
    il = identifier.lower()
    # Email exact first.
    email = [u for u in users if (u.get("email") or "").lower() == il]
    if len(email) == 1:
        return email[0]
    # Name / displayName exact.
    exact = [u for u in users if (u.get("name") or "").lower() == il or (u.get("displayName") or "").lower() == il]
    if len(exact) == 1:
        return exact[0]
    subs = [u for u in users if il in (u.get("name") or "").lower() or il in (u.get("email") or "").lower()]
    if len(subs) == 1:
        return subs[0]
    if not subs and not exact:
        die(f'user not found: "{identifier}". Try email or full display name.')
    candidates = ", ".join(sorted(f"{u.get('displayName') or u.get('name')} <{u.get('email')}>" for u in (subs or exact)))
    die(f'Ambiguous user "{identifier}". Candidates: {candidates}')
    return {}


def _list_projects(team_id: Optional[str], cfg: dict[str, str]) -> list[dict[str, Any]]:
    key = (_cache_key(cfg), team_id)
    cached = _projects_cache.get(key)
    if cached is not None:
        return cached
    if team_id:
        query = """
        query Projects($teamId: ID!) {
          projects(filter: { accessibleTeams: { id: { eq: $teamId } } }, first: 250) {
            nodes { id name state progress description lead { id name email } targetDate }
          }
        }
        """
        data = _gql(query, {"teamId": team_id}, cfg=cfg)
    else:
        query = """
        query Projects {
          projects(first: 250) {
            nodes { id name state progress description lead { id name email } targetDate }
          }
        }
        """
        data = _gql(query, cfg=cfg)
    nodes = ((data or {}).get("projects") or {}).get("nodes") or []
    _projects_cache[key] = nodes
    return nodes


def resolve_project(name: str, team_id: Optional[str], cfg: dict[str, str]) -> dict[str, Any]:
    projects = _list_projects(team_id, cfg)
    if _is_uuid(name):
        for p in projects:
            if p.get("id") == name:
                return p
        die(f"project UUID not found: {name}")
    nl = name.lower()
    exact = [p for p in projects if (p.get("name") or "").lower() == nl]
    if len(exact) == 1:
        return exact[0]
    subs = [p for p in projects if nl in (p.get("name") or "").lower()]
    if len(subs) == 1:
        return subs[0]
    if not subs and not exact:
        avail = ", ".join(sorted(p.get("name") or "?" for p in projects[:20]))
        die(f'project not found: "{name}". Available: {avail}')
    candidates = ", ".join(sorted(p.get("name") or "?" for p in (subs or exact)))
    die(f'Ambiguous project "{name}". Candidates: {candidates}. Use exact name.')
    return {}


def _resolve_issue_id(ref: str, cfg: dict[str, str]) -> str:
    """Accept UUID, human key (LOA-123), or free-text. Returns the UUID.

    Free-text queries fall through to `issues search` semantics — first match
    wins, fail on ambiguity.
    """
    if not ref:
        die("no issue specified")
    if _is_uuid(ref):
        return ref
    if _is_human_key(ref):
        # Lookup by identifier.
        query = """
        query IssueByIdentifier($id: String!) {
          issue(id: $id) { id identifier title }
        }
        """
        data = _gql(query, {"id": ref}, cfg=cfg)
        issue = (data or {}).get("issue")
        if issue and issue.get("id"):
            return issue["id"]
        die(f"issue not found: {ref}")
    # Fall through: search.
    matches = _search_issues(ref, 5, cfg)
    if not matches:
        die(f'no issue matches query: "{ref}"')
    if len(matches) == 1:
        return matches[0]["id"]
    names = ", ".join(f"{m.get('identifier')}: {m.get('title', '')[:40]}" for m in matches[:5])
    die(f'ambiguous issue query "{ref}". Candidates: {names}. Use an ID or narrower query.')
    return ""  # unreachable


# ──────────────────────────── issue operations ────────────────────────────


ISSUE_FIELDS_BASIC = """
id identifier title priority estimate
url createdAt updatedAt
state { id name type color }
team { id key name }
project { id name state }
assignee { id name email displayName }
labels(first: 20) { nodes { id name color } }
cycle { id name number startsAt endsAt }
parent { id identifier title }
"""


def _issue_query(include_comments: bool, include_relations: bool) -> str:
    extra = ""
    if include_comments:
        extra += """
    comments(first: 100) {
      nodes {
        id body createdAt updatedAt
        user { id name displayName email }
      }
      pageInfo { hasNextPage endCursor }
    }
    """
    if include_relations:
        extra += """
    relations(first: 50) {
      nodes {
        id type
        relatedIssue { id identifier title state { name } }
      }
    }
    inverseRelations(first: 50) {
      nodes {
        id type
        issue { id identifier title state { name } }
      }
    }
    """
    return f"""
    query Issue($id: String!) {{
      issue(id: $id) {{
        {ISSUE_FIELDS_BASIC}
        description
        {extra}
      }}
    }}
    """


def get_issue(ref: str, include_comments: bool, include_relations: bool, cfg: dict[str, str]) -> dict[str, Any]:
    # `issue(id:)` accepts either UUID or human key, so avoid an extra resolve hop.
    if _is_uuid(ref) or _is_human_key(ref):
        issue_id = ref
    else:
        issue_id = _resolve_issue_id(ref, cfg)
    data = _gql(_issue_query(include_comments, include_relations), {"id": issue_id}, cfg=cfg)
    issue = (data or {}).get("issue")
    if not issue:
        die(f"issue not found: {ref}")
    # Normalise description through the markdown helper.
    if issue.get("description"):
        issue["description"] = _normalise_markdown(issue["description"])
    if include_comments:
        comments = (issue.get("comments") or {}).get("nodes") or []
        for c in comments:
            if c.get("body"):
                c["body"] = _normalise_markdown(c["body"])
    return issue


def _search_issues(query_text: str, limit: int, cfg: dict[str, str]) -> list[dict[str, Any]]:
    query = """
    query Search($q: String!, $limit: Int!) {
      issues(
        filter: { title: { containsIgnoreCase: $q } }
        first: $limit
        orderBy: updatedAt
      ) {
        nodes { id identifier title updatedAt state { name } }
      }
    }
    """
    data = _gql(query, {"q": query_text, "limit": min(limit, MAX_LIST_LIMIT)}, cfg=cfg)
    return ((data or {}).get("issues") or {}).get("nodes") or []


def list_issues(
    *,
    project: Optional[str],
    state: Optional[str],
    assignee: Optional[str],
    team: Optional[str],
    label: Optional[str],
    limit: int,
    cursor: Optional[str],
    cfg: dict[str, str],
) -> dict[str, Any]:
    filt: dict[str, Any] = {}
    team_id: Optional[str] = None
    if team:
        team_obj = resolve_team(team, cfg)
        team_id = team_obj["id"]
        filt["team"] = {"id": {"eq": team_id}}
    if project:
        p = resolve_project(project, team_id, cfg)
        filt["project"] = {"id": {"eq": p["id"]}}
    if state and team_id:
        st = resolve_state(state, team_id, cfg)
        filt["state"] = {"id": {"eq": st["id"]}}
    elif state:
        # Without a team, match by state name directly.
        filt["state"] = {"name": {"eqIgnoreCase": state}}
    if assignee:
        u = resolve_user(assignee, cfg)
        filt["assignee"] = {"id": {"eq": u["id"]}}
    if label:
        lbl_ids = resolve_labels([label], team_id, cfg)
        if lbl_ids:
            filt["labels"] = {"id": {"in": lbl_ids}}

    lim = max(1, min(limit, MAX_LIST_LIMIT))
    variables: dict[str, Any] = {"filter": filt, "first": lim}
    if cursor:
        variables["after"] = cursor
    query = """
    query Issues($filter: IssueFilter, $first: Int!, $after: String) {
      issues(filter: $filter, first: $first, after: $after, orderBy: updatedAt) {
        nodes {
          id identifier title priority updatedAt
          state { name type }
          assignee { name email }
          team { key }
          project { name }
          labels(first: 10) { nodes { name } }
        }
        pageInfo { hasNextPage endCursor }
      }
    }
    """
    data = _gql(query, variables, cfg=cfg)
    issues_obj = (data or {}).get("issues") or {}
    return {
        "nodes": issues_obj.get("nodes") or [],
        "pageInfo": issues_obj.get("pageInfo") or {"hasNextPage": False, "endCursor": None},
    }


def create_issue(
    *,
    title: str,
    team: str,
    project: Optional[str] = None,
    body: Optional[str] = None,
    labels: Optional[list[str]] = None,
    priority: Optional[int] = None,
    assignee: Optional[str] = None,
    cfg: dict[str, str],
) -> dict[str, Any]:
    team_obj = resolve_team(team, cfg)
    team_id = team_obj["id"]
    inp: dict[str, Any] = {"title": title, "teamId": team_id}
    if body:
        inp["description"] = _normalise_markdown(body)
    if project:
        p = resolve_project(project, team_id, cfg)
        inp["projectId"] = p["id"]
    if labels:
        inp["labelIds"] = resolve_labels(labels, team_id, cfg)
    if priority is not None:
        if priority < 0 or priority > 4:
            die("--priority must be 0-4 (0=none, 1=urgent, 2=high, 3=medium, 4=low)")
        inp["priority"] = priority
    if assignee:
        u = resolve_user(assignee, cfg)
        inp["assigneeId"] = u["id"]

    mutation = """
    mutation CreateIssue($input: IssueCreateInput!) {
      issueCreate(input: $input) {
        success
        issue {
          id identifier title url priority
          state { name }
          team { key name }
          project { name }
          assignee { name email }
          labels(first: 10) { nodes { name } }
        }
      }
    }
    """
    data = _gql(mutation, {"input": inp}, cfg=cfg)
    result = (data or {}).get("issueCreate") or {}
    if not result.get("success"):
        raise LinearError("issueCreate returned success=false")
    return result.get("issue") or {}


def create_from_markdown(path: str, team_override: Optional[str], cfg: dict[str, str]) -> dict[str, Any]:
    p = Path(path)
    if not p.is_file():
        die(f"--from-markdown file not found: {path}")
    text = p.read_text(encoding="utf-8")
    meta, body_with_title = _parse_frontmatter(text)
    title, body = _extract_title_and_body(body_with_title)
    if not title:
        die(f"no title found in {path} (expected H1 at top of file or title: in frontmatter)")
    if meta.get("title"):
        title = str(meta["title"])
    team = team_override or meta.get("team")
    if not team:
        team = cfg.get("LINEAR_TEAM_ID", "").strip() or None
    if not team:
        die(
            "no team specified for --from-markdown.\n"
            "  Fix: pass --team, add `team: LOA` to frontmatter, or set LINEAR_TEAM_ID."
        )
    labels = meta.get("labels") or []
    if isinstance(labels, str):
        labels = [labels]
    priority = meta.get("priority")
    if priority is not None:
        try:
            priority = int(priority)
        except (ValueError, TypeError):
            die(f"frontmatter priority must be int 0-4, got {priority!r}")
    return create_issue(
        title=title,
        team=str(team),
        project=meta.get("project"),
        body=body or None,
        labels=[str(x) for x in labels] if labels else None,
        priority=priority,
        assignee=meta.get("assignee"),
        cfg=cfg,
    )


def update_issue(
    ref: str,
    *,
    title: Optional[str] = None,
    state: Optional[str] = None,
    assignee: Optional[str] = None,
    labels: Optional[list[str]] = None,
    priority: Optional[int] = None,
    project: Optional[str] = None,
    cfg: dict[str, str],
) -> dict[str, Any]:
    issue_id = _resolve_issue_id(ref, cfg)
    # Need team context for state/label resolution — pull lightweight.
    query = "query I($id: String!) { issue(id: $id) { id team { id key name } } }"
    data = _gql(query, {"id": issue_id}, cfg=cfg)
    issue = (data or {}).get("issue") or {}
    team_id = (issue.get("team") or {}).get("id")

    inp: dict[str, Any] = {}
    if title is not None:
        inp["title"] = title
    if state is not None:
        if not team_id:
            die("cannot resolve state without team context on the issue")
        st = resolve_state(state, team_id, cfg)
        inp["stateId"] = st["id"]
    if assignee is not None:
        u = resolve_user(assignee, cfg)
        inp["assigneeId"] = u["id"]
    if labels is not None:
        inp["labelIds"] = resolve_labels(labels, team_id, cfg)
    if priority is not None:
        if priority < 0 or priority > 4:
            die("--priority must be 0-4")
        inp["priority"] = priority
    if project is not None:
        p = resolve_project(project, team_id, cfg)
        inp["projectId"] = p["id"]

    if not inp:
        die("no update fields given")

    mutation = """
    mutation UpdateIssue($id: String!, $input: IssueUpdateInput!) {
      issueUpdate(id: $id, input: $input) {
        success
        issue {
          id identifier title
          state { name }
          assignee { name email }
          labels(first: 10) { nodes { name } }
        }
      }
    }
    """
    data = _gql(mutation, {"id": issue_id, "input": inp}, cfg=cfg)
    result = (data or {}).get("issueUpdate") or {}
    if not result.get("success"):
        raise LinearError("issueUpdate returned success=false")
    return result.get("issue") or {}


def move_issue(
    ref: str,
    state_name: str,
    *,
    wait: bool,
    timeout: int,
    cfg: dict[str, str],
) -> dict[str, Any]:
    # Mutation is instant. `--wait` is for webhook-driven transitions: you move
    # to "In Review" and wait for Linear's PR integration to push "Done".
    updated = update_issue(ref, state=state_name, cfg=cfg)
    if not wait:
        return {"status": "moved", "issue": updated}

    issue_id = _resolve_issue_id(ref, cfg)
    deadline = time.monotonic() + timeout
    target_norm = state_name.lower()
    last: dict[str, Any] = updated
    while time.monotonic() < deadline:
        data = _gql(
            "query I($id: String!) { issue(id: $id) { id identifier title state { name type } } }",
            {"id": issue_id}, cfg=cfg,
        )
        last = (data or {}).get("issue") or last
        cur = ((last.get("state") or {}).get("name") or "").lower()
        if cur == target_norm or target_norm in cur:
            return {"status": "moved", "issue": last}
        time.sleep(WAIT_POLL_INTERVAL)
    return {"status": "timeout", "lastKnown": last, "target": state_name}


def assign_issue(ref: str, assignee: str, cfg: dict[str, str]) -> dict[str, Any]:
    return update_issue(ref, assignee=assignee, cfg=cfg)


# ──────────────────────────── comments ────────────────────────────


def add_comment(issue_ref: str, body: str, cfg: dict[str, str]) -> dict[str, Any]:
    issue_id = _resolve_issue_id(issue_ref, cfg)
    body_text = _normalise_markdown(_load_body_arg(body))
    mutation = """
    mutation AddComment($input: CommentCreateInput!) {
      commentCreate(input: $input) {
        success
        comment {
          id body createdAt
          user { name email }
          issue { id identifier }
        }
      }
    }
    """
    data = _gql(mutation, {"input": {"issueId": issue_id, "body": body_text}}, cfg=cfg)
    result = (data or {}).get("commentCreate") or {}
    if not result.get("success"):
        raise LinearError("commentCreate returned success=false")
    return result.get("comment") or {}


def list_comments(issue_ref: str, cfg: dict[str, str]) -> list[dict[str, Any]]:
    issue_id = _resolve_issue_id(issue_ref, cfg)
    query = """
    query Comments($id: String!) {
      issue(id: $id) {
        comments(first: 100) {
          nodes {
            id body createdAt updatedAt
            user { name email displayName }
          }
        }
      }
    }
    """
    data = _gql(query, {"id": issue_id}, cfg=cfg)
    comments = ((data or {}).get("issue") or {}).get("comments") or {}
    nodes = comments.get("nodes") or []
    for c in nodes:
        if c.get("body"):
            c["body"] = _normalise_markdown(c["body"])
    return nodes


# ──────────────────────────── projects / teams / meta ────────────────────────────


def list_projects(team: Optional[str], cfg: dict[str, str]) -> list[dict[str, Any]]:
    team_id = None
    if team:
        team_id = resolve_team(team, cfg)["id"]
    return _list_projects(team_id, cfg)


def project_overview(name: str, bucket_limit: int, cfg: dict[str, str]) -> dict[str, Any]:
    """State-bucketed project snapshot with milestones + recent activity.

    Buckets: backlog / todo / inProgress / inReview / done / canceled.
    Each capped at `bucket_limit` (default 25, max 100).
    """
    lim = max(1, min(bucket_limit, MAX_BUCKET_LIMIT))
    # Resolve via the general (team-less) cache first.
    project = resolve_project(name, None, cfg)
    pid = project["id"]

    # One fetch — pull all the pieces we need. Linear doesn't support multi-alias
    # well across varying first: caps, so we issue one combined query.
    query = """
    query Overview($id: String!, $first: Int!) {
      project(id: $id) {
        id name description state progress targetDate
        lead { id name email }
        teams(first: 10) { nodes { id key name } }
        projectMilestones(first: 50) {
          nodes { id name targetDate sortOrder }
        }
        issues(first: $first, orderBy: updatedAt) {
          nodes {
            id identifier title priority updatedAt createdAt
            state { name type }
            assignee { name email }
            labels(first: 5) { nodes { name } }
          }
          pageInfo { hasNextPage endCursor }
        }
      }
    }
    """
    data = _gql(query, {"id": pid, "first": min(lim * 6, 250)}, cfg=cfg)
    p = (data or {}).get("project") or {}
    issues = ((p.get("issues") or {}).get("nodes")) or []

    buckets: dict[str, list[dict[str, Any]]] = {
        "backlog": [], "todo": [], "inProgress": [],
        "inReview": [], "done": [], "canceled": [],
    }
    type_map = {
        "backlog": "backlog",
        "unstarted": "todo",
        "started": "inProgress",
        # Linear has no native "in review" type; surface by name if present.
        "completed": "done",
        "canceled": "canceled",
    }
    for issue in issues:
        t = ((issue.get("state") or {}).get("type") or "").lower()
        n = ((issue.get("state") or {}).get("name") or "").lower()
        bucket = type_map.get(t)
        if bucket is None and "review" in n:
            bucket = "inReview"
        if bucket is None:
            continue
        if len(buckets[bucket]) < lim:
            buckets[bucket].append(issue)

    total = len(issues)
    open_count = len(buckets["backlog"]) + len(buckets["todo"]) + len(buckets["inProgress"]) + len(buckets["inReview"])
    completed = len(buckets["done"])
    pct = (completed / total * 100.0) if total else 0.0

    # Recent activity: last N comments + state changes across the issue set.
    # Cheap path — comments-per-issue would be N+1. Instead, pull a flat
    # comments-by-project via a small issue filter.
    activity: list[dict[str, Any]] = []
    for issue in issues[:DEFAULT_ACTIVITY_LIMIT]:
        activity.append({
            "issue": issue.get("identifier"),
            "title": issue.get("title"),
            "state": (issue.get("state") or {}).get("name"),
            "updatedAt": issue.get("updatedAt"),
        })

    return {
        "project": {
            "id": p.get("id"),
            "name": p.get("name"),
            "description": p.get("description"),
            "state": p.get("state"),
            "progress": p.get("progress"),
            "targetDate": p.get("targetDate"),
            "lead": p.get("lead"),
            "teams": ((p.get("teams") or {}).get("nodes")) or [],
        },
        "milestones": ((p.get("projectMilestones") or {}).get("nodes")) or [],
        "issuesByState": buckets,
        "activity": activity,
        "counts": {
            "total": total,
            "open": open_count,
            "completed": completed,
            "percentComplete": round(pct, 1),
        },
        "caps": {
            "perBucket": f"{lim} (max {MAX_BUCKET_LIMIT})",
            "activity": DEFAULT_ACTIVITY_LIMIT,
            "milestones": "unbounded up to 50",
        },
    }


def list_teams_cmd(cfg: dict[str, str]) -> list[dict[str, Any]]:
    return _list_teams(cfg)


def list_states_cmd(team: str, cfg: dict[str, str]) -> list[dict[str, Any]]:
    team_obj = resolve_team(team, cfg)
    return _list_states(team_obj["id"], cfg)


def list_labels_cmd(team: Optional[str], cfg: dict[str, str]) -> list[dict[str, Any]]:
    team_id = None
    if team:
        team_id = resolve_team(team, cfg)["id"]
    return _list_labels(team_id, cfg)


def list_cycles_cmd(team: str, cfg: dict[str, str]) -> list[dict[str, Any]]:
    team_obj = resolve_team(team, cfg)
    query = """
    query Cycles($teamId: ID!) {
      cycles(filter: { team: { id: { eq: $teamId } } }, first: 50) {
        nodes { id number name startsAt endsAt completedAt progress }
      }
    }
    """
    data = _gql(query, {"teamId": team_obj["id"]}, cfg=cfg)
    return ((data or {}).get("cycles") or {}).get("nodes") or []


# ──────────────────────────── emit ────────────────────────────


def emit_json(obj: Any, *, pretty: bool = False) -> None:
    scrubbed = _scrub(obj)
    if pretty:
        print(json.dumps(scrubbed, indent=2, sort_keys=False, default=str))
    else:
        print(json.dumps(scrubbed, default=str))


# ──────────────────────────── CLI ────────────────────────────


def _add_common_args(p: argparse.ArgumentParser) -> None:
    p.add_argument("--api-key", help="LINEAR_API_KEY (override env)")
    p.add_argument("--team", dest="team_cfg", help="LINEAR_TEAM_ID default (override env)")
    p.add_argument("--env-file", help="explicit .env file path")
    p.add_argument("--pretty", action="store_true", help="indent JSON output")


def _cfg_from_args(args: argparse.Namespace) -> dict[str, str]:
    cfg = load_config(env_file=getattr(args, "env_file", None))
    if getattr(args, "api_key", None):
        cfg["LINEAR_API_KEY"] = args.api_key
    if getattr(args, "team_cfg", None):
        cfg["LINEAR_TEAM_ID"] = args.team_cfg
    return cfg


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="linear-remote",
        description=(
            "Read-first Linear GraphQL API wrapper. One call returns an issue's "
            "full context (comments + relations + state). Name-resolved. Zero "
            "API-key leakage."
        ),
        epilog=(
            "Examples:\n"
            "  linear-remote issues get LOA-229 --include-comments --pretty\n"
            "  linear-remote issues list --project 'Agent Plus' --state 'In Progress'\n"
            "  linear-remote issues create --from-markdown design-doc.md --team LOA\n"
            "  linear-remote issues move LOA-229 'In Review' --wait --timeout 120\n"
            "  linear-remote projects overview 'Agent Plus' --pretty\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    _add_common_args(p)
    sub = p.add_subparsers(dest="cmd", required=True)

    # issues
    si = sub.add_parser(
        "issues", help="issue get / list / search / create / update / move / assign",
        description="Example:\n  linear-remote issues get LOA-229 --include-comments",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    si_sub = si.add_subparsers(dest="action", required=True)

    sig = si_sub.add_parser(
        "get",
        description=(
            "Fetch a single issue with optional comments and relations.\n\n"
            "Accepts UUID, human key (LOA-123), or free-text (searched).\n\n"
            "Example:\n  linear-remote issues get LOA-229 --include-comments --include-relations"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sig.add_argument("ref", help="issue UUID, human key (LOA-123), or search query")
    sig.add_argument("--include-comments", action="store_true")
    sig.add_argument("--include-relations", action="store_true")

    sil = si_sub.add_parser(
        "list",
        description="Example:\n  linear-remote issues list --team LOA --state 'In Progress' --limit 50",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sil.add_argument("--project")
    sil.add_argument("--state")
    sil.add_argument("--assignee", help="name, email, or UUID")
    sil.add_argument("--team-filter", dest="team_filter", help="team key or name")
    sil.add_argument("--label", help="label name or UUID")
    sil.add_argument("--limit", type=int, default=DEFAULT_LIST_LIMIT,
                     help=f"default {DEFAULT_LIST_LIMIT}, max {MAX_LIST_LIMIT}")
    sil.add_argument("--cursor", help="pageInfo.endCursor from previous page")

    sis = si_sub.add_parser(
        "search",
        description="Example:\n  linear-remote issues search 'redis timeout' --limit 10",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sis.add_argument("query")
    sis.add_argument("--limit", type=int, default=DEFAULT_LIST_LIMIT)

    sic = si_sub.add_parser(
        "create",
        description=(
            "Create an issue. Two forms:\n"
            "  (a) --title <t> --team <name> [--project ...] [--body ... | --body @file]\n"
            "      [--labels a,b] [--priority 0-4] [--assignee email]\n"
            "  (b) --from-markdown <path> [--team <name>]\n"
            "      Uses the first H1 as title, rest as body. YAML frontmatter keys:\n"
            "      team, project, labels, assignee, priority.\n\n"
            "Example:\n  linear-remote issues create --from-markdown ./rfcs/cache.md --team LOA"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sic.add_argument("--title")
    sic.add_argument("--team", dest="create_team")
    sic.add_argument("--project")
    sic.add_argument("--body", help="description (use @path to read from a file)")
    sic.add_argument("--labels", help="comma-separated label names or IDs")
    sic.add_argument("--priority", type=int, help="0=none 1=urgent 2=high 3=medium 4=low")
    sic.add_argument("--assignee", help="name, email, or UUID")
    sic.add_argument("--from-markdown", dest="from_markdown", help="path to a markdown file")

    siu = si_sub.add_parser(
        "update",
        description="Example:\n  linear-remote issues update LOA-229 --state 'In Review' --priority 2",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    siu.add_argument("ref")
    siu.add_argument("--title")
    siu.add_argument("--state")
    siu.add_argument("--assignee")
    siu.add_argument("--labels", help="comma-separated label names or IDs")
    siu.add_argument("--priority", type=int)
    siu.add_argument("--project")

    sim = si_sub.add_parser(
        "move",
        description=(
            "Move an issue to a target state. `--wait` polls until the issue\n"
            "reaches the target state - for webhook-driven transitions (PR -> Done).\n"
            "Default timeout 60s, poll every 3s. On timeout: non-zero exit, partial JSON.\n\n"
            "Example:\n  linear-remote issues move LOA-229 'In Review' --wait --timeout 120"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sim.add_argument("ref")
    sim.add_argument("state")
    sim.add_argument("--wait", action="store_true")
    sim.add_argument("--timeout", type=int, default=WAIT_DEFAULT_TIMEOUT,
                     help=f"wait timeout seconds (default {WAIT_DEFAULT_TIMEOUT})")

    sia = si_sub.add_parser(
        "assign",
        description="Example:\n  linear-remote issues assign LOA-229 alice@example.com",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sia.add_argument("ref")
    sia.add_argument("assignee")

    # comments
    sc = sub.add_parser("comments", help="comment add / list")
    sc_sub = sc.add_subparsers(dest="action", required=True)
    sca = sc_sub.add_parser(
        "add",
        description="Example:\n  linear-remote comments add LOA-229 @./review-notes.md",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sca.add_argument("issue")
    sca.add_argument("body", help="comment body (use @path to read from file)")
    scl = sc_sub.add_parser(
        "list",
        description="Example:\n  linear-remote comments list LOA-229 --pretty",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    scl.add_argument("issue")

    # projects
    sp = sub.add_parser("projects", help="project list / overview")
    sp_sub = sp.add_subparsers(dest="action", required=True)
    spl = sp_sub.add_parser(
        "list",
        description="Example:\n  linear-remote projects list --team LOA",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    spl.add_argument("--team-filter", dest="team_filter", help="team key or name")
    spo = sp_sub.add_parser(
        "overview",
        description=(
            "Bounded project snapshot: metadata + milestones + state-bucketed issues\n"
            "(backlog / todo / inProgress / inReview / done / canceled) + recent activity.\n\n"
            "Example:\n  linear-remote projects overview 'Agent Plus' --pretty"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    spo.add_argument("name")
    spo.add_argument("--bucket-limit", type=int, default=DEFAULT_BUCKET_LIMIT,
                     help=f"per-bucket issue cap (default {DEFAULT_BUCKET_LIMIT}, max {MAX_BUCKET_LIMIT})")

    # teams
    st = sub.add_parser("teams", help="team list")
    st_sub = st.add_subparsers(dest="action", required=True)
    st_sub.add_parser(
        "list",
        description="Example:\n  linear-remote teams list --pretty",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    # states
    sst = sub.add_parser(
        "states", help="list workflow states for a team",
        description="Example:\n  linear-remote states LOA",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sst.add_argument("team_name")

    # labels
    slb = sub.add_parser(
        "labels", help="list labels (team-scoped or workspace)",
        description="Example:\n  linear-remote labels --team LOA",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    slb.add_argument("--team-filter", dest="team_filter", help="team key or name")

    # cycles
    scy = sub.add_parser(
        "cycles", help="list cycles for a team",
        description="Example:\n  linear-remote cycles LOA",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    scy.add_argument("team_name")

    return p


def _split_csv(s: Optional[str]) -> Optional[list[str]]:
    if s is None:
        return None
    parts = [x.strip() for x in s.split(",") if x.strip()]
    return parts


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    cfg = _cfg_from_args(args)

    try:
        if args.cmd == "issues":
            if args.action == "get":
                emit_json(
                    get_issue(args.ref, args.include_comments, args.include_relations, cfg),
                    pretty=args.pretty,
                )
            elif args.action == "list":
                result = list_issues(
                    project=args.project,
                    state=args.state,
                    assignee=args.assignee,
                    team=args.team_filter,
                    label=args.label,
                    limit=args.limit,
                    cursor=args.cursor,
                    cfg=cfg,
                )
                emit_json(result, pretty=args.pretty)
            elif args.action == "search":
                emit_json(_search_issues(args.query, args.limit, cfg), pretty=args.pretty)
            elif args.action == "create":
                if args.from_markdown:
                    issue = create_from_markdown(args.from_markdown, args.create_team, cfg)
                else:
                    if not args.title:
                        die("issues create requires --title (or --from-markdown)")
                    if not args.create_team:
                        if not cfg.get("LINEAR_TEAM_ID"):
                            die("issues create requires --team (or LINEAR_TEAM_ID)")
                    body = _load_body_arg(args.body) if args.body else None
                    issue = create_issue(
                        title=args.title,
                        team=args.create_team or cfg.get("LINEAR_TEAM_ID", ""),
                        project=args.project,
                        body=body,
                        labels=_split_csv(args.labels),
                        priority=args.priority,
                        assignee=args.assignee,
                        cfg=cfg,
                    )
                emit_json(issue, pretty=args.pretty)
            elif args.action == "update":
                emit_json(
                    update_issue(
                        args.ref,
                        title=args.title,
                        state=args.state,
                        assignee=args.assignee,
                        labels=_split_csv(args.labels),
                        priority=args.priority,
                        project=args.project,
                        cfg=cfg,
                    ),
                    pretty=args.pretty,
                )
            elif args.action == "move":
                result = move_issue(args.ref, args.state, wait=args.wait, timeout=args.timeout, cfg=cfg)
                emit_json(result, pretty=args.pretty)
                if result.get("status") == "timeout":
                    return 2
            elif args.action == "assign":
                emit_json(assign_issue(args.ref, args.assignee, cfg), pretty=args.pretty)

        elif args.cmd == "comments":
            if args.action == "add":
                emit_json(add_comment(args.issue, args.body, cfg), pretty=args.pretty)
            elif args.action == "list":
                emit_json(list_comments(args.issue, cfg), pretty=args.pretty)

        elif args.cmd == "projects":
            if args.action == "list":
                emit_json(list_projects(args.team_filter, cfg), pretty=args.pretty)
            elif args.action == "overview":
                emit_json(project_overview(args.name, args.bucket_limit, cfg), pretty=args.pretty)

        elif args.cmd == "teams":
            if args.action == "list":
                emit_json(list_teams_cmd(cfg), pretty=args.pretty)

        elif args.cmd == "states":
            emit_json(list_states_cmd(args.team_name, cfg), pretty=args.pretty)

        elif args.cmd == "labels":
            emit_json(list_labels_cmd(args.team_filter, cfg), pretty=args.pretty)

        elif args.cmd == "cycles":
            emit_json(list_cycles_cmd(args.team_name, cfg), pretty=args.pretty)

        return 0
    except LinearError as e:
        die(str(e))
    except KeyboardInterrupt:
        die("interrupted", code=130)
    return 0


if __name__ == "__main__":
    sys.exit(main())
