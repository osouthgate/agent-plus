        "to use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n"
        "copies of the Software, and to permit persons to whom the Software is\n"
        "furnished to do so, subject to the following conditions:\n\n"
        "The above copyright notice and this permission notice shall be included in all\n"
        "copies or substantial portions of the Software.\n\n"
        "THE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n"
        "IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n"
        "FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n"
        "AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n"
        "LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n"
        "OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n"
        "SOFTWARE.\n"
    )


def _marketplace_readme(owner: str, name: str) -> str:
    return (
        f"# {name}\n\n"
        f"An [agent-plus](https://github.com/osouthgate/agent-plus) marketplace published by **{owner}**.\n\n"
        "This repo follows the `<user>/agent-plus-skills` convention: every skill it ships\n"
        "is declared in [`marketplace.json`](./marketplace.json) at the repo root.\n\n"
        "## Install\n\n"
        "```bash\n"
        f"agent-plus-meta marketplace install {owner}/{name}\n"
        "```\n\n"
        "(Phase 2 — install is not implemented yet. For now, clone manually:)\n\n"
        "```bash\n"
        f"git clone https://github.com/{owner}/{name}.git ~/.agent-plus/marketplaces/{owner}-{name}\n"
        "```\n\n"
        "## Discovery\n\n"
        "This repo is tagged with the `agent-plus-skills` GitHub topic so it surfaces in:\n\n"
        "```bash\n"
        "gh search repos topic:agent-plus-skills\n"
        "```\n\n"
        "## Schema\n\n"
        "See the [marketplace convention](https://github.com/osouthgate/agent-plus) for the full\n"
        "`marketplace.json` schema. This repo declares `agent_plus_version: \""
        + MARKETPLACE_AGENT_PLUS_RANGE
        + "\"` and `surface: \"claude-code\"`.\n\n"
        "## License\n\n"
        "MIT — see [LICENSE](./LICENSE).\n"
    )


_MARKETPLACE_GITIGNORE = (
    "# agent-plus-meta marketplace\n"
    ".DS_Store\n"
    "Thumbs.db\n"
    "*.swp\n"
    "*.bak\n"
    ".idea/\n"
    ".vscode/\n"
    "__pycache__/\n"
    "*.py[cod]\n"
    "node_modules/\n"
    ".env\n"
    ".env.local\n"
)


def _marketplace_changelog(owner: str, name: str) -> str:
    today = _dt.datetime.now(_dt.timezone.utc).strftime("%Y-%m-%d")
    return (
        f"# {name} — changelog\n\n"
        "All notable changes to this marketplace.\n\n"
        "Format: one entry per change, most recent first. Date format `YYYY-MM-DD`.\n\n"
        "## Unreleased\n\n"
        f"## 0.1.0 - {today}\n\n"
        f"Initial scaffold via `agent-plus-meta marketplace init {owner}/{name}`.\n\n"
        "### Added\n\n"
        "- `marketplace.json` with empty `skills: []` and `agent_plus_version: \""
        + MARKETPLACE_AGENT_PLUS_RANGE
        + "\"`.\n"
        "- README, MIT LICENSE, .gitignore.\n"
    )


def _marketplace_json(owner: str, name: str) -> dict[str, Any]:
    return {
        "name": name,
        "owner": owner,
        "version": MARKETPLACE_SCHEMA_VERSION,
        "agent_plus_version": MARKETPLACE_AGENT_PLUS_RANGE,
        "surface": MARKETPLACE_DEFAULT_SURFACE,
        "skills": [],
        "homepage": f"https://github.com/{owner}/{name}",
        "license": "MIT",
    }


def _marketplace_dir_is_empty(path: Path) -> bool:
    """A directory is 'empty' if it doesn't exist OR it exists with no children."""
    if not path.exists():
        return True
    if not path.is_dir():
        return False
    try:
        next(path.iterdir())
    except StopIteration:
        return True
    except OSError:
        return False
    return False


def _git_init_in(path: Path) -> tuple[bool, Optional[str]]:
    """Run `git init` in path. Returns (initialized, note).
    note is set if git is missing or init failed; not a hard error."""
    if shutil.which("git") is None:
        return False, "git not found on PATH; skipped `git init`"
    try:
        proc = subprocess.run(
            ["git", "init", "--quiet"],
            capture_output=True, text=True, timeout=10,
            cwd=str(path), check=False,
        )
    except (OSError, subprocess.SubprocessError) as e:
        return False, f"git init failed to spawn: {e}"
    if proc.returncode != 0:
        msg = (proc.stderr or proc.stdout or "").strip()
        return False, f"git init exited {proc.returncode}: {msg[:160]}"
    # Windows hygiene: pin core.autocrlf=false on the new repo so files we
    # write later (skill bins with shebangs, JSON manifests Python re-reads)
    # don't get CRLF-mangled on checkout. Best-effort — git is already
    # confirmed present and exit code is captured but not surfaced as a
    # hard error since the init itself succeeded.
    try:
        subprocess.run(
            ["git", "config", "--local", "core.autocrlf", "false"],
            capture_output=True, text=True, timeout=5,
            cwd=str(path), check=False,
        )
    except (OSError, subprocess.SubprocessError):
        pass
    return True, None


def cmd_marketplace_init(args: argparse.Namespace) -> dict:
    slug = args.slug
    m = MARKETPLACE_SLUG_RE.match(slug)
    if not m:
        return {"error": f"invalid slug {slug!r}; expected `<user>/<name>`"}
    owner, name = m.group(1), m.group(2)

    if name != MARKETPLACE_REQUIRED_NAME:
        return {
            "error": (
                f"v1 reserves the marketplace name `{MARKETPLACE_REQUIRED_NAME}`; "
                f"got `{name}`"
            ),
            "slug": slug,
        }

    # Resolve target directory.
    if args.path:
        target = Path(args.path).expanduser().resolve()
    else:
        target = (Path.cwd() / name).resolve()

    if not _marketplace_dir_is_empty(target):
        return {
            "error": f"target directory exists and is non-empty: {target}",
            "path": str(target),
        }

    target.mkdir(parents=True, exist_ok=True)

    files_written: list[str] = []

    # marketplace.json
    mj_path = target / "marketplace.json"
    mj_path.write_text(
        json.dumps(_marketplace_json(owner, name), indent=2) + "\n",
        encoding="utf-8",
    )
    files_written.append("marketplace.json")

    # README.md
    (target / "README.md").write_text(_marketplace_readme(owner, name), encoding="utf-8")
    files_written.append("README.md")

    # LICENSE
    year = _dt.datetime.now(_dt.timezone.utc).year
    (target / "LICENSE").write_text(_mit_license_text(year, owner), encoding="utf-8")
    files_written.append("LICENSE")

    # .gitignore
    (target / ".gitignore").write_text(_MARKETPLACE_GITIGNORE, encoding="utf-8")
    files_written.append(".gitignore")

    # CHANGELOG.md
    (target / "CHANGELOG.md").write_text(
        _marketplace_changelog(owner, name), encoding="utf-8",
    )
    files_written.append("CHANGELOG.md")

    # git init (best-effort).
    git_initialized, git_note = _git_init_in(target)

    next_steps = [
        f"gh repo create {owner}/{name} --public --source . --remote origin",
        f"gh repo edit {owner}/{name} --add-topic agent-plus-skills",
        f"gh repo edit {owner}/{name} --add-topic claude-code",
    ]

    payload: dict[str, Any] = {
        "marketplace": {
            "path": str(target),
            "owner": owner,
            "name": name,
            "files_written": files_written,
            "git_initialized": git_initialized,
            "next_steps": next_steps,
        },
    }
    if git_note:
        payload["marketplace"]["git_note"] = git_note
    return payload


# ─── marketplace lifecycle (Phase 2) ─────────────────────────────────────────
#
# install / list / update / remove. Trust gates per
# plans/todo/2026-04-28-marketplace-convention.md "Trust model":
#   1. Pin to commit SHA at install.
#   2. First-run review prompt — once per install, re-armed on update accept.
#   3. No automatic updates (--cron explicitly refused).
#   4. No execution at install time. Clone + parse JSON + filesystem move only.
#   5. Optional checksum verification when marketplace.json declares them.

MARKETPLACE_META_FILENAME = ".agent-plus-meta.json"
MARKETPLACE_RESERVED_SURFACES = frozenset({"claude-ai", "universal"})


def _marketplaces_root() -> Path:
    """Return the user-state marketplaces directory.

    Defaults to ~/.agent-plus/marketplaces/. The AGENT_PLUS_MARKETPLACES_ROOT
    env var overrides for tests so the suite never touches a real install.
    """
    override = os.environ.get("AGENT_PLUS_MARKETPLACES_ROOT")
    if override:
        return Path(override).expanduser().resolve()
    return (Path.home() / ".agent-plus" / "marketplaces").resolve()


def _marketplace_state_dir(owner: str, name: str) -> Path:
    return _marketplaces_root() / f"{owner}-{name}"


def _read_marketplace_meta(state_dir: Path) -> Optional[dict]:
    p = state_dir / MARKETPLACE_META_FILENAME
    if not p.is_file():
        return None
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def _write_marketplace_meta(state_dir: Path, meta: dict) -> None:
    p = state_dir / MARKETPLACE_META_FILENAME
    p.write_text(json.dumps(meta, indent=2) + "\n", encoding="utf-8")


def _marketplace_accepted(state_dir: Path) -> bool:
    """Return True if the marketplace's first-run prompt has been accepted."""
    meta = _read_marketplace_meta(state_dir)
    return bool(meta and meta.get("accepted_first_run") is True)


# ── semver-range checking (minimal, stdlib-only) ────────────────────────────

_VERSION_RE = re.compile(r"^(\d+)(?:\.(\d+))?(?:\.(\d+))?")
_RANGE_CLAUSE_RE = re.compile(
    r"^\s*(>=|<=|>|<|==|=)?\s*([0-9][0-9A-Za-z\.\-+]*)\s*$"
)


def _parse_version_tuple(s: str) -> tuple[int, int, int]:
    m = _VERSION_RE.match(s.strip().lstrip("v"))
    if not m:
        raise ValueError(f"unparseable version: {s!r}")
    return (int(m.group(1)), int(m.group(2) or 0), int(m.group(3) or 0))


def _validate_range_spec(range_spec: Any) -> bool:
    if not isinstance(range_spec, str) or not range_spec.strip():
        return False
    for clause in range_spec.split(","):
        if not _RANGE_CLAUSE_RE.match(clause.strip()):
            return False
    return True


def _satisfies_range(version: str, range_spec: str) -> bool:
    try:
        v = _parse_version_tuple(version)
    except ValueError:
        return False
    for clause in range_spec.split(","):
        clause = clause.strip()
        if not clause:
            continue
        m = _RANGE_CLAUSE_RE.match(clause)
        if not m:
            return False
        op = m.group(1) or "=="
        try:
            target = _parse_version_tuple(m.group(2))
        except ValueError:
            return False
        if op == ">=" and not (v >= target):
            return False
        if op == ">" and not (v > target):
            return False
        if op == "<=" and not (v <= target):
            return False
        if op == "<" and not (v < target):
            return False
        if op in ("==", "=") and not (v == target):
            return False
    return True


# ── deterministic plugin-dir checksum ───────────────────────────────────────

def _plugin_dir_checksum(plugin_dir: Path) -> str:
    """SHA-256 of a deterministic tar of every regular file in the plugin
    directory. Metadata zeroed out so the same tree always hashes the same.
    """
    import io
    import tarfile

    buf = io.BytesIO()
    files = sorted(p for p in plugin_dir.rglob("*") if p.is_file())
    with tarfile.open(fileobj=buf, mode="w", format=tarfile.USTAR_FORMAT) as tar:
        for path in files:
            arcname = path.relative_to(plugin_dir).as_posix()
            data = path.read_bytes()
            ti = tarfile.TarInfo(name=arcname)
            ti.size = len(data)
            ti.mtime = 0
            ti.uid = 0
            ti.gid = 0
            ti.uname = ""
            ti.gname = ""
            ti.mode = 0o644
            tar.addfile(ti, io.BytesIO(data))
    return hashlib.sha256(buf.getvalue()).hexdigest()


# ── git helpers ─────────────────────────────────────────────────────────────

def _git_clone_shallow(url: str, dest: Path) -> tuple[bool, Optional[str]]:
    if shutil.which("git") is None:
        return False, "git not found on PATH"
    try:
        # `--` separator is load-bearing: prevents a URL that starts with `--`
        # from being parsed as a flag by git (CVE-2017-1000117 shape). The
        # default URL is https://... and safe; the `--url` override is the
        # exposure vector. Kept paranoid by design.
        proc = subprocess.run(
            ["git", "-c", "protocol.version=2", "clone", "--depth", "1",
             "--", url, str(dest)],
            capture_output=True, text=True, timeout=180, check=False,
        )
    except (OSError, subprocess.SubprocessError) as e:
        return False, f"git clone spawn failed: {e}"
    if proc.returncode != 0:
        msg = (proc.stderr or proc.stdout or "git clone failed").strip()
        return False, msg[:400]
    return True, None


def _git_head_sha(repo: Path) -> Optional[str]:
    try:
        proc = subprocess.run(
            ["git", "rev-parse", "HEAD"],
            capture_output=True, text=True, timeout=10,
            cwd=str(repo), check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if proc.returncode != 0:
        return None
    sha = proc.stdout.strip()
    return sha or None


def _git_show_at(repo: Path, sha: str, path: str) -> Optional[str]:
    try:
        proc = subprocess.run(
            ["git", "show", f"{sha}:{path}"],
            capture_output=True, text=True, timeout=10,
            cwd=str(repo), check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout


def _resolve_origin_default_branch(repo: Path) -> Optional[str]:
    try:
        proc = subprocess.run(
            ["git", "symbolic-ref", "refs/remotes/origin/HEAD"],
            capture_output=True, text=True, timeout=5,
            cwd=str(repo), check=False,
        )
        if proc.returncode == 0:
            ref = proc.stdout.strip()
            prefix = "refs/remotes/origin/"
            if ref.startswith(prefix):
                return ref[len(prefix):]
    except (OSError, subprocess.SubprocessError):
        pass
    for guess in ("main", "master"):
        try:
            proc = subprocess.run(
                ["git", "rev-parse", f"origin/{guess}"],
                capture_output=True, text=True, timeout=5,
                cwd=str(repo), check=False,
            )
            if proc.returncode == 0:
                return guess
        except (OSError, subprocess.SubprocessError):
            continue
    return None


# ── marketplace.json validation ─────────────────────────────────────────────

def _validate_marketplace_json(
    data: Any, owner: str, clone_root: Path,
) -> tuple[bool, list[str], dict]:
    """Pure validator: parses the cloned marketplace.json and the plugin
    manifests it points at. Never executes anything from the clone."""
    errs: list[str] = []
    if not isinstance(data, dict):
        return False, ["marketplace.json: not a JSON object"], {}

    name = data.get("name")
    if name != MARKETPLACE_REQUIRED_NAME:
        errs.append(
            f"marketplace.json: name must be {MARKETPLACE_REQUIRED_NAME!r}, "
            f"got {name!r}"
        )

    declared_owner = data.get("owner")
    if declared_owner != owner:
        errs.append(
            f"marketplace.json: owner {declared_owner!r} does not match URL "
            f"slug owner {owner!r}"
        )

    apv = data.get("agent_plus_version")
    if not _validate_range_spec(apv):
        errs.append(
            f"marketplace.json: agent_plus_version is malformed: {apv!r}"
        )
    else:
        fw = _plugin_version()
        if not _satisfies_range(fw, apv):
            errs.append(
                f"marketplace.json: framework version {fw} does not satisfy "
                f"agent_plus_version={apv!r}"
            )

    surface = data.get("surface", MARKETPLACE_DEFAULT_SURFACE)
    if surface in MARKETPLACE_RESERVED_SURFACES:
        errs.append(
            f"marketplace.json: surface {surface!r} is reserved for future use"
        )
    elif surface != MARKETPLACE_DEFAULT_SURFACE:
        errs.append(
            f"marketplace.json: unsupported surface {surface!r}"
        )

    skills = data.get("skills", [])
    if not isinstance(skills, list):
        errs.append("marketplace.json: skills must be a list")
        skills = []

    plugin_summaries: list[dict] = []
    clone_root_resolved = clone_root.resolve()
    for i, s in enumerate(skills):
        if not isinstance(s, dict):
            errs.append(f"skills[{i}]: not an object")
            continue
        sname = s.get("name")
        sver = s.get("version")
        spath = s.get("path")
        if not isinstance(sname, str) or not sname:
            errs.append(f"skills[{i}]: missing/invalid name")
            continue
        if not isinstance(sver, str) or not sver:
            errs.append(f"skills[{i}].{sname}: missing/invalid version")
        if not isinstance(spath, str) or not spath:
            errs.append(f"skills[{i}].{sname}: missing/invalid path")
            continue
        plugin_dir = (clone_root / spath).resolve()
        try:
            plugin_dir.relative_to(clone_root_resolved)
        except ValueError:
            errs.append(
                f"skills[{i}].{sname}: path escapes clone root: {spath!r}"
            )
            continue
        if not plugin_dir.is_dir():
            errs.append(
                f"skills[{i}].{sname}: path does not exist in clone: {spath!r}"
            )
            continue
        manifest = plugin_dir / ".claude-plugin" / "plugin.json"
        if not manifest.is_file():
            errs.append(
                f"skills[{i}].{sname}: missing .claude-plugin/plugin.json "
                f"under {spath!r}"
            )
            continue
        try:
            pm = json.loads(manifest.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as e:
            errs.append(
                f"skills[{i}].{sname}: plugin.json unreadable: {e}"
            )
            continue
        if not isinstance(pm, dict):
            errs.append(f"skills[{i}].{sname}: plugin.json not an object")
            continue
        if pm.get("name") != sname:
            errs.append(
                f"skills[{i}].{sname}: plugin.json name {pm.get('name')!r} "
                f"!= marketplace.json name {sname!r}"
            )
        if pm.get("version") != sver:
            errs.append(
                f"skills[{i}].{sname}: plugin.json version "
                f"{pm.get('version')!r} != marketplace.json version {sver!r}"
            )
        plugin_summaries.append({
            "name": sname,
            "version": sver,
            "path": spath,
            "obviates": (
                s["obviates"] if isinstance(s.get("obviates"), list) else []
            ),
        })

    checksums = data.get("checksums")
    if checksums is not None:
        if not isinstance(checksums, dict):
            errs.append("marketplace.json: checksums must be an object")
        else:
            for ps in plugin_summaries:
                expected = checksums.get(ps["name"])
                if expected is None:
                    continue  # partial checksums are allowed
                if not isinstance(expected, str):
                    errs.append(
                        f"checksums.{ps['name']}: must be a string"
                    )
                    continue
                exp = expected[7:] if expected.startswith("sha256:") else expected
                actual = _plugin_dir_checksum(clone_root / ps["path"])
                if actual != exp:
                    errs.append(
                        f"checksum mismatch for {ps['name']}: expected "
                        f"{exp!r}, got {actual!r}"
                    )

    return (not errs), errs, {"plugins": plugin_summaries}


# ── interactive y/n on stdin (default no on EOF) ────────────────────────────

def _read_yes_no(prompt: str) -> bool:
    sys.stderr.write(prompt)
    sys.stderr.flush()
    try:
        line = sys.stdin.readline()
    except (OSError, KeyboardInterrupt):
        return False
    if not line:
        return False
    return line.strip().lower() in ("y", "yes")


def _format_first_run_prompt(
    owner: str, name: str, sha: str, plugins: list[dict],
) -> str:
    lines = [
        "",
        f"=== agent-plus-meta marketplace install: {owner}/{name} ===",
        f"  pinned SHA: {sha}",
        f"  plugins ({len(plugins)}):",
    ]
    obviates_union: set[str] = set()
    for p in plugins:
        lines.append(
            f"    - {p['name']} {p.get('version', '?')}  ({p.get('path', '?')})"
        )
        for o in p.get("obviates") or []:
            if isinstance(o, str):
                obviates_union.add(o)
    if obviates_union:
        lines.append("  obviates (commands these plugins replace):")
        for o in sorted(obviates_union):
            lines.append(f"    - {o}")
    lines.append("")
    lines.append(
        "Install only writes files; no code from the clone has executed."
    )
    lines.append(
        "Plugins from this marketplace will refuse to load until you accept."
    )
    lines.append("")
    lines.append("Accept? [y/N]: ")
    return "\n".join(lines)


# ── install / list / update / remove ────────────────────────────────────────

def cmd_marketplace_install(args: argparse.Namespace) -> dict:
    slug = args.slug
    m = MARKETPLACE_SLUG_RE.match(slug)
    if not m:
        return {"error": f"invalid slug {slug!r}; expected `<user>/<name>`"}
    owner, name = m.group(1), m.group(2)
    if name != MARKETPLACE_REQUIRED_NAME:
        return {
            "error": (
                f"v1 reserves the marketplace name "
                f"`{MARKETPLACE_REQUIRED_NAME}`; got `{name}`"
            ),
            "slug": slug,
        }

    target = _marketplace_state_dir(owner, name)
    if target.exists():
        return {
            "error": (
                f"marketplace already installed at {target}; use "
                f"`marketplace update` or `marketplace remove` first"
            ),
            "path": str(target),
        }

    url = args.url or f"https://github.com/{owner}/{name}.git"

    target.parent.mkdir(parents=True, exist_ok=True)

    # Clone into a sibling temp dir so the move stays on one filesystem.
    with tempfile.TemporaryDirectory(prefix=".clone-", dir=str(target.parent)) as tmp:
        tmp_clone = Path(tmp) / "clone"
        ok, err = _git_clone_shallow(url, tmp_clone)
        if not ok:
            return {"error": f"git clone failed: {err}", "url": url}

        mj_path = tmp_clone / "marketplace.json"
        if not mj_path.is_file():
            return {
                "error": "clone missing marketplace.json at repo root",
                "url": url,
            }
        try:
            mj_data = json.loads(mj_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as e:
            return {"error": f"marketplace.json unreadable: {e}"}

        valid, errs, normalized = _validate_marketplace_json(
            mj_data, owner, tmp_clone,
        )
        if not valid:
            return {
                "error": "marketplace validation failed",
                "validation_errors": errs,
            }

        sha = _git_head_sha(tmp_clone)
        if not sha:
            return {"error": "could not resolve HEAD SHA from clone"}

        # Move the validated clone into place. shutil.move across the same
        # filesystem is a rename; cross-fs falls back to copy+remove.
        shutil.move(str(tmp_clone), str(target))

    plugins = normalized["plugins"]
    meta = {
        "owner": owner,
        "name": name,
        "pinned_sha": sha,
        "installed_at": _now_iso(),
        "framework_version": _plugin_version(),
        "accepted_first_run": False,
    }
    _write_marketplace_meta(target, meta)

    # Trust gate 2: first-run review prompt. Stderr-only; stdout stays JSON.
    accepted = _read_yes_no(
        _format_first_run_prompt(owner, name, sha, plugins)
    )
    if accepted:
        meta["accepted_first_run"] = True
        _write_marketplace_meta(target, meta)
    else:
        sys.stderr.write(
            f"\n[!] Marketplace installed but NOT accepted. Plugins from "
            f"{owner}/{name} will refuse to load until accepted.\n"
            f"    To accept, run `agent-plus-meta marketplace remove "
            f"{owner}/{name}` and re-install, or set "
            f'`accepted_first_run: true` in '
            f"{target / MARKETPLACE_META_FILENAME}.\n\n"
        )

    return {
        "marketplace": {
            "owner": owner,
            "name": name,
            "path": str(target),
            "pinned_sha": sha,
            "plugins_count": len(plugins),
            "first_run_accepted": meta["accepted_first_run"],
        },
    }


def cmd_marketplace_list(args: argparse.Namespace) -> dict:  # noqa: ARG001
    root = _marketplaces_root()
    entries: list[dict] = []
    warnings: list[str] = []
    if not root.is_dir():
        return {"root": str(root), "marketplaces": []}
    for child in sorted(root.iterdir()):
        if not child.is_dir():
            continue
        meta = _read_marketplace_meta(child)
        if meta is None:
            warnings.append(
                f"{child.name}: missing or unreadable "
                f"{MARKETPLACE_META_FILENAME}"
            )
            continue
        plugins_count = 0
        plugins_summary: list[dict] = []
        mj = child / "marketplace.json"
        if mj.is_file():
            try:
                mjd = json.loads(mj.read_text(encoding="utf-8"))
                skills = mjd.get("skills") if isinstance(mjd, dict) else None
                if isinstance(skills, list):
                    plugins_count = len(skills)
                    for s in skills:
                        if isinstance(s, dict) and isinstance(s.get("name"), str):
                            plugins_summary.append({
                                "name": s["name"],
                                "version": s.get("version"),
                            })
            except (OSError, json.JSONDecodeError) as e:
                warnings.append(
                    f"{child.name}: marketplace.json unreadable: {e}"
                )
        entries.append({
            "owner": meta.get("owner"),
            "name": meta.get("name"),
            "path": str(child),
            "pinned_sha": meta.get("pinned_sha"),
            "installed_at": meta.get("installed_at"),
            "framework_version": meta.get("framework_version"),
            "first_run_accepted": bool(meta.get("accepted_first_run")),
            "plugins_count": plugins_count,
            "plugins": plugins_summary,
        })
    out: dict = {"root": str(root), "marketplaces": entries}
    if warnings:
        out["warnings"] = warnings
    return out


def _recency_boost(updated_at: str) -> float:
    """Boost = max(0, 30 - days_since_update) * 2. Empty/unparseable → 0."""
    if not isinstance(updated_at, str) or not updated_at:
        return 0.0
    s = updated_at.replace("Z", "+00:00")
    try:
        dt = _dt.datetime.fromisoformat(s)
    except ValueError:
        return 0.0
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=_dt.timezone.utc)
    now = _dt.datetime.now(_dt.timezone.utc)
    days = (now - dt).total_seconds() / 86400.0
    return max(0.0, 30.0 - days) * 2.0


def cmd_marketplace_search(args: argparse.Namespace) -> dict:
    """Search GitHub for `topic:agent-plus-skills` repos via `gh`.

    Ranks by `stars + recency_boost(updatedAt)`. Stdlib only, list-form
    subprocess. The query is never interpolated into a shell string.
    """
    query = (getattr(args, "query", "") or "").strip()
    if shutil.which("gh") is None:
        return {
            "ok": False,
            "error": "gh_not_installed",
            "hint": "install GitHub CLI: https://cli.github.com/",
        }

    cmd: list[str] = ["gh", "search", "repos"]
    if query:
        cmd.append(query)
    cmd += [
        "--topic", "agent-plus-skills",
        "--json", "name,owner,description,stargazerCount,updatedAt,url",
        "--limit", "30",
    ]

    try:
        proc = subprocess.run(
            cmd, capture_output=True, text=True, timeout=20, check=False,
        )
    except subprocess.TimeoutExpired:
        return {
            "ok": False, "error": "gh_search_timeout",
            "query": query, "timeout_seconds": 20,
        }
    except OSError as e:
        return {
            "ok": False, "error": "gh_search_unavailable",
            "query": query, "detail": str(e),
        }

    if proc.returncode != 0:
        return {
            "ok": False,
            "error": "gh_search_failed",
            "query": query,
            "exit_code": proc.returncode,
            "stderr": (proc.stderr or "").strip()[-400:],
        }

    try:
        raw = json.loads(proc.stdout or "[]")
    except json.JSONDecodeError as e:
        return {
            "ok": False,
            "error": "gh_search_failed",
            "query": query,
            "stderr": f"unparseable JSON from gh: {e}",
        }
    if not isinstance(raw, list):
        raw = []

    results: list[dict] = []
    for item in raw:
        if not isinstance(item, dict):
            continue
        owner_obj = item.get("owner") or {}
        owner = ""
        if isinstance(owner_obj, dict):
            owner = owner_obj.get("login") or owner_obj.get("name") or ""
        elif isinstance(owner_obj, str):
            owner = owner_obj
        name = item.get("name") or ""
        if not (owner and name):
            continue
        stars = item.get("stargazerCount") or 0
        if not isinstance(stars, (int, float)):
            stars = 0
        updated_at = item.get("updatedAt") or ""
        score = float(stars) + _recency_boost(updated_at)
        results.append({
            "slug": f"{owner}/{name}",
            "name": name,
            "owner": owner,
            "description": item.get("description") or "",
            "stars": int(stars),
            "updatedAt": updated_at,
            "url": item.get("url") or "",
            "score": round(score, 2),
        })

    results.sort(key=lambda r: r["score"], reverse=True)
    return {"ok": True, "query": query, "results": results}


def _diff_skill_lists(
    old: list[dict], new: list[dict],
) -> dict[str, list[str]]:
    old_by_name = {
        s.get("name"): s for s in old if isinstance(s.get("name"), str)
    }
    new_by_name = {
        s.get("name"): s for s in new if isinstance(s.get("name"), str)
    }
    added = [
        f"{n} {s.get('version', '?')}"
        for n, s in new_by_name.items() if n not in old_by_name
    ]
    removed = [
        f"{n} {s.get('version', '?')}"
        for n, s in old_by_name.items() if n not in new_by_name
    ]
    bumped: list[str] = []
    for n, s in new_by_name.items():
        if n in old_by_name and old_by_name[n].get("version") != s.get("version"):
            bumped.append(
                f"{n} {old_by_name[n].get('version', '?')} → "
                f"{s.get('version', '?')}"
            )
    return {"added": added, "removed": removed, "version-changed": bumped}


def _skills_at_sha(repo: Path, sha: str) -> list[dict]:
    raw = _git_show_at(repo, sha, "marketplace.json")
    if not raw:
        return []
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return []
    skills = data.get("skills") if isinstance(data, dict) else None
    if not isinstance(skills, list):
        return []
    return [s for s in skills if isinstance(s, dict)]


def _update_one(state_dir: Path) -> dict:
    meta = _read_marketplace_meta(state_dir)
    if meta is None:
        return {"path": str(state_dir), "error": "missing meta"}
    owner = meta.get("owner") or ""
    name = meta.get("name") or ""
    slug = f"{owner}/{name}"
    old_sha = meta.get("pinned_sha")

    # git fetch
    try:
        proc = subprocess.run(
            ["git", "fetch", "--quiet", "origin"],
            capture_output=True, text=True, timeout=120,
            cwd=str(state_dir), check=False,
        )
    except (OSError, subprocess.SubprocessError) as e:
        return {"slug": slug, "error": f"git fetch failed: {e}"}
    if proc.returncode != 0:
        return {
            "slug": slug,
            "error": (
                f"git fetch exited {proc.returncode}: "
                f"{(proc.stderr or '').strip()[:200]}"
            ),
        }

    branch = _resolve_origin_default_branch(state_dir)
    if not branch:
        return {"slug": slug, "error": "could not resolve origin default branch"}
    try:
        proc = subprocess.run(
            ["git", "rev-parse", f"origin/{branch}"],
            capture_output=True, text=True, timeout=10,
            cwd=str(state_dir), check=False,
        )
    except (OSError, subprocess.SubprocessError) as e:
        return {"slug": slug, "error": f"rev-parse failed: {e}"}
    new_sha = proc.stdout.strip()
    if not new_sha:
        return {"slug": slug, "error": "could not resolve new SHA"}

    if new_sha == old_sha:
        return {
            "slug": slug,
            "status": "up-to-date",
            "pinned_sha": old_sha,
        }

    # Diff stat (informational; used only for the human prompt)
    try:
        diff_proc = subprocess.run(
            ["git", "diff", "--stat", f"{old_sha}..{new_sha}"],
            capture_output=True, text=True, timeout=10,
            cwd=str(state_dir), check=False,
        )
        diff_stat = diff_proc.stdout if diff_proc.returncode == 0 else ""
    except (OSError, subprocess.SubprocessError):
        diff_stat = ""

    new_mj_raw = _git_show_at(state_dir, new_sha, "marketplace.json")
    new_mj: Optional[dict] = None
    if new_mj_raw:
        try:
            parsed = json.loads(new_mj_raw)
            if isinstance(parsed, dict):
                new_mj = parsed
        except json.JSONDecodeError:
            new_mj = None

    apv_blocks = False
    apv_msg = ""
    if isinstance(new_mj, dict):
        new_apv = new_mj.get("agent_plus_version")
        if isinstance(new_apv, str) and _validate_range_spec(new_apv):
            if not _satisfies_range(_plugin_version(), new_apv):
                apv_blocks = True
                apv_msg = (
                    f"new agent_plus_version={new_apv!r} not satisfied by "
                    f"framework {_plugin_version()}"
                )

    old_skills = _skills_at_sha(state_dir, old_sha) if old_sha else []
    new_skills_list: list[dict] = []
    if isinstance(new_mj, dict) and isinstance(new_mj.get("skills"), list):
        new_skills_list = [
            s for s in new_mj["skills"] if isinstance(s, dict)
        ]
    skills_diff = _diff_skill_lists(old_skills, new_skills_list)

    sys.stderr.write(f"\n=== marketplace update: {slug} ===\n")
    sys.stderr.write(
        f"  {(old_sha or '?')[:8]} → {new_sha[:8]}\n\n"
    )
    if diff_stat.strip():
        sys.stderr.write("Changed files:\n")
        for line in diff_stat.splitlines():
            sys.stderr.write(f"  {line}\n")
        sys.stderr.write("\n")
    if any(skills_diff.values()):
        sys.stderr.write("Skills diff:\n")
        for verb, items in skills_diff.items():
            for it in items:
                sys.stderr.write(f"  [{verb}] {it}\n")
        sys.stderr.write("\n")

    if apv_blocks:
        sys.stderr.write(
            f"[BLOCKED] {apv_msg}\n"
            f"Upgrade agent-plus-meta first, then re-run update.\n\n"
        )
        return {
            "slug": slug,
            "status": "blocked",
            "old_sha": old_sha,
            "new_sha": new_sha,
            "reason": apv_msg,
        }

    if not _read_yes_no(
        f"Accept update from {(old_sha or '?')[:8]} to {new_sha[:8]}? [y/N]: "
    ):
        return {
            "slug": slug,
            "status": "declined",
            "old_sha": old_sha,
            "new_sha": new_sha,
        }

    # Fast-forward to the new SHA.
    try:
        ff = subprocess.run(
            ["git", "merge", "--ff-only", new_sha],
            capture_output=True, text=True, timeout=30,
            cwd=str(state_dir), check=False,
        )
    except (OSError, subprocess.SubprocessError) as e:
        return {"slug": slug, "error": f"merge failed: {e}"}
    if ff.returncode != 0:
        return {
            "slug": slug,
            "error": (
                f"git merge --ff-only failed: "
                f"{(ff.stderr or '').strip()[:200]}"
            ),
        }

    meta["pinned_sha"] = new_sha
    meta["accepted_first_run"] = False  # re-arm: new code surface
    meta["updated_at"] = _now_iso()
    meta["framework_version"] = _plugin_version()
    _write_marketplace_meta(state_dir, meta)

    sys.stderr.write(
        f"\n[i] {slug} updated. Re-arming first-run acceptance for the new "
        f"surface.\n"
    )
    re_plugins: list[dict] = []
    for s in new_skills_list:
        re_plugins.append({
            "name": s.get("name"),
            "version": s.get("version"),
            "path": s.get("path"),
            "obviates": (
                s["obviates"] if isinstance(s.get("obviates"), list) else []
            ),
        })
    if _read_yes_no(_format_first_run_prompt(owner, name, new_sha, re_plugins)):
        meta["accepted_first_run"] = True
        _write_marketplace_meta(state_dir, meta)

    return {
        "slug": slug,
        "status": "updated",
        "old_sha": old_sha,
        "new_sha": new_sha,
        "first_run_accepted": meta["accepted_first_run"],
    }


def cmd_marketplace_update(args: argparse.Namespace) -> dict:
    if getattr(args, "cron", False):
        return {
            "error": (
                "marketplace update refuses --cron. Updates are interactive "
                "only by trust-model design. Wire your own scheduler if you "
                "want one — and own the failure mode."
            ),
        }

    root = _marketplaces_root()
    targets: list[Path] = []
    if args.slug:
        m = MARKETPLACE_SLUG_RE.match(args.slug)
        if not m:
            return {"error": f"invalid slug {args.slug!r}"}
        owner, name = m.group(1), m.group(2)
        d = _marketplace_state_dir(owner, name)
        if not d.is_dir():
            return {
                "error": f"marketplace not installed: {owner}/{name}",
                "path": str(d),
            }
        targets.append(d)
    elif root.is_dir():
        for c in sorted(root.iterdir()):
            if c.is_dir() and (c / MARKETPLACE_META_FILENAME).is_file():
                targets.append(c)

    results = [_update_one(d) for d in targets]
    return {"root": str(root), "updates": results}


def cmd_marketplace_remove(args: argparse.Namespace) -> dict:
    slug = args.slug
    m = MARKETPLACE_SLUG_RE.match(slug)
    if not m:
        return {"error": f"invalid slug {slug!r}; expected `<user>/<name>`"}
    owner, name = m.group(1), m.group(2)
    target = _marketplace_state_dir(owner, name)
    if not target.exists():
        return {
            "slug": f"{owner}/{name}",
            "status": "not-installed",
            "path": str(target),
        }
    if not _read_yes_no(
        f"Remove marketplace {owner}/{name} at {target}? [y/N]: "
    ):
        return {
            "slug": f"{owner}/{name}",
            "status": "declined",
            "path": str(target),
        }
    _rmtree_force(target)
    return {
        "slug": f"{owner}/{name}",
        "status": "removed",
        "path": str(target),
    }


def _rmtree_force(path: Path) -> None:
    """rmtree that tolerates read-only files (Windows git packs).

    git marks pack `.idx` and `.pack` files read-only on Windows; vanilla
    `shutil.rmtree` raises PermissionError on them. The onexc/onerror callback
    chmods writable and retries.
    """
    import stat

    def _onerror(func, p, exc_info):  # noqa: ARG001 — signature fixed by stdlib
        try:
            os.chmod(p, stat.S_IWRITE | stat.S_IREAD)
        except OSError:
            pass
        try:
            func(p)
        except OSError:
            pass

    # Python 3.12 renamed `onerror` → `onexc`; 3.9–3.11 only have `onerror`.
    if sys.version_info >= (3, 12):
        shutil.rmtree(path, onexc=_onerror)  # type: ignore[call-arg]
    else:
        shutil.rmtree(path, onerror=_onerror)


# ─── prefer ──────────────────────────────────────────────────────────────────
#
# Per-skill marketplace preference for collision resolution. When two
# installed marketplaces ship a skill of the same name, `cmd_refresh`
# consults `~/.agent-plus/preferences.json` to choose unambiguously.

PREFER_USER_REPO_RE = re.compile(r"^[a-zA-Z0-9_-]+/[a-zA-Z0-9_-]+$")
PREFER_SKILL_NAME_RE = re.compile(r"^[a-z][a-z0-9-]{0,63}$")


def _preferences_path() -> Path:
    """Path to ~/.agent-plus/preferences.json. Override via
    AGENT_PLUS_PREFERENCES_PATH for tests."""
    override = os.environ.get("AGENT_PLUS_PREFERENCES_PATH")
    if override:
        return Path(override).expanduser().resolve()
    return (Path.home() / ".agent-plus" / "preferences.json").resolve()


def _read_preferences() -> dict:
    p = _preferences_path()
    if not p.is_file():
        return {"skillPreferences": {}}
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {"skillPreferences": {}}
    if not isinstance(data, dict):
        return {"skillPreferences": {}}
    sp = data.get("skillPreferences")
    if not isinstance(sp, dict):
        data["skillPreferences"] = {}
    return data


def _write_preferences_atomic(data: dict) -> Path:
    p = _preferences_path()
    p.parent.mkdir(parents=True, exist_ok=True)
    body = json.dumps(data, indent=2) + "\n"
    fd, tmp_path = tempfile.mkstemp(prefix=".preferences.", suffix=".tmp",
                                    dir=str(p.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(body)
        os.replace(tmp_path, p)
    except OSError:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise
    return p


def _preferred_marketplace_for_skill(skill: str) -> Optional[str]:
    """Return the preferred `<owner>/<name>` slug for a skill, or None."""
    prefs = _read_preferences()
    sp = prefs.get("skillPreferences") or {}
    entry = sp.get(skill)
    if not isinstance(entry, dict):
        return None
    pref = entry.get("preferredMarketplace")
    return pref if isinstance(pref, str) else None


def cmd_marketplace_prefer(args: argparse.Namespace) -> dict:
    list_prefs = bool(getattr(args, "list_prefs", False))
    clear = bool(getattr(args, "clear", False))
    skill = getattr(args, "skill", None)
    user_repo = getattr(args, "user_repo", None)
    prefs_path = _preferences_path()

    if list_prefs:
        prefs = _read_preferences()
        return {
            "ok": True,
            "skillPreferences": prefs.get("skillPreferences") or {},
            "preferencesPath": str(prefs_path),
        }

    if clear:
        if not skill:
            return {"error": "--clear requires --skill <name>"}
        if not PREFER_SKILL_NAME_RE.match(skill):
            return {
                "error": (
                    f"invalid --skill {skill!r}; expected lowercase, "
                    "starts with a letter, [a-z0-9-]{1,64}"
                ),
            }
        prefs = _read_preferences()
        sp = prefs.setdefault("skillPreferences", {})
        was_present = skill in sp
        if was_present:
            del sp[skill]
            _write_preferences_atomic(prefs)
        return {
            "ok": True,
            "cleared": True,
            "skill": skill,
            "wasPresent": was_present,
            "preferencesPath": str(prefs_path),
        }

    # Set path: both positional + --skill required.
    if not user_repo or not skill:
        return {
            "error": (
                "marketplace prefer requires `<user>/<repo>` and "
                "`--skill <name>` (or use --list / --clear)"
            ),
        }
    if not PREFER_USER_REPO_RE.match(user_repo):
        return {
            "error": (
                f"invalid user/repo {user_repo!r}; expected "
                "`<user>/<repo>` matching ^[a-zA-Z0-9_-]+/[a-zA-Z0-9_-]+$"
            ),
        }
    if not PREFER_SKILL_NAME_RE.match(skill):
        return {
            "error": (
                f"invalid --skill {skill!r}; expected lowercase, "
                "starts with a letter, [a-z0-9-]{1,64}"
            ),
        }

    prefs = _read_preferences()
    sp = prefs.setdefault("skillPreferences", {})
    prev = sp.get(skill)
    previous_pref: Optional[str] = None
    if isinstance(prev, dict):
        pp = prev.get("preferredMarketplace")
        if isinstance(pp, str):
            previous_pref = pp
    sp[skill] = {
        "preferredMarketplace": user_repo,
        "setAt": _now_iso(),
    }
    written = _write_preferences_atomic(prefs)
    return {
        "ok": True,
        "skill": skill,
        "preferredMarketplace": user_repo,
        "preferencesPath": str(written),
        "previousPreference": previous_pref,
    }


def cmd_marketplace(args: argparse.Namespace) -> dict:
    sub = getattr(args, "marketplace_cmd", None)
    if sub == "init":
        return cmd_marketplace_init(args)
    if sub == "install":
        return cmd_marketplace_install(args)
    if sub == "list":
        return cmd_marketplace_list(args)
    if sub == "update":
        return cmd_marketplace_update(args)
    if sub == "remove":
        return cmd_marketplace_remove(args)
    if sub == "search":
        return cmd_marketplace_search(args)
    if sub == "prefer":
        return cmd_marketplace_prefer(args)
    return {
        "error": "marketplace subcommand required: init|install|list|update|remove|search|prefer",
    }


# ─── doctor ──────────────────────────────────────────────────────────────────

# The five framework primitives shipped from this repo's marketplace.json.
# Ordered for stable doctor output; `agent-plus-meta` is the meta plugin
# itself and is included so its on_path state is visible in the report.
FRAMEWORK_PRIMITIVES: tuple[str, ...] = (
    "agent-plus-meta",
    "repo-analyze",
    "diff-summary",
    "skill-feedback",
    "skill-plus",
)


def cmd_doctor(args: argparse.Namespace) -> dict:
    """Read-only diagnostic: self-check, workspace, sibling primitives, env
    readiness, installed marketplaces, stale services.json. Aggregates into
    one envelope with a verdict (healthy|degraded|broken) plus an issues
    list. Never writes to disk."""
    issues: list[dict[str, str]] = []
    checks_run = 0

    # 1. Self-check ────────────────────────────────────────────────────────
    checks_run += 1
    on_path = shutil.which(TOOL_NAME)
    bin_path = Path(__file__).resolve()
    try:
        executable = os.access(str(bin_path), os.X_OK)
    except OSError:
        executable = False
    self_version = _plugin_version()
    # `version_known` is true when plugin.json was readable at runtime.
    # We don't compare against an external version, just confirm the manifest
    # was reachable — a False here means a broken or stale install.
    version_known = self_version != "unknown"
    self_section = {
        "on_path": on_path is not None,
        "on_path_location": on_path,
        "version_known": version_known,
        "executable": executable,
        "version": self_version,
        "bin_path": str(bin_path),
    }
    if on_path is None:
        issues.append({
            "severity": "warn",
            "category": "self",
            "message": f"{TOOL_NAME} not found on PATH; install via install.sh or symlink the bin",
        })
    if not version_known:
        issues.append({
            "severity": "error",
            "category": "self",
            "message": "could not read plugin.json#version (manifest missing or unreadable)",
        })

    # 2. Workspace ─────────────────────────────────────────────────────────
    checks_run += 1
    workspace, source = _resolve_for_read(getattr(args, "dir", None))
    ws_exists = workspace.is_dir()
    files_status: dict[str, dict] = {}
    expected_files = ("manifest.json", "services.json", "env-status.json")
    for fname in expected_files:
        fpath = workspace / fname
        if not fpath.is_file():
            files_status[fname] = {"present": False, "valid_json": False}
            continue
        valid = True
        try:
            json.loads(fpath.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            valid = False
        files_status[fname] = {"present": True, "valid_json": valid}
        if not valid:
            issues.append({
                "severity": "error",
                "category": "workspace",
                "message": f"{fname} is not valid JSON",
            })
    workspace_section = {
        "exists": ws_exists,
        "path": str(workspace),
        "source": source,
        "files": files_status,
    }
    if not ws_exists:
        issues.append({
            "severity": "error",
            "category": "workspace",
            "message": f"workspace not initialised at {workspace}; run `agent-plus-meta init`",
        })

    # 3. Sibling primitives on PATH ────────────────────────────────────────
    checks_run += 1
    primitives_section: dict[str, str] = {}
    for prim in FRAMEWORK_PRIMITIVES:
        primitives_section[prim] = "installed" if shutil.which(prim) else "missing"
        if primitives_section[prim] == "missing":
            issues.append({
                "severity": "warn",
                "category": "primitives",
                "message": f"{prim} not installed; some patterns won't work",
            })

    # 4. Env vars (reuse envcheck logic) ───────────────────────────────────
    checks_run += 1
    cfg = load_env(getattr(args, "env_file", None))
    envcheck_plugins: dict[str, dict] = {}
    ready_count = 0
    missing_count = 0
    for plugin, spec in sorted(PLUGIN_ENV_SPEC.items()):
        plugin_missing_req: list[str] = []
        for name in spec["required"]:
            if not cfg.get(name, "").strip():
                plugin_missing_req.append(name)
        bin_name = PLUGIN_BINARY_REQUIREMENT.get(plugin)
        bin_ok = True
        if bin_name:
            bin_ok = shutil.which(bin_name) is not None
        ready = (not plugin_missing_req) and bin_ok
        envcheck_plugins[plugin] = {
            "ready": ready,
            "missing_required": plugin_missing_req,
        }
        if ready:
            ready_count += 1
        else:
            missing_count += 1
            if plugin_missing_req:
                issues.append({
                    "severity": "warn",
                    "category": "envcheck",
                    "message": f"{plugin}: missing required env vars: {','.join(plugin_missing_req)}",
                })
            elif bin_name and not bin_ok:
                issues.append({
                    "severity": "warn",
                    "category": "envcheck",
                    "message": f"{plugin}: required CLI `{bin_name}` not on PATH",
                })
    envcheck_section = {
        "ready_count": ready_count,
        "missing_count": missing_count,
        "plugins": envcheck_plugins,
    }

    # 5. Installed marketplaces ────────────────────────────────────────────
    checks_run += 1
    mp_root = _marketplaces_root()
    mp_installed: list[dict] = []
    if mp_root.is_dir():
        for child in sorted(mp_root.iterdir()):
            if not child.is_dir():
                continue
            meta = _read_marketplace_meta(child)
            if meta is None:
                continue
            mp_installed.append({
                "owner": meta.get("owner"),
                "name": meta.get("name"),
                "accepted": bool(meta.get("accepted_first_run")),
            })
    marketplaces_section = {"root": str(mp_root), "installed": mp_installed}

    # 6. Stale services.json entries ───────────────────────────────────────
    checks_run += 1
    stale_entries: list[str] = []
    services_path = workspace / "services.json"
    if services_path.is_file():
        try:
            sj = json.loads(services_path.read_text(encoding="utf-8"))
            services = sj.get("services") if isinstance(sj, dict) else None
            if isinstance(services, dict):
                installed_set = set(PLUGIN_ENV_SPEC.keys()) | set(FRAMEWORK_PRIMITIVES)
                for key in services.keys():
                    if key not in installed_set:
                        stale_entries.append(key)
        except (OSError, json.JSONDecodeError):
            pass
    if stale_entries:
        issues.append({
            "severity": "warn",
            "category": "services",
            "message": f"services.json has stale entries for plugins not installed: {','.join(stale_entries)}; run `agent-plus-meta refresh`",
        })

    # 7. Verdict ───────────────────────────────────────────────────────────
    self_broken = (not self_section["executable"]) or (not version_known)
    if self_broken or not ws_exists:
        verdict = "broken"
    elif any(i["severity"] == "error" for i in issues) or missing_count > 0 or stale_entries:
        verdict = "degraded"
    else:
        verdict = "healthy"

    return {
        "verdict": verdict,
        "self": self_section,
        "workspace": workspace_section,
        "primitives": primitives_section,
        "envcheck": envcheck_section,
        "marketplaces": marketplaces_section,
        "stale_services_entries": stale_entries,
        "checks_run": checks_run,
        "issues": issues,
    }


def _render_doctor_pretty(payload: dict) -> str:
    """Human-readable summary appended to stderr when --pretty is set."""
    lines: list[str] = []
    verdict = payload.get("verdict", "unknown")
    lines.append("")
    lines.append(f"agent-plus-meta doctor: {verdict.upper()}")
    lines.append("=" * (24 + len(verdict)))
    self_s = payload.get("self") or {}
    lines.append(f"  self        : on_path={self_s.get('on_path')} version={self_s.get('version')}")
    ws = payload.get("workspace") or {}
    lines.append(f"  workspace   : exists={ws.get('exists')} path={ws.get('path')}")
    prims = payload.get("primitives") or {}
    missing_prims = [k for k, v in prims.items() if v == "missing"]
    lines.append(f"  primitives  : {len(prims) - len(missing_prims)}/{len(prims)} installed"
                 + (f" (missing: {', '.join(missing_prims)})" if missing_prims else ""))
    ec = payload.get("envcheck") or {}
    lines.append(f"  envcheck    : {ec.get('ready_count', 0)} ready, {ec.get('missing_count', 0)} not ready")
    mp = payload.get("marketplaces") or {}
    lines.append(f"  marketplaces: {len(mp.get('installed') or [])} installed")
    issues = payload.get("issues") or []
    if issues:
        lines.append("")
        lines.append("Issues:")
        for it in issues:
            lines.append(f"  - [{it.get('severity')}] {it.get('category')}: {it.get('message')}")
    else:
        lines.append("")
        lines.append("No issues detected.")
    return "\n".join(lines)


# ─── argparse ────────────────────────────────────────────────────────────────


def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="agent-plus-meta",
        description="The meta plugin for the agent-plus framework — workspace bootstrap, env-var readiness, identity cache, marketplace lifecycle, extensions.",
    )
    p.add_argument("--version", action="store_true",
                   help="print plugin version and exit")
    p.add_argument("--pretty", action="store_true",
                   help="pretty-print JSON output")
    sub = p.add_subparsers(dest="cmd")

    pretty_parent = argparse.ArgumentParser(add_help=False)
    pretty_parent.add_argument("--pretty", action="store_true",
                               help="pretty-print JSON output")
    pretty_parent.add_argument("--dir", help="override workspace dir resolution "
                                             "(creates/uses <PATH>/.agent-plus)")
    pretty_parent.add_argument("--env-file", help="extra env file to load (highest "
                                                  "precedence after CLI flags)")

    sub.add_parser("init", help="create .agent-plus/ workspace files",
                   parents=[pretty_parent])

    sub.add_parser("envcheck", help="report which plugin env vars are set "
                                    "(names only)",
                   parents=[pretty_parent])

    sub.add_parser("doctor", help="diagnose install + workspace + env-var "
                                  "+ marketplace state (read-only)",
                   parents=[pretty_parent])

    s_refresh = sub.add_parser(
        "refresh",
        help="resolve identity for supported plugins into services.json",
        parents=[pretty_parent],
    )
    s_refresh.add_argument("--plugin",
                           help="refresh only this plugin (default: all plugins "
                                "with a refresh_handler declared in plugin.json)")
    s_refresh.add_argument("--no-extensions", action="store_true",
                           help="skip user extensions defined in extensions.json")
    s_refresh.add_argument("--extensions-only", action="store_true",
                           help="run only user extensions; skip built-in handlers")

    s_list = sub.add_parser(
        "list",
        help="discoverability — every plugin in marketplace.json with "
             "headline-commands previews from each README",
        parents=[pretty_parent],
    )
    s_list.add_argument("--names-only", action="store_true",
                        help="return only the plugin names list")

    s_ext = sub.add_parser(
        "extensions",
        help="manage user-defined refresh extensions (extensions.json)",
        parents=[pretty_parent],
    )
    ext_sub = s_ext.add_subparsers(dest="ext_cmd")

    ext_sub.add_parser("list", help="show registered extensions",
                       parents=[pretty_parent])
    ext_sub.add_parser("validate",
                       help="dry-run validate extensions.json (no script execution)",
                       parents=[pretty_parent])

    s_add = ext_sub.add_parser("add", help="register a new extension",
                               parents=[pretty_parent])
    s_add.add_argument("--name", required=True,
                       help="extension slug (lowercase, 1-31 chars)")
    s_add.add_argument("--command", required=True,
                       help="extension executable (argv[0])")
    s_add.add_argument("--command-arg", action="append", default=[],
                       help="additional argv element; repeatable")
    s_add.add_argument("--description", help="human-readable description")
    s_add.add_argument("--timeout", type=int,
                       help="timeout in seconds (default 30)")

    s_rm = ext_sub.add_parser("remove", help="remove an extension by name",
                              parents=[pretty_parent])
    s_rm.add_argument("--name", required=True, help="extension slug to remove")

    # ── marketplace ────────────────────────────────────────────────────────
    s_market = sub.add_parser(
        "marketplace",
        help="manage agent-plus-meta marketplaces (init/install/list/update/remove/search/prefer)",
        parents=[pretty_parent],
    )
    market_sub = s_market.add_subparsers(dest="marketplace_cmd")

    s_minit = market_sub.add_parser(
        "init",
        help="scaffold a new <user>/agent-plus-skills marketplace repo locally",
        parents=[pretty_parent],
    )
    s_minit.add_argument("slug", help="`<user>/<name>` slug; name must be `agent-plus-skills` for v1")
    s_minit.add_argument("--path", help="override target directory (default: <cwd>/<name>/)")

    s_minst = market_sub.add_parser(
        "install",
        help="clone + register a <user>/agent-plus-skills marketplace (interactive accept)",
        parents=[pretty_parent],
    )
    s_minst.add_argument("slug", help="`<user>/agent-plus-skills` slug")
    # --url is a test-only override; documented hint kept terse.
    s_minst.add_argument("--url", help=argparse.SUPPRESS)

    market_sub.add_parser(
        "list",
        help="list installed marketplaces",
        parents=[pretty_parent],
    )

    s_mup = market_sub.add_parser(
        "update",
        help="update an installed marketplace (interactive; refuses --cron)",
        parents=[pretty_parent],
    )
    s_mup.add_argument("slug", nargs="?",
                       help="`<user>/<name>` slug (default: iterate all installed)")
    s_mup.add_argument("--cron", action="store_true",
                       help="explicitly refused by trust model — do not use")

    s_mrm = market_sub.add_parser(
        "remove",
        help="remove an installed marketplace (interactive confirm)",
        parents=[pretty_parent],
    )
    s_mrm.add_argument("slug", help="`<user>/<name>` slug")

    s_msearch = market_sub.add_parser(
        "search",
        help="search GitHub for marketplaces (topic:agent-plus-skills); ranks by stars + recent activity",
        parents=[pretty_parent],
    )
    s_msearch.add_argument("query", nargs="?", default="",
                           help="optional search keyword (e.g. 'database', 'aws')")

    s_mpref = market_sub.add_parser(
        "prefer",
        help="set or inspect per-skill marketplace preference for collision resolution",
        parents=[pretty_parent],
    )
    s_mpref.add_argument("user_repo", nargs="?", default=None,
                         help="`<user>/<repo>` slug to prefer for the named skill")
    s_mpref.add_argument("--skill", default=None,
                         help="skill name; required unless --list")
    s_mpref.add_argument("--list", dest="list_prefs", action="store_true",
                         help="show current preferences and exit")
    s_mpref.add_argument("--clear", action="store_true",
                         help="clear the preference for --skill")

    return p


def main(argv: Optional[list[str]] = None) -> int:
    # Windows: default stdout is cp1252 which chokes on em-dashes/arrows from
    # plugin READMEs. Force UTF-8 so list output round-trips cleanly.
    try:
        sys.stdout.reconfigure(encoding="utf-8")  # type: ignore[attr-defined]
    except (AttributeError, OSError):
        pass

    parser = _build_parser()
    args = parser.parse_args(argv)

    if args.version:
        print(f"{TOOL_NAME} {_plugin_version()}")
        return 0

    handlers = {
        "init": cmd_init,
        "envcheck": cmd_envcheck,
        "doctor": cmd_doctor,
        "refresh": cmd_refresh,
        "list": cmd_list,
        "extensions": cmd_extensions,
        "marketplace": cmd_marketplace,
    }
    if args.cmd not in handlers:
        parser.print_help()
        return 2

    try:
        payload = handlers[args.cmd](args)
    except SystemExit:
        raise
    except Exception as e:  # noqa: BLE001 — never crash with a stack trace
        err = {"tool": _tool_meta(), "error": str(e), "cmd": args.cmd}
        print(json.dumps(err), file=sys.stderr)
        return 1

    out = _with_tool_meta(payload)
    indent = 2 if args.pretty else None
    print(json.dumps(out, ensure_ascii=False, indent=indent))

    # init --pretty: append a human-readable "Suggested skills" section to
    # stderr so it doesn't pollute the JSON on stdout. Silent if no matches.
    if args.cmd == "init" and getattr(args, "pretty", False) and isinstance(out, dict):
        section = _render_suggestions_section(out.get("suggested_skills") or [])
        if section:
            sys.stderr.write(section + "\n")

    # doctor --pretty: append the human-readable verdict + issues summary to
    # stderr, leaving the JSON envelope untouched on stdout.
    if args.cmd == "doctor" and getattr(args, "pretty", False) and isinstance(out, dict):
        sys.stderr.write(_render_doctor_pretty(out) + "\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
