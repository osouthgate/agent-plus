#!/bin/sh
# .githooks/pre-commit — agent-plus pre-commit hook
#
# Runs the test suite with `env -i` (minimal env, like CI) so the class of
# bug where local-tests-pass-but-CI-fails gets caught before you push.
# Bypass with: git commit --no-verify
#
# Activate (one-time per clone):
#   sh scripts/install-precommit.sh
# OR:
#   git config core.hooksPath .githooks
#
# Why: agent-plus's tests can pass locally because the maintainer's `~/.env`
# leaks into `load_env`, or because `LINEAR_API_KEY` is set in their shell.
# CI runs with no such state. Two recent incidents:
#   1. v0.12.0 test_decode_windows_drive_form — Linux assumption masked by
#      Windows-passing test (commit 7397153 fix).
#   2. v0.15.5 test_doctor_degraded_when_envvar_missing — verdict semantics
#      changed in v0.15.4 but local tests passed because env vars triggered
#      the partial-config path; CI's clean env hit the new healthy path
#      (commit 5720536 fix).
#
# This hook prevents that bug class by running tests with `env -i` plus a
# minimal whitelist (PATH for python3/sh, HOME for tempdir resolution,
# AGENT_PLUS_NO_ENV_FILES=1 for envcheck hermeticity).
#
# Pure POSIX shell — no bashisms.

set -e

# Escape hatch: SKIP_PRECOMMIT_TESTS=1 git commit ... bypasses for hot fixes
# that don't touch test-relevant surfaces. Prefer --no-verify for explicit
# one-off bypasses; this env var is for repeated automation contexts.
if [ "${SKIP_PRECOMMIT_TESTS:-0}" = "1" ]; then
    echo "pre-commit: SKIP_PRECOMMIT_TESTS=1 — skipping test run."
    exit 0
fi

# Optimization: skip if the staged diff doesn't touch any code/test/CI/hook
# surface. Avoids running ~50s of tests for pure documentation commits.
# Includes .githooks/ and scripts/ so changes to the hook itself trigger
# a self-test (otherwise we could land a broken hook).
CHANGED=$(git diff --cached --name-only)
if ! echo "$CHANGED" | grep -qE '\.(py|sh)$|/test_|^test/|^.github/|^.githooks/|^scripts/|^install.sh$|^VERSION$'; then
    echo "pre-commit: no code/test/CI/hook changes staged — skipping tests."
    exit 0
fi

cat <<'EOF'
pre-commit: running tests with clean env (PATH+HOME only).
            Bypass with: git commit --no-verify  (or set SKIP_PRECOMMIT_TESTS=1)
EOF

# Resolve repo root so the hook works from any subdirectory.
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Mimic CI's hermeticity by stripping the maintainer's plugin-specific env
# vars (the actual leak source) while preserving system state (PATH, HOME,
# USERPROFILE on Windows, TEMP, TMPDIR, etc.) so Python's Path.home() and
# tempfile work. This is more portable than `env -i HOME=$HOME` which
# breaks on Windows Git Bash because Python looks at USERPROFILE first
# and `env -i` strips it.
#
# Single source of truth: derive the strip list from PLUGIN_ENV_SPEC at
# hook time via scripts/_dump_plugin_env_vars.py. This keeps the hook in
# sync with the framework — when a new plugin lands with new required env
# vars, the dump picks them up automatically. No drift between hook and
# contract. Hard-fail if the dump fails (silently skipping the strip is
# the bug class the hook exists to prevent).
PLUGIN_ENV_VARS=$(python3 "$REPO_ROOT/scripts/_dump_plugin_env_vars.py" 2>&1)
if [ -z "$PLUGIN_ENV_VARS" ] || ! echo "$PLUGIN_ENV_VARS" | grep -q '^[A-Z_]'; then
    echo "pre-commit: failed to derive plugin env vars from PLUGIN_ENV_SPEC:" >&2
    echo "$PLUGIN_ENV_VARS" >&2
    echo "  (this would let the maintainer's env leak into tests — refusing to proceed)" >&2
    exit 2
fi

# Subshell keeps the unsets local so the rest of the hook still has the
# maintainer's env if it needs to print things etc.
clean_env() {
    (
        # Unset every plugin env var (derived dynamically — see above).
        for _var in $PLUGIN_ENV_VARS; do
            unset "$_var"
        done
        # AGENT_PLUS_NO_ENV_FILES=1 prevents the bin's load_env from walking
        # up from cwd and finding the maintainer's ~/.env (which has the
        # same plugin env vars we just stripped).
        AGENT_PLUS_NO_ENV_FILES=1 "$@"
    )
}

# Run a labelled test step. We can't pipe through `tail` because POSIX `set -e`
# doesn't catch failures inside a pipeline (exit code is the LAST stage's).
# Solution: write to a temp file, capture rc, then tail-print on success or
# full-print + exit on failure. Tempfile cleaned up via trap.
TMPOUT=$(mktemp)
trap 'rm -f "$TMPOUT"' EXIT INT TERM HUP

run_step() {
    label="$1"
    shift
    echo
    echo "  $label"
    if "$@" > "$TMPOUT" 2>&1; then
        tail -2 "$TMPOUT"
    else
        rc=$?
        echo "  ✗ FAILED (rc=$rc) — full output below:"
        echo
        cat "$TMPOUT"
        echo
        echo "pre-commit: tests failed under clean env. Bypass with: git commit --no-verify"
        exit "$rc"
    fi
}

run_step "[1/4] doc-drift check (VERSION/CHANGELOG/keystone-plugin invariants)..." \
    python3 "$REPO_ROOT/.github/scripts/doc-drift-check.py"

run_step "[2/4] agent-plus-meta + skill-feedback unittest..." \
    clean_env python3 -m unittest \
        agent-plus-meta/test/test_agent_plus.py \
        agent-plus-meta/test/test_marketplace_lifecycle.py \
        agent-plus-meta/test/test_installer_skill.py \
        agent-plus-meta/test/test_upgrade_check.py \
        agent-plus-meta/test/test_upgrade.py \
        agent-plus-meta/test/test_migrations.py \
        agent-plus-meta/test/test_uninstall.py

run_step "[3/4] skill-plus + skill-feedback pytest..." \
    clean_env python3 -m pytest skill-plus/test/ skill-feedback/test/

run_step "[4/4] install.sh shell tests..." \
    clean_env python3 -m unittest discover -s test -p "test_install_script.py"

echo
echo "pre-commit: all tests passed under clean env."
