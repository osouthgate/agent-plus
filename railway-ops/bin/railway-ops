#!/usr/bin/env python3
"""
railway-ops — read-first CLI wrapper around `railway` for incident triage.

One call returns the full env/services/errors/envs tree so the agent doesn't
burn context running `railway list`, `railway service status`, `railway logs`,
`railway variables` per service.

Commands (all emit JSON to stdout; use --pretty for indented):
  overview [--env <name>] [--service <name>] [--since <dur>] [--limit N]
      Single-shot snapshot: project, env, services[], deploy status, recent
      errors/warnings per service, env var NAMES (never values), and a
      top-level `summary` object with counts (services/failures/errors/
      warnings). `--service` filters to a single service for focused triage.
      `--limit` overrides the per-service error/warning cap.
  status
      Current project/env/service context + whoami.
  errors <service> [--since <dur>] [--limit N]
      Focus on one service's error/warning lines.
  envs <service>
      Env var NAMES only. Values stripped at parse time.
  services [--env <name>]
      Per-service deploy status shortlist.
  projects
      `railway list` re-shaped to JSON.

JSON-first contract:
  Every command emits a single JSON document on stdout. Fields are stable
  across releases; additive changes may add new fields but will not rename
  or remove existing ones without a major-version bump. Use `--pretty` for
  human-readable output; machine consumers should parse stdout as JSON.

Hard safety rules:
  1. Env var VALUES are NEVER written to stdout/stderr. Only names.
  2. Read-only. No up / redeploy / variables --set / etc.
  3. Requires `railway` CLI installed + authed (`railway login`).
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from typing import Any, Callable, Optional

# ──────────────────────────── constants ────────────────────────────

DEFAULT_SINCE = "24h"
DEFAULT_OVERVIEW_LOG_LINES = 500
DEFAULT_ERRORS_LIMIT = 50
DEFAULT_OVERVIEW_BUCKET_CAP = 20
# Back-compat alias; prefer DEFAULT_OVERVIEW_BUCKET_CAP.
OVERVIEW_BUCKET_CAP = DEFAULT_OVERVIEW_BUCKET_CAP
CMD_TIMEOUT_SEC = 30

# Classification regexes — applied to text log lines (fallback path) and also
# used to confirm JSON `level` field matches. Deliberately broad but not greedy.
ERROR_RE = re.compile(r"\b(error|fatal|panic|exception|traceback|unhandled)\b", re.IGNORECASE)
WARNING_RE = re.compile(r"\b(warn|warning)\b", re.IGNORECASE)

# Postgres log lines come out of the container on stderr with an embedded
# pg-level tag: `2026-04-24 13:36:15.296 UTC [22] LOG:  checkpoint complete…`.
# Railway stamps every line from stderr as level=error, which floods the bucket
# with routine LOG/STATEMENT/DETAIL noise. When a message matches this shape we
# trust the embedded level instead of the envelope.
_PG_LINE_RE = re.compile(
    r"^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}:\d{2}(?:\.\d+)?\s+\w+\s+\[\d+\]\s+"
    r"(LOG|INFO|NOTICE|DEBUG\d?|DETAIL|HINT|CONTEXT|STATEMENT|QUERY|LOCATION|"
    r"WARNING|ERROR|FATAL|PANIC):\s",
    re.IGNORECASE,
)
_PG_LEVEL_MAP = {
    "ERROR": "error", "FATAL": "error", "PANIC": "error",
    "WARNING": "warning",
    # Everything else is informational. STATEMENT/DETAIL/HINT/CONTEXT/QUERY are
    # attached to an adjacent real event and will be captured via its ERROR line.
    "LOG": None, "INFO": None, "NOTICE": None, "DEBUG": None,
    "DEBUG1": None, "DEBUG2": None, "DEBUG3": None, "DEBUG4": None, "DEBUG5": None,
    "DETAIL": None, "HINT": None, "CONTEXT": None,
    "STATEMENT": None, "QUERY": None, "LOCATION": None,
}


def pg_embedded_level(msg: str) -> Optional[str]:
    """If `msg` is a Postgres log line, return its embedded level mapped to
    'error' | 'warning' | None. Returns None for non-pg lines so the caller
    falls back to the envelope `level` field.

    Example: '2026-04-24 13:36:15.296 UTC [22] LOG:  checkpoint complete…'
    → None (not a real error, just pg's routine LOG stream).
    """
    if not msg:
        return None
    m = _PG_LINE_RE.match(msg.strip())
    if not m:
        return None
    tag = m.group(1).upper()
    # `_PG_LEVEL_MAP[tag]` is the mapped classification (or None).
    # A tag that matched the regex but isn't in the map (shouldn't happen,
    # but defensive) returns None too — i.e. ignore as noise.
    if tag in _PG_LEVEL_MAP:
        return _PG_LEVEL_MAP[tag]
    return None


def is_pg_log_line(msg: str) -> bool:
    """True if the message matches the canonical pg log line shape."""
    return bool(msg and _PG_LINE_RE.match(msg.strip()))

# Top-N cap for the per-service errorKinds / warningKinds bucketed summaries.
# The buckets exist specifically so a flood of identical errors can't hide behind
# the truncated errors[] list — keep this generous enough that a real incident
# shows up, small enough that the overview stays scannable.
DEFAULT_KINDS_TOP_N = 10

# Fingerprint normalisation: collapses variable parts (UUIDs, numbers, quoted
# strings, hex) so "FK violation on row 12345" and "FK violation on row 67890"
# bucket together. Applied in order.
_UUID_RE = re.compile(r"\b[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\b", re.IGNORECASE)
_HEX_RE = re.compile(r"\b0x[0-9a-f]+\b|\b[0-9a-f]{16,}\b", re.IGNORECASE)
_NUM_RE = re.compile(r"\b\d+\b")
_DQSTR_RE = re.compile(r'"[^"\n]{0,200}"')
_SQSTR_RE = re.compile(r"'[^'\n]{0,200}'")
_WS_RE = re.compile(r"\s+")
FINGERPRINT_MAX_LEN = 120


def fingerprint_message(msg: str) -> str:
    """Normalise a log message into a bucketable fingerprint.

    Strips UUIDs/hex/numbers and quoted strings so messages that differ only
    by a row ID, timestamp, or inlined value collapse into one bucket. This is
    the key used by the `errorKinds` / `warningKinds` summaries so that a flood
    of 800 identical FK violations shows up as one bucket with count=800,
    instead of being hidden behind the 20-line errors[] truncation.
    """
    if not msg:
        return ""
    s = msg.strip()
    s = _UUID_RE.sub("<uuid>", s)
    s = _HEX_RE.sub("<hex>", s)
    s = _DQSTR_RE.sub('"<str>"', s)
    s = _SQSTR_RE.sub("'<str>'", s)
    s = _NUM_RE.sub("<n>", s)
    s = _WS_RE.sub(" ", s).strip()
    if len(s) > FINGERPRINT_MAX_LEN:
        s = s[:FINGERPRINT_MAX_LEN].rstrip() + "…"
    return s

# Commands that write — rejected outright. railway-ops is read-only.
BLOCKED_SUBCOMMANDS = {
    "up", "deploy", "redeploy", "restart", "down", "delete",
    "init", "link", "unlink", "add", "scale",
}


# ──────────────────────────── subprocess ────────────────────────────


def _resolve_exe(name: str) -> Optional[str]:
    """Resolve an executable on PATH, including Windows .cmd / .bat shims.
    subprocess.run() without shell=True won't find .cmd files via bare name
    on Windows — we have to hand it the fully-qualified path."""
    found = shutil.which(name)
    if found:
        return found
    if os.name == "nt":
        for ext in (".cmd", ".bat", ".exe"):
            found = shutil.which(name + ext)
            if found:
                return found
    return None


def default_run_cmd(argv: list[str], *, timeout: int = CMD_TIMEOUT_SEC,
                    stdin: Optional[str] = None) -> tuple[int, str, str]:
    """Run a command. Returns (returncode, stdout, stderr). Tests inject a stub."""
    # Resolve argv[0] through shutil.which so Windows .cmd shims work.
    if argv:
        resolved = _resolve_exe(argv[0])
        if resolved:
            argv = [resolved, *argv[1:]]
    try:
        proc = subprocess.run(
            argv,
            capture_output=True,
            text=True,
            timeout=timeout,
            input=stdin,
        )
        return proc.returncode, proc.stdout, proc.stderr
    except FileNotFoundError as e:
        return 127, "", f"command not found: {e.filename}"
    except subprocess.TimeoutExpired:
        return 124, "", f"command timed out after {timeout}s: {' '.join(argv)}"


# Module-level hook so tests can monkey-patch.
run_cmd: Callable[..., tuple[int, str, str]] = default_run_cmd


def railway(args: list[str], *, timeout: int = CMD_TIMEOUT_SEC) -> tuple[int, str, str]:
    """Invoke `railway` with safety checks."""
    if args and args[0] in BLOCKED_SUBCOMMANDS:
        return 1, "", f"railway-ops: blocked write subcommand '{args[0]}'"
    return run_cmd(["railway", *args], timeout=timeout)


# ──────────────────────────── safety helpers ────────────────────────────


def strip_env_values(raw_json_text: str) -> list[str]:
    """Parse `railway variables --json` output (a dict of KEY -> VALUE) and
    return ONLY the list of keys. The raw dict is discarded immediately.

    Also accepts legacy KV output (KEY=VALUE\\n...) as a fallback — in that
    case we split on '=' and keep only the left side.

    INVARIANT: the return value contains no substring of any value.
    """
    if not raw_json_text.strip():
        return []
    # Try JSON first.
    try:
        data = json.loads(raw_json_text)
        if isinstance(data, dict):
            keys = sorted(str(k) for k in data.keys())
            del data  # be explicit: drop the values from memory scope
            return keys
    except json.JSONDecodeError:
        pass
    # Fallback: KEY=VALUE lines.
    keys: list[str] = []
    for line in raw_json_text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            k = line.split("=", 1)[0].strip()
            if k:
                keys.append(k)
    return sorted(set(keys))


# ──────────────────────────── log classification ────────────────────────────


def classify_log_line(line_json: dict[str, Any]) -> Optional[str]:
    """Return 'error', 'warning', or None for an already-parsed JSON log line.

    Priority order:
      1. Postgres-embedded level, if the message is a pg log line. This runs
         FIRST because Railway stamps stderr as level=error, which otherwise
         floods the bucket with routine `LOG: checkpoint complete` noise.
      2. Explicit `level` field (Pino, standard loggers).
      3. Message content regex match.
    """
    msg = str(line_json.get("message", "") or line_json.get("msg", ""))
    if msg and is_pg_log_line(msg):
        return pg_embedded_level(msg)

    level = str(line_json.get("level", "")).lower()
    if level in ("error", "fatal", "critical"):
        return "error"
    if level in ("warn", "warning"):
        return "warning"
    # Some loggers use numeric levels (Pino: 50=error, 60=fatal, 40=warn).
    if isinstance(line_json.get("level"), int):
        lv = line_json["level"]
        if lv >= 50:
            return "error"
        if lv == 40:
            return "warning"
    if msg:
        if ERROR_RE.search(msg):
            return "error"
        if WARNING_RE.search(msg):
            return "warning"
    return None


def classify_log_text(line: str) -> Optional[str]:
    """Fallback classification for non-JSON log lines.

    Postgres-shape lines are classified by their embedded level first so
    `LOG: checkpoint complete` doesn't get matched as an error by the regex.
    """
    if is_pg_log_line(line):
        return pg_embedded_level(line)
    if ERROR_RE.search(line):
        return "error"
    if WARNING_RE.search(line):
        return "warning"
    return None


def parse_log_entries(raw: str) -> list[dict[str, Any]]:
    """Parse a block of `railway logs --json` output. Each line is a JSON object.
    Lines that fail to parse are wrapped as {text: ..., timestamp: None}."""
    entries: list[dict[str, Any]] = []
    for raw_line in raw.splitlines():
        line = raw_line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            if isinstance(obj, dict):
                entries.append(obj)
            else:
                entries.append({"message": str(obj), "_non_object": True})
        except json.JSONDecodeError:
            entries.append({"message": line, "_non_json": True})
    return entries


def bucket_log_entries(entries: list[dict[str, Any]], cap: int) -> tuple[
        list[dict[str, Any]], list[dict[str, Any]]]:
    """Classify entries into (errors, warnings). Dedupes consecutive identical
    messages. Keeps the most-recent `cap` of each bucket.

    Back-compat shape: returns (errors, warnings) only. For the flood-resistant
    `errorKinds` / `warningKinds` summary + totals, use `summarize_log_buckets`.
    """
    errors, warnings, _ = _bucket_with_totals(entries, cap)
    return errors, warnings


def _bucket_with_totals(entries: list[dict[str, Any]], cap: int) -> tuple[
        list[dict[str, Any]], list[dict[str, Any]], dict[str, Any]]:
    """Internal: classify + dedupe + cap, AND compute totals / kind buckets.

    Returns (errors[cap], warnings[cap], stats) where stats =
      {errorTotal, warningTotal, errorKinds: Counter, warningKinds: Counter}

    Dedupe here matches the original behaviour: consecutive identical messages
    collapse into one bucket entry. Totals, however, count EVERY classified
    entry — that's the whole point, so a flood of 800 identical FK violations
    shows up as errorTotal=800 even though errors[] may hold only 20.
    """
    errors: list[dict[str, Any]] = []
    warnings: list[dict[str, Any]] = []
    last_error_msg: Optional[str] = None
    last_warning_msg: Optional[str] = None
    error_total = 0
    warning_total = 0
    error_kinds: dict[str, int] = {}
    warning_kinds: dict[str, int] = {}

    for entry in entries:
        kind = (classify_log_line(entry)
                if not entry.get("_non_json")
                else classify_log_text(str(entry.get("message", ""))))
        if not kind:
            continue
        msg = str(entry.get("message") or entry.get("msg") or "").strip()
        fp = fingerprint_message(msg)
        slim = {
            "timestamp": entry.get("timestamp") or entry.get("time"),
            "level": entry.get("level"),
            "message": msg[:500],
            "module": entry.get("module"),
        }
        if kind == "error":
            error_total += 1
            if fp:
                error_kinds[fp] = error_kinds.get(fp, 0) + 1
            if msg == last_error_msg:
                continue
            last_error_msg = msg
            errors.append(slim)
        else:
            warning_total += 1
            if fp:
                warning_kinds[fp] = warning_kinds.get(fp, 0) + 1
            if msg == last_warning_msg:
                continue
            last_warning_msg = msg
            warnings.append(slim)

    stats = {
        "errorTotal": error_total,
        "warningTotal": warning_total,
        "errorKinds": error_kinds,
        "warningKinds": warning_kinds,
    }
    # Keep most-recent `cap` entries. Logs are typically returned oldest-first,
    # so keep the tail. If entries are newest-first, this still gives us `cap`
    # contiguous items — downstream consumers should not rely on the order.
    return errors[-cap:], warnings[-cap:], stats


def top_n_kinds(kinds: dict[str, int], n: int = DEFAULT_KINDS_TOP_N) -> dict[str, int]:
    """Return the top-N entries of a fingerprint→count map, sorted by count
    desc then fingerprint asc. Emits as dict (JSON preserves insertion order)."""
    items = sorted(kinds.items(), key=lambda kv: (-kv[1], kv[0]))[:n]
    return {k: v for k, v in items}


# ──────────────────────────── railway wrappers ────────────────────────────


def check_prereqs() -> None:
    rc, out, _ = railway(["--version"], timeout=10)
    if rc != 0:
        die("railway CLI not found on PATH — install from https://docs.railway.com/guides/cli")
    rc, out, _ = railway(["whoami"], timeout=10)
    if rc != 0 or "Logged in" not in out:
        die("not authenticated — run `railway login`")


def get_status() -> dict[str, Any]:
    """Return the project/env context from `railway status --json`.
    If not linked, return a synthetic object with a clear error."""
    rc, out, err = railway(["status", "--json"], timeout=15)
    if rc != 0:
        if "No linked project" in err or "not linked" in err.lower():
            die("no linked project — run `railway link` first")
        die(f"railway status failed: {err.strip() or out.strip()}")
    try:
        return json.loads(out)
    except json.JSONDecodeError as e:
        die(f"could not parse `railway status --json`: {e}")
    return {}  # unreachable


def list_services(env: Optional[str]) -> list[dict[str, Any]]:
    """Return per-service deploy status for the given env (or linked env)."""
    args = ["service", "status", "--all", "--json"]
    if env:
        args.extend(["--environment", env])
    rc, out, err = railway(args, timeout=30)
    if rc != 0:
        die(f"railway service status failed: {err.strip() or out.strip()}")
    try:
        data = json.loads(out)
    except json.JSONDecodeError as e:
        die(f"could not parse service status JSON: {e}")
        return []
    return data if isinstance(data, list) else []


def fetch_logs(service: str, env: Optional[str], *, lines: int, since: Optional[str]) -> str:
    args = ["logs", "-s", service, "--json", "--lines", str(lines)]
    if since:
        args.extend(["--since", since])
    if env:
        args.extend(["--environment", env])
    rc, out, err = railway(args, timeout=30)
    if rc != 0:
        # Don't abort — just return empty. A single service failing to stream
        # logs shouldn't kill the entire overview.
        sys.stderr.write(f"railway-ops: logs for '{service}' failed: {err.strip() or out.strip()}\n")
        return ""
    return out


def fetch_env_var_names(service: str, env: Optional[str]) -> list[str]:
    """Return env var NAMES only. Values are stripped before returning."""
    args = ["variables", "-s", service, "--json"]
    if env:
        args.extend(["--environment", env])
    rc, out, err = railway(args, timeout=20)
    if rc != 0:
        sys.stderr.write(f"railway-ops: variables for '{service}' failed: {err.strip() or out.strip()}\n")
        return []
    return strip_env_values(out)


def fetch_deployment_logs(deployment_id: str, *, lines: int = 300) -> str:
    """Fetch logs for a specific deployment (both build and runtime streams).

    Used primarily to pull the build-log tail for FAILED deploys. The Railway
    CLI targets a deployment with `--deployment <id>`; for build failures this
    returns only the build log since runtime never started.
    """
    if not deployment_id:
        return ""
    args = ["logs", "--deployment", deployment_id, "--json", "--lines", str(lines)]
    rc, out, err = railway(args, timeout=30)
    if rc != 0:
        sys.stderr.write(
            f"railway-ops: deployment logs for '{deployment_id}' failed: "
            f"{err.strip() or out.strip()}\n"
        )
        return ""
    return out


def _slim_build_entry(entry: dict[str, Any]) -> dict[str, Any]:
    """Slim a build-log entry down to the triage-relevant bits."""
    msg = str(entry.get("message") or entry.get("msg") or "").strip()
    return {
        "timestamp": entry.get("timestamp") or entry.get("time"),
        "message": msg[:500],
    }


_DEPLOY_FAILURE_STATUSES = {"FAILED", "CRASHED", "ERRORED", "SKIPPED"}

# Build logs fail in ways runtime logs don't — Docker "COPY failed", BuildKit
# "cache key" errors, "not found", "exit code: <n>". Runtime ERROR_RE misses
# most of these, so we use a broader regex specifically for the build stream.
# Intentionally permissive: this only runs on build-log context, where noise
# is low and false positives are cheap.
_BUILD_FAILURE_RE = re.compile(
    r"\b("
    r"error|fatal|failed|failure|panic|exception|traceback|unhandled|"
    r"cannot|denied|refused|unable|timeout|killed|"
    r"exit(?:\s+code)?|not\s+found|no\s+such"
    r")\b",
    re.IGNORECASE,
)


def _bucket_build_log(entries: list[dict[str, Any]], *, tail_cap: int) -> tuple[
        list[dict[str, Any]], dict[str, Any]]:
    """Bucket build-log entries: collect every non-empty line into `tail`
    (capped at the most-recent `tail_cap`), and fingerprint-count lines
    matching `_BUILD_FAILURE_RE` into `errorKinds`. Returns (tail, stats).

    Separate from `_bucket_with_totals` because build logs have different
    failure keywords and don't need dedupe (build output is already linear).
    """
    tail: list[dict[str, Any]] = []
    error_kinds: dict[str, int] = {}
    line_count = 0
    for entry in entries:
        msg = str(entry.get("message") or entry.get("msg") or "").strip()
        if not msg:
            continue
        line_count += 1
        tail.append({
            "timestamp": entry.get("timestamp") or entry.get("time"),
            "message": msg[:500],
        })
        if _BUILD_FAILURE_RE.search(msg):
            fp = fingerprint_message(msg)
            if fp:
                error_kinds[fp] = error_kinds.get(fp, 0) + 1
    return tail[-tail_cap:], {"errorKinds": error_kinds, "lineCount": line_count}


def enrich_deploy_with_build_logs(deploy: Optional[dict[str, Any]],
                                  *, tail: int = 30) -> Optional[dict[str, Any]]:
    """If `deploy` is in a failure state, mutate it in-place to add:
      - `buildLogTail`: last `tail` entries as slim dicts
      - `buildErrorKinds`: fingerprint→count across all build-log errors (pre-tail)
      - `buildLineCount`: total classified log lines pulled (signal for "did we
        get any logs at all")

    Safe no-op if deploy is None, has no id, or isn't in a failure state.
    Failures in log fetch are swallowed — enrichment is best-effort.
    """
    if not deploy:
        return deploy
    status = (deploy.get("status") or "").upper()
    if status not in _DEPLOY_FAILURE_STATUSES:
        return deploy
    deploy_id = deploy.get("id")
    if not deploy_id:
        return deploy
    raw = fetch_deployment_logs(deploy_id, lines=300)
    if not raw:
        return deploy
    entries = parse_log_entries(raw)
    tail_entries, stats = _bucket_build_log(entries, tail_cap=tail)
    if not tail_entries:
        return deploy
    deploy["buildLogTail"] = tail_entries
    deploy["buildErrorKinds"] = top_n_kinds(stats["errorKinds"])
    deploy["buildLineCount"] = stats["lineCount"]
    return deploy


# ──────────────────────────── GraphQL deploy history ────────────────────────────
#
# `railway service status --all --json` only returns ONE deployment per service
# — which is misleading in the common UI state of "SUCCESS deploy serving
# traffic, newer FAILED attempt on top." To expose both, we hit Railway's
# GraphQL API directly. Guarded behind RAILWAY_API_TOKEN / RAILWAY_TOKEN; if
# absent or the request fails, callers silently fall back to the single-deploy
# shape pulled from the CLI.

RAILWAY_GRAPHQL_URL = "https://backboard.railway.com/graphql/v2"

_DEPLOYMENTS_QUERY = """
query Deployments($serviceId: String!, $environmentId: String) {
  deployments(
    first: 10
    input: { serviceId: $serviceId, environmentId: $environmentId }
  ) {
    edges {
      node {
        id
        status
        createdAt
        updatedAt
        staticUrl
        meta
      }
    }
  }
}
"""


def _railway_api_token() -> Optional[str]:
    """Return the first non-empty Railway API token from the environment."""
    for key in ("RAILWAY_API_TOKEN", "RAILWAY_TOKEN"):
        v = os.environ.get(key, "").strip()
        if v:
            return v
    return None


def _graphql_request(query: str, variables: dict[str, Any], *,
                     timeout: int = 15) -> Optional[dict[str, Any]]:
    """POST a GraphQL query to Railway. Returns the `data` field or None on
    ANY failure (missing token, network, HTTP error, GraphQL errors). Never
    raises — callers use None as the signal to fall back.

    Imported lazily so we don't pay urllib startup cost when the GraphQL path
    isn't being used.
    """
    token = _railway_api_token()
    if not token:
        return None
    import urllib.request
    import urllib.error
    body = json.dumps({"query": query, "variables": variables}).encode("utf-8")
    req = urllib.request.Request(
        RAILWAY_GRAPHQL_URL,
        data=body,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {token}",
            "User-Agent": "railway-ops/0.2",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:  # noqa: S310
            payload = json.loads(resp.read().decode("utf-8"))
    except (urllib.error.HTTPError, urllib.error.URLError,
            json.JSONDecodeError, TimeoutError, OSError) as e:
        sys.stderr.write(f"railway-ops: graphql request failed: {e}\n")
        return None
    if payload.get("errors"):
        sys.stderr.write(f"railway-ops: graphql errors: {payload['errors']}\n")
        return None
    return payload.get("data")


def _slim_deploy(node: Optional[dict[str, Any]]) -> Optional[dict[str, Any]]:
    """Flatten a GraphQL deployment node into the stable shape we emit. Pulls
    the interesting bits from `meta` (commit SHA, message, PR number) so agents
    don't have to dig, but keeps the raw meta too."""
    if not node:
        return None
    meta = node.get("meta") or {}
    commit_msg = str(meta.get("commitMessage") or "").strip()
    return {
        "id": node.get("id"),
        "status": node.get("status"),
        "createdAt": node.get("createdAt"),
        "updatedAt": node.get("updatedAt"),
        "staticUrl": node.get("staticUrl"),
        "commitSha": meta.get("commitHash") or meta.get("commit"),
        "commitMessage": commit_msg[:300] if commit_msg else None,
        "prNumber": meta.get("prNumber") or meta.get("pullRequestNumber"),
        "branch": meta.get("branch"),
    }


def fetch_deploy_history(service_id: Optional[str],
                         environment_id: Optional[str]) -> Optional[list[dict[str, Any]]]:
    """Return newest-first list of recent deployments for a service, or None
    if the GraphQL path is unavailable (no token, request failed, schema drift).

    Callers MUST handle None — the cheap CLI `service status` path provides
    the single-deploy fallback used when this returns None.
    """
    if not service_id:
        return None
    data = _graphql_request(_DEPLOYMENTS_QUERY, {
        "serviceId": service_id,
        "environmentId": environment_id,
    })
    if not data:
        return None
    edges = ((data.get("deployments") or {}).get("edges")) or []
    nodes = [e.get("node") for e in edges if isinstance(e, dict) and e.get("node")]
    return nodes


def classify_deploys(history: list[dict[str, Any]]) -> tuple[
        Optional[dict[str, Any]], Optional[dict[str, Any]]]:
    """From a newest-first deploy list, pick (activeDeploy, latestDeploy).

    - `latestDeploy` is always history[0] — the most recent attempt, regardless
      of status. This is what the railway UI flags at the top of the list.
    - `activeDeploy` is the most recent deploy whose status is SUCCESS — the
      one actually serving traffic. It may be the same as latestDeploy (when
      the newest attempt succeeded), older than it (newer attempt failed), or
      None (nothing ever succeeded).
    """
    if not history:
        return None, None
    latest = history[0]
    active = next(
        (d for d in history if (d.get("status") or "").upper() == "SUCCESS"),
        None,
    )
    return active, latest


# ──────────────────────────── overview builder ────────────────────────────


def build_service_snapshot(
    service_row: dict[str, Any],
    env: Optional[str],
    *,
    since: str,
    log_lines: int,
    bucket_cap: int,
    environment_id: Optional[str] = None,
) -> dict[str, Any]:
    name = service_row.get("name") or service_row.get("id") or "unknown"
    service_id = service_row.get("id")
    raw_logs = fetch_logs(name, env, lines=log_lines, since=since)
    entries = parse_log_entries(raw_logs)
    errors, warnings, stats = _bucket_with_totals(entries, bucket_cap)
    env_var_names = fetch_env_var_names(name, env)

    # Fallback deploy shape from the CLI — always present, single entry.
    cli_deploy = {
        "id": service_row.get("deploymentId"),
        "status": service_row.get("status"),
        "createdAt": None,
        "updatedAt": None,
        "staticUrl": None,
        "commitSha": None,
        "commitMessage": None,
        "prNumber": None,
        "branch": None,
    }
    active_deploy: Optional[dict[str, Any]] = None
    latest_deploy: dict[str, Any] = cli_deploy

    # Richer history via GraphQL, if a token is available. Any failure falls
    # back to the CLI shape silently — the overview must not break just because
    # the API refused a query.
    history = fetch_deploy_history(service_id, environment_id)
    if history:
        active_node, latest_node = classify_deploys(history)
        slim_active = _slim_deploy(active_node)
        slim_latest = _slim_deploy(latest_node)
        if slim_latest:
            latest_deploy = slim_latest
        if slim_active:
            active_deploy = slim_active

    # If the latest attempt failed AND it's distinct from what's actually
    # serving, auto-include a build-log tail + errorKinds so the overview
    # carries everything needed to triage a failed deploy in one call. This
    # is specifically the UI "ACTIVE (23h ago) + FAILED (8m ago)" case.
    latest_failed_and_newer = (
        (latest_deploy.get("status") or "").upper() in _DEPLOY_FAILURE_STATUSES
        and (active_deploy is None
             or active_deploy.get("id") != latest_deploy.get("id"))
    )
    if latest_failed_and_newer:
        enrich_deploy_with_build_logs(latest_deploy, tail=30)

    return {
        "name": name,
        "id": service_id,
        "status": service_row.get("status"),
        "stopped": service_row.get("stopped"),
        "activeDeploy": active_deploy,
        "latestDeploy": latest_deploy,
        "errors": errors,
        "warnings": warnings,
        "errorTotal": stats["errorTotal"],
        "warningTotal": stats["warningTotal"],
        "errorKinds": top_n_kinds(stats["errorKinds"]),
        "warningKinds": top_n_kinds(stats["warningKinds"]),
        "truncated": stats["errorTotal"] > len(errors) or stats["warningTotal"] > len(warnings),
        "envVarNames": env_var_names,
    }


def _resolve_environment_id(status: dict[str, Any], env_name: Optional[str]) -> Optional[str]:
    """Pick the environment ID matching `env_name` from `railway status --json`.

    Railway's status payload exposes `environments.edges[].node.{id, name}`;
    we match case-insensitively on the name. If env_name is None, we can't
    disambiguate, so we return None and let the GraphQL query omit the filter.
    """
    if not env_name:
        return None
    edges = ((status.get("environments") or {}).get("edges")) or []
    lower = env_name.lower()
    for edge in edges:
        if not isinstance(edge, dict):
            continue
        node = edge.get("node") or {}
        if str(node.get("name", "")).lower() == lower:
            return node.get("id")
    return None


_FAILURE_STATUSES = {"FAILED", "CRASHED", "ERRORED", "REMOVED"}


def _summarize_snapshots(snapshots: list[dict[str, Any]]) -> dict[str, int]:
    """Compute totals across service snapshots for the top-level `summary` field.

    Counts:
      services  — total snapshots included (post-filter)
      failures  — snapshots whose `status` is a known failure state OR that
                  errored out during collection (`error` field present)
      errors    — sum of per-service error-bucket sizes
      warnings  — sum of per-service warning-bucket sizes
    """
    failures = 0
    errors = 0
    warnings = 0
    for snap in snapshots:
        status = (snap.get("status") or "").upper()
        if status in _FAILURE_STATUSES or snap.get("error"):
            failures += 1
        # Prefer the pre-cap totals (errorTotal/warningTotal) so a flood of
        # identical errors is reflected here; fall back to bucket length for
        # old callers / collection-failure snapshots.
        errors += int(snap.get("errorTotal", len(snap.get("errors") or [])))
        warnings += int(snap.get("warningTotal", len(snap.get("warnings") or [])))
    return {
        "services": len(snapshots),
        "failures": failures,
        "errors": errors,
        "warnings": warnings,
    }


def build_overview(
    env: Optional[str],
    since: str,
    log_lines: int,
    *,
    service_filter: Optional[str] = None,
    bucket_cap: int = DEFAULT_OVERVIEW_BUCKET_CAP,
) -> dict[str, Any]:
    status = get_status()
    project_name = status.get("name", "unknown")
    # Resolve the env used for this snapshot — if not passed, use linked env.
    resolved_env = env
    if not resolved_env:
        # Try to extract linked env from the status payload. Railway's status
        # JSON shape doesn't put the currently-linked env at top-level, so we
        # just leave this as None and rely on the CLI default.
        resolved_env = None

    # Resolve env NAME → env ID from the status payload so the GraphQL
    # deployments query can filter correctly. If env not found, pass None and
    # let the API return deploys across all envs for the service.
    environment_id = _resolve_environment_id(status, resolved_env)

    services = list_services(resolved_env)

    if service_filter:
        target = service_filter.lower()
        services = [s for s in services if (s.get("name") or "").lower() == target]

    # Parallelise per-service fetches — each one is 2 CLI roundtrips (logs +
    # variables). Thread pool is fine since we're CPU-idle while subprocess
    # blocks on network I/O.
    snapshots: list[dict[str, Any]] = []
    max_workers = max(2, min(8, len(services) or 1))
    with ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = {
            pool.submit(
                build_service_snapshot, svc, resolved_env,
                since=since, log_lines=log_lines, bucket_cap=bucket_cap,
                environment_id=environment_id,
            ): svc.get("name", "?")
            for svc in services
        }
        for fut in as_completed(futures):
            try:
                snapshots.append(fut.result())
            except Exception as e:  # noqa: BLE001
                snapshots.append({
                    "name": futures[fut],
                    "error": f"snapshot failed: {e}",
                })

    snapshots.sort(key=lambda s: (s.get("name") or "").lower())
    return {
        "project": project_name,
        "projectId": status.get("id"),
        "env": resolved_env or "<linked>",
        "since": since,
        "filter": {"service": service_filter} if service_filter else None,
        "summary": _summarize_snapshots(snapshots),
        "services": snapshots,
    }


# ──────────────────────────── command dispatch ────────────────────────────


def die(msg: str) -> None:
    print(f"railway-ops: {msg}", file=sys.stderr)
    sys.exit(1)


def emit(data: Any, pretty: bool) -> None:
    if pretty:
        print(json.dumps(data, indent=2, default=str))
    else:
        print(json.dumps(data, default=str))


def cmd_overview(args: argparse.Namespace) -> None:
    check_prereqs()
    data = build_overview(
        args.env,
        args.since,
        args.log_lines,
        service_filter=args.service,
        bucket_cap=args.limit,
    )
    emit(data, args.pretty)


def cmd_status(args: argparse.Namespace) -> None:
    check_prereqs()
    rc, out, err = railway(["whoami"], timeout=10)
    whoami = out.strip() if rc == 0 else None
    status = get_status()
    emit({
        "whoami": whoami,
        "project": status.get("name"),
        "projectId": status.get("id"),
        "environments": [
            e["node"]["name"]
            for e in (status.get("environments", {}) or {}).get("edges", [])
            if isinstance(e, dict) and isinstance(e.get("node"), dict)
        ],
    }, args.pretty)


def cmd_errors(args: argparse.Namespace) -> None:
    check_prereqs()
    since = args.since
    since_source = "flag"
    # --since-deploy: use the currently-active deploy's createdAt as the
    # cutoff, so triage scopes to "errors since the running deploy came up".
    # Needs GraphQL (which needs RAILWAY_API_TOKEN) — falls back to --since
    # if we can't resolve an active deploy, with a stderr warning so the user
    # knows why the scope is wider than they asked for.
    if getattr(args, "since_deploy", False):
        status = get_status()
        env_id = _resolve_environment_id(status, args.env)
        svc = next(
            (s for s in list_services(args.env)
             if (s.get("name") or "").lower() == args.service.lower()),
            None,
        )
        history = fetch_deploy_history(svc.get("id") if svc else None, env_id)
        active_node, _latest = classify_deploys(history or [])
        active = _slim_deploy(active_node)
        if active and active.get("createdAt"):
            since = active["createdAt"]
            since_source = "active-deploy"
        else:
            sys.stderr.write(
                "railway-ops: --since-deploy: could not resolve an active "
                "deploy (no RAILWAY_API_TOKEN, service not found, or no "
                "successful deploy yet). Falling back to --since=" + since + "\n"
            )
    # Pull more lines than overview — this command is focused.
    raw = fetch_logs(args.service, args.env, lines=max(args.limit * 10, 500), since=since)
    entries = parse_log_entries(raw)
    errors, warnings, stats = _bucket_with_totals(entries, args.limit)
    emit({
        "service": args.service,
        "env": args.env or "<linked>",
        "since": since,
        "sinceSource": since_source,
        "errors": errors,
        "warnings": warnings,
        "errorTotal": stats["errorTotal"],
        "warningTotal": stats["warningTotal"],
        "errorKinds": top_n_kinds(stats["errorKinds"]),
        "warningKinds": top_n_kinds(stats["warningKinds"]),
        "truncated": stats["errorTotal"] > len(errors) or stats["warningTotal"] > len(warnings),
    }, args.pretty)


def cmd_envs(args: argparse.Namespace) -> None:
    check_prereqs()
    names = fetch_env_var_names(args.service, args.env)
    emit({
        "service": args.service,
        "env": args.env or "<linked>",
        "envVarNames": names,
        "count": len(names),
    }, args.pretty)


def cmd_services(args: argparse.Namespace) -> None:
    check_prereqs()
    services = list_services(args.env)
    emit({
        "env": args.env or "<linked>",
        "services": [
            {
                "name": s.get("name"),
                "id": s.get("id"),
                "status": s.get("status"),
                "stopped": s.get("stopped"),
                "latestDeploymentId": s.get("deploymentId"),
            }
            for s in services
        ],
    }, args.pretty)


def cmd_projects(args: argparse.Namespace) -> None:
    check_prereqs()
    rc, out, err = railway(["list", "--json"], timeout=15)
    if rc != 0:
        die(f"railway list failed: {err.strip() or out.strip()}")
    try:
        data = json.loads(out)
    except json.JSONDecodeError as e:
        die(f"could not parse `railway list --json`: {e}")
        return
    emit(data, args.pretty)


# ──────────────────────────── argparse ────────────────────────────


def _add_globals(p: argparse.ArgumentParser) -> None:
    p.add_argument("--pretty", action="store_true", help="indent JSON output")


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="railway-ops",
        description="Read-first wrapper around the Railway CLI for incident triage.",
    )
    _add_globals(p)
    sub = p.add_subparsers(dest="cmd", required=True)

    over = sub.add_parser("overview", help="full env/services/errors/envs snapshot")
    _add_globals(over)
    over.add_argument("--env", help="Railway environment name (e.g. production, staging)")
    over.add_argument("--service",
                      help="filter snapshot to a single service name (focused triage)")
    over.add_argument("--since", default=DEFAULT_SINCE,
                      help=f"pull logs since this duration (default: {DEFAULT_SINCE})")
    over.add_argument("--log-lines", type=int, default=DEFAULT_OVERVIEW_LOG_LINES,
                      help=f"log lines per service (default: {DEFAULT_OVERVIEW_LOG_LINES})")
    over.add_argument("--limit", type=int, default=DEFAULT_OVERVIEW_BUCKET_CAP,
                      help=(f"per-service cap on errors and warnings "
                            f"(default: {DEFAULT_OVERVIEW_BUCKET_CAP})"))

    st = sub.add_parser("status", help="current project/env/whoami context")
    _add_globals(st)

    er = sub.add_parser("errors", help="errors+warnings for one service")
    _add_globals(er)
    er.add_argument("service", help="Railway service name")
    er.add_argument("--env", help="Railway environment name")
    er.add_argument("--since", default=DEFAULT_SINCE,
                    help=f"pull logs since this duration (default: {DEFAULT_SINCE})")
    er.add_argument("--limit", type=int, default=DEFAULT_ERRORS_LIMIT,
                    help=(f"cap on errors and warnings buckets "
                          f"(default: {DEFAULT_ERRORS_LIMIT})"))
    er.add_argument("--since-deploy", action="store_true", dest="since_deploy",
                    help=("pull logs since the currently-active deploy's "
                          "createdAt (overrides --since). Requires "
                          "RAILWAY_API_TOKEN; falls back to --since with a "
                          "warning if unavailable."))

    ev = sub.add_parser("envs", help="env var NAMES only for one service (values stripped)")
    _add_globals(ev)
    ev.add_argument("service")
    ev.add_argument("--env", help="Railway environment name")

    sv = sub.add_parser("services", help="per-service deploy status in an env")
    _add_globals(sv)
    sv.add_argument("--env", help="Railway environment name")

    sub.add_parser("projects", help="list all Railway projects").add_argument(
        "--pretty", action="store_true", help="indent JSON output",
    )

    return p


DISPATCH = {
    "overview": cmd_overview,
    "status": cmd_status,
    "errors": cmd_errors,
    "envs": cmd_envs,
    "services": cmd_services,
    "projects": cmd_projects,
}


def main() -> None:
    args = build_parser().parse_args()
    fn = DISPATCH[args.cmd]
    fn(args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
