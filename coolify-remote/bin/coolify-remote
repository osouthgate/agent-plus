#!/usr/bin/env python3
"""coolify-remote — CLI for managing a Coolify instance over its REST API.

Collapses the common Coolify fumbles into one-liners:

  - Resolves apps by name (no UUID threading through call chains)
  - Sends the correct field names (`domains`, not `fqdn`) with client-side validation
  - `deploy --wait` polls to completion instead of hand-rolled `until` loops
  - `env set --verify` reads vars back after writing to catch silent no-ops
  - `tls enable` bundles domain + force_https + deploy + cert smoke test
  - No shell heredocs, no temp files — JSON parsed in-process (works on Windows)

Configuration (highest precedence first):
  1. --env-file <path>
  2. ./.env.local, ./.env   (walked up from cwd)
  3. Shell environment       (including Claude Code settings)

Project .env files WIN over the shell — drop a .env in your repo and it
overrides whatever globals you have set, no unset required.

Env vars read:
  COOLIFY_URL          e.g. http://1.2.3.4:8000 or https://coolify.example.com
  COOLIFY_API_KEY      Bearer token from Coolify → Keys & Tokens

For `app exec` (SSH-based, since Coolify has no REST exec endpoint):
  COOLIFY_SSH_HOST     override for the SSH target (default: host parsed from COOLIFY_URL)
  COOLIFY_SSH_USER     SSH user (default: root)
  COOLIFY_SSH_KEY      SSH private key path (default: ssh's own defaults / agent)
  COOLIFY_SSH_PORT     SSH port (default: 22)

Python 3.9+, stdlib only.
"""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any

# ─── .env autoloading ─────────────────────────────────────────────────────────

_ENV_FILENAMES = (".env.local", ".env")
_ENV_PREFIXES = ("COOLIFY_",)


def _parse_env_file(path: Path) -> dict[str, str]:
    out: dict[str, str] = {}
    try:
        text = path.read_text(encoding="utf-8")
    except Exception:
        return out
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :].lstrip()
        if "=" not in line:
            continue
        k, v = line.split("=", 1)
        k = k.strip()
        v = v.strip()
        if len(v) >= 2 and v[0] == v[-1] and v[0] in ("'", '"'):
            v = v[1:-1]
        if k:
            out[k] = v
    return out


def _autoload_env_files(extra: list[str] | None = None) -> list[Path]:
    """Populate os.environ from .env files. Project files override the shell
    for COOLIFY_* keys.

    Precedence (highest first): --env-file, then project .env.local, then
    project .env, then shell. Candidates collected high-to-low, then applied
    low-to-high so each higher-priority file overwrites on top.
    """
    candidates: list[Path] = []
    seen: set[Path] = set()

    def _push(p: Path) -> None:
        p = p.expanduser().resolve()
        if p in seen or not p.is_file():
            return
        seen.add(p)
        candidates.append(p)

    for f in extra or []:
        _push(Path(f))

    cwd = Path.cwd().resolve()
    for parent in (cwd, *cwd.parents):
        before = len(candidates)
        for name in _ENV_FILENAMES:
            _push(parent / name)
        if len(candidates) > before:
            break

    loaded: list[Path] = []
    for p in reversed(candidates):
        vals = _parse_env_file(p)
        any_taken = False
        for k, v in vals.items():
            if not k.startswith(_ENV_PREFIXES):
                continue
            os.environ[k] = v
            any_taken = True
        if any_taken:
            loaded.append(p)
    return loaded


def _suggest_env_setup(missing: str) -> str:
    cwd = Path.cwd()
    return (
        f"{missing}\n\n"
        "Set these in whichever is most convenient — project files win over shell env:\n\n"
        f"  Project-level (preferred):  {cwd / '.env'}\n"
        "    # .env\n"
        "    COOLIFY_URL=https://coolify.example.com\n"
        "    COOLIFY_API_KEY=...\n\n"
        "  Global (Claude Code settings):\n"
        "    ~/.claude/settings.json → \"env\": { \"COOLIFY_URL\": \"...\", \"COOLIFY_API_KEY\": \"...\" }\n"
        "    (or export them in your shell profile)\n"
    )


# ─── transport ────────────────────────────────────────────────────────────────


class CoolifyClient:
    def __init__(self) -> None:
        url = os.environ.get("COOLIFY_URL", "").rstrip("/")
        key = os.environ.get("COOLIFY_API_KEY", "")
        if not url or not key:
            raise SystemExit(_suggest_env_setup(
                "COOLIFY_URL and COOLIFY_API_KEY must both be set."
            ))
        self.base_url = url
        self.api_key = key

    def call(
        self,
        method: str,
        path: str,
        body: Any = None,
        *,
        query: dict[str, Any] | None = None,
        timeout: float = 60.0,
    ) -> tuple[int, Any]:
        url = f"{self.base_url}{path}"
        if query:
            url += "?" + urllib.parse.urlencode({k: v for k, v in query.items() if v is not None})
        headers = {
            "Authorization": f"Bearer {self.api_key}",
            "Accept": "application/json",
        }
        data: bytes | None = None
        if body is not None:
            data = json.dumps(body).encode()
            headers["Content-Type"] = "application/json"
        req = urllib.request.Request(url, data=data, headers=headers, method=method)
        try:
            with urllib.request.urlopen(req, timeout=timeout) as resp:
                raw = resp.read()
                status = resp.status
        except urllib.error.HTTPError as e:
            raw = e.read()
            status = e.code
        try:
            parsed = json.loads(raw) if raw else None
        except json.JSONDecodeError:
            parsed = raw
        return status, parsed

    # ── app resolution ────────────────────────────────────────────────────────

    def _apps(self) -> list[dict]:
        status, data = self.call("GET", "/api/v1/applications")
        if status >= 300 or not isinstance(data, list):
            raise SystemExit(f"GET /api/v1/applications failed: HTTP {status}: {data!r}")
        return data

    def resolve_app(self, ident: str) -> dict:
        """Find an app by name or UUID. Returns the full app record."""
        apps = self._apps()
        # Exact UUID match first (cheap).
        for a in apps:
            if a.get("uuid") == ident:
                return a
        # Exact name match.
        for a in apps:
            if a.get("name") == ident:
                return a
        # FQDN substring (occasionally useful).
        for a in apps:
            fqdn = a.get("fqdn") or ""
            if ident in fqdn:
                return a
        names = ", ".join(sorted(a.get("name", "?") for a in apps)) or "(none)"
        raise SystemExit(f"No app matching {ident!r}. Known apps: {names}")


# ─── pretty printers ──────────────────────────────────────────────────────────


def _dump_json(obj: Any) -> None:
    json.dump(obj, sys.stdout, indent=2, sort_keys=True, default=str)
    sys.stdout.write("\n")


def _print_app_row(a: dict) -> None:
    fqdn = (a.get("fqdn") or "").split(",")[0].strip() or "-"
    status = a.get("status") or "?"
    print(f"  {a.get('name',''):24s} {status:22s} {fqdn}")


# ─── subcommands ──────────────────────────────────────────────────────────────


def cmd_app_list(client: CoolifyClient, args: argparse.Namespace) -> None:
    apps = client._apps()
    if args.json:
        _dump_json(apps)
        return
    print(f"{len(apps)} application(s):")
    print(f"  {'name':24s} {'status':22s} fqdn")
    for a in sorted(apps, key=lambda x: x.get("name", "")):
        _print_app_row(a)


def cmd_app_show(client: CoolifyClient, args: argparse.Namespace) -> None:
    app = client.resolve_app(args.app)
    # Re-fetch by UUID to get the full record (list endpoint may summarise).
    status, full = client.call("GET", f"/api/v1/applications/{app['uuid']}")
    _dump_json(full if status < 300 else app)


def _resolve_ssh_host() -> str:
    """Figure out where to SSH. Priority: COOLIFY_SSH_HOST explicit override →
    hostname/IP parsed from COOLIFY_URL. Fails with a useful hint otherwise.

    Coolify has no REST exec endpoint (`/applications/{uuid}/execute` et al
    return 404). The web UI uses a WebSocket terminal; we take the simpler
    path and shell out to `ssh host 'docker exec …'`. For single-VPS setups
    (is_coolify_host=true) this is the same box hosting the workload anyway.
    """
    explicit = os.environ.get("COOLIFY_SSH_HOST", "").strip()
    if explicit:
        return explicit
    url = os.environ.get("COOLIFY_URL", "")
    if url:
        try:
            parsed = urllib.parse.urlparse(url)
            if parsed.hostname:
                return parsed.hostname
        except Exception:
            pass
    raise SystemExit(
        "Cannot determine SSH host. Set COOLIFY_SSH_HOST explicitly, or make "
        "sure COOLIFY_URL contains a real hostname/IP (not 'host.docker.internal')."
    )


def cmd_app_exec(client: CoolifyClient, args: argparse.Namespace) -> None:
    """Run a shell command inside the app's running Docker container.

    Implementation: SSH to the Coolify host and `docker exec` into the
    container Coolify tagged with the app's UUID. Needs ssh on PATH and
    a working key-based connection to the host (no password prompts).
    """
    # argparse.REMAINDER keeps the leading `--` sentinel in args.command;
    # strip it so we don't forward it to `sh -c` as a no-op argument.
    if args.command and args.command[0] == "--":
        args.command = args.command[1:]
    if not args.command:
        raise SystemExit(
            "No command given. Pass it after --, e.g.\n"
            "  coolify-remote app exec hermes -- ls /data"
        )

    app = client.resolve_app(args.app)
    uuid = app["uuid"]
    host = _resolve_ssh_host()
    user = os.environ.get("COOLIFY_SSH_USER", "root")
    port = os.environ.get("COOLIFY_SSH_PORT", "22")
    key = os.environ.get("COOLIFY_SSH_KEY", "").strip()

    # Compose the remote-side command. One round trip: find the container by
    # name prefix (Coolify names running containers `<app-uuid>-<timestamp>`),
    # then docker exec into it. Uses `--filter name=<uuid>` which does prefix
    # matching by default — matches whichever timestamped deploy is live.
    # Fails cleanly with exit 2 if no container is running for this app.
    user_cmd = " ".join(shlex.quote(a) for a in args.command)
    docker_flags = "-i" + ("t" if args.tty else "")
    remote = (
        f"CID=$(docker ps --filter name={shlex.quote(uuid)} "
        f"--format '{{{{.ID}}}}' | head -n1); "
        f'if [ -z "$CID" ]; then '
        f'echo "coolify-remote: no running container found for app {uuid}" >&2; exit 2; '
        f"fi; "
        f"docker exec {docker_flags} \"$CID\" sh -c {shlex.quote(user_cmd)}"
    )

    ssh_cmd = ["ssh"]
    if args.tty:
        ssh_cmd.append("-t")
    ssh_cmd += ["-p", port]
    if key:
        ssh_cmd += ["-i", key]
    # Silence the "Warning: Permanently added ... to known hosts" noise for
    # cron-style use; user can override with --verbose.
    if not args.verbose:
        ssh_cmd += ["-o", "LogLevel=ERROR"]
    ssh_cmd += [f"{user}@{host}", remote]

    if args.verbose:
        print(f"→ {' '.join(shlex.quote(a) for a in ssh_cmd)}", file=sys.stderr)

    try:
        result = subprocess.run(ssh_cmd)
    except FileNotFoundError:
        raise SystemExit("ssh not found on PATH")
    sys.exit(result.returncode)


def cmd_env_list(client: CoolifyClient, args: argparse.Namespace) -> None:
    app = client.resolve_app(args.app)
    status, data = client.call("GET", f"/api/v1/applications/{app['uuid']}/envs")
    if status >= 300:
        raise SystemExit(f"GET envs failed: HTTP {status}: {data!r}")
    if args.json:
        _dump_json(data)
        return
    if not isinstance(data, list):
        _dump_json(data)
        return
    for e in sorted(data, key=lambda x: x.get("key", "")):
        key = e.get("key", "")
        val = e.get("value", "")
        if val and len(val) > 12 and not args.show:
            val = val[:4] + "…" + val[-4:]
        preview = " [preview]" if e.get("is_preview") else ""
        print(f"  {key:32s} {val}{preview}")


def _parse_kv_pairs(pairs: list[str]) -> dict[str, str]:
    out: dict[str, str] = {}
    for p in pairs:
        if "=" not in p:
            raise SystemExit(f"Expected KEY=VALUE, got: {p!r}")
        k, v = p.split("=", 1)
        out[k.strip()] = v
    return out


def _upsert_env(client: CoolifyClient, app_uuid: str, key: str, value: str, is_preview: bool) -> int:
    """POST new env; if it already exists (409/422), PATCH it."""
    payload = {
        "key": key,
        "value": value,
        "is_preview": is_preview,
        "is_literal": True,
    }
    status, data = client.call("POST", f"/api/v1/applications/{app_uuid}/envs", body=payload)
    if status < 300:
        return status
    # Coolify returns 422 "already exists" — update instead.
    status2, data2 = client.call("PATCH", f"/api/v1/applications/{app_uuid}/envs", body=payload)
    if status2 >= 300:
        raise SystemExit(f"Failed to set {key}: POST {status} {data!r} / PATCH {status2} {data2!r}")
    return status2


def cmd_env_set(client: CoolifyClient, args: argparse.Namespace) -> None:
    app = client.resolve_app(args.app)
    pairs = _parse_kv_pairs(args.pairs)
    if not pairs:
        raise SystemExit("No KEY=VALUE pairs given")

    for k, v in pairs.items():
        status = _upsert_env(client, app["uuid"], k, v, args.preview)
        print(f"  set {k} (HTTP {status})")

    if args.verify:
        # Read back via API. Note: this only verifies Coolify has stored it,
        # not that it propagated to the running container — that's a known
        # Coolify gotcha. If the app is redeployed, values land in-container.
        s, data = client.call("GET", f"/api/v1/applications/{app['uuid']}/envs")
        if s >= 300 or not isinstance(data, list):
            print(f"  verify: could not read envs back (HTTP {s})", file=sys.stderr)
        else:
            by_key = {e.get("key"): e.get("value") for e in data}
            bad = [k for k, v in pairs.items() if by_key.get(k) != v]
            if bad:
                print(f"  verify: MISMATCH after write: {', '.join(bad)}", file=sys.stderr)
                sys.exit(2)
            print(f"  verify: OK — {len(pairs)} key(s) match in API")
            print("  (note: container needs redeploy to see new values — use --deploy)")

    if args.deploy:
        _deploy_and_maybe_wait(client, app, wait=args.wait, force=True)


def cmd_env_sync(client: CoolifyClient, args: argparse.Namespace) -> None:
    app = client.resolve_app(args.app)
    vals = _parse_env_file(Path(args.file).expanduser().resolve())
    if not vals:
        raise SystemExit(f"No values parsed from {args.file}")
    if args.prefix:
        vals = {k: v for k, v in vals.items() if k.startswith(args.prefix)}
    if not vals:
        raise SystemExit(f"No keys match prefix {args.prefix!r}")
    print(f"Syncing {len(vals)} key(s) from {args.file} to {app['name']}:")
    for k, v in vals.items():
        status = _upsert_env(client, app["uuid"], k, v, args.preview)
        print(f"  set {k} (HTTP {status})")
    if args.deploy:
        _deploy_and_maybe_wait(client, app, wait=args.wait, force=True)


def cmd_domain_set(client: CoolifyClient, args: argparse.Namespace) -> None:
    app = client.resolve_app(args.app)
    body: dict[str, Any] = {"domains": args.url}
    if args.force_https is not None:
        body["is_force_https_enabled"] = args.force_https
    if args.instant_deploy:
        body["instant_deploy"] = True
    status, data = client.call("PATCH", f"/api/v1/applications/{app['uuid']}", body=body)
    if status >= 300:
        print(f"HTTP {status}: PATCH failed", file=sys.stderr)
        _dump_json(data)
        sys.exit(1)
    print(f"HTTP {status}: domain set to {args.url}")
    if args.deploy:
        _deploy_and_maybe_wait(client, app, wait=args.wait, force=True)


def cmd_deploy(client: CoolifyClient, args: argparse.Namespace) -> None:
    app = client.resolve_app(args.app)
    _deploy_and_maybe_wait(client, app, wait=args.wait, force=args.force)


def _deploy_and_maybe_wait(
    client: CoolifyClient, app: dict, *, wait: bool, force: bool
) -> None:
    status, data = client.call(
        "GET", "/api/v1/deploy", query={"uuid": app["uuid"], "force": "true" if force else "false"}
    )
    if status >= 300:
        print(f"HTTP {status}: deploy trigger failed", file=sys.stderr)
        _dump_json(data)
        sys.exit(1)
    deployments = (data or {}).get("deployments") if isinstance(data, dict) else None
    dep_uuid = None
    if deployments:
        dep_uuid = deployments[0].get("resource_uuid") or deployments[0].get("uuid")
    print(f"HTTP {status}: deploy triggered for {app['name']} (deployment {dep_uuid or '?'})")
    if not wait or not dep_uuid:
        return

    print("Waiting for deployment to finish…")
    terminal = {"finished", "failed", "cancelled-by-user", "cancelled-by-system"}
    last = None
    start = time.time()
    while True:
        s, d = client.call("GET", f"/api/v1/deployments/{dep_uuid}")
        if s >= 300:
            print(f"  poll HTTP {s}: {d!r}", file=sys.stderr)
            time.sleep(3)
            continue
        state = (d or {}).get("status") if isinstance(d, dict) else None
        if state != last:
            elapsed = int(time.time() - start)
            print(f"  [{elapsed:4d}s] {state}")
            last = state
        if state in terminal:
            if state == "finished":
                return
            sys.exit(1)
        if time.time() - start > args.timeout:
            print(f"Timed out after {args.timeout}s in state {last!r}", file=sys.stderr)
            sys.exit(1)
        time.sleep(3)


def cmd_tls_enable(client: CoolifyClient, args: argparse.Namespace) -> None:
    """Bundle: set domain, enable force-https, redeploy, smoke-test HTTPS."""
    app = client.resolve_app(args.app)
    url = args.domain
    if not url.startswith("https://"):
        raise SystemExit(f"--domain must be an https:// URL, got {url!r}")

    print(f"[1/4] Setting domain → {url}")
    s, d = client.call(
        "PATCH",
        f"/api/v1/applications/{app['uuid']}",
        body={"domains": url, "is_force_https_enabled": True},
    )
    if s >= 300:
        print(f"HTTP {s}: PATCH failed", file=sys.stderr)
        _dump_json(d)
        sys.exit(1)

    print("[2/4] Triggering deploy")
    _deploy_and_maybe_wait(client, app, wait=True, force=True)

    print("[3/4] Waiting for Let's Encrypt cert provisioning (up to 120s)")
    # Coolify proxies request a cert on first hit; poll the HTTPS endpoint.
    ok = False
    start = time.time()
    while time.time() - start < 120:
        try:
            req = urllib.request.Request(url, method="HEAD")
            with urllib.request.urlopen(req, timeout=10) as resp:
                if resp.status < 500:
                    ok = True
                    break
        except Exception as e:
            print(f"  retry: {e.__class__.__name__}: {e}")
        time.sleep(5)

    print(f"[4/4] HTTPS smoke test: {'OK' if ok else 'FAILED'}")
    if not ok:
        sys.exit(1)


def cmd_server_list(client: CoolifyClient, args: argparse.Namespace) -> None:
    status, data = client.call("GET", "/api/v1/servers")
    if status >= 300:
        raise SystemExit(f"GET /api/v1/servers failed: HTTP {status}: {data!r}")
    if args.json:
        _dump_json(data)
        return
    if not isinstance(data, list):
        _dump_json(data)
        return
    print(f"{len(data)} server(s):")
    for s in data:
        print(f"  {s.get('name',''):24s} {s.get('ip',''):18s} {s.get('uuid','')}")


# ─── argparse wiring ──────────────────────────────────────────────────────────


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="coolify-remote",
        description="Remote CLI for a Coolify PaaS deployment",
    )
    p.add_argument(
        "--env-file",
        action="append",
        default=[],
        help="Additional .env file(s) to load (highest precedence). "
             "Project .env/.env.local (walked up from cwd) are auto-loaded "
             "and override shell env; --env-file overrides those in turn.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    # app
    sp = sub.add_parser("app", help="Manage applications")
    app_sub = sp.add_subparsers(dest="app_cmd", required=True)

    al = app_sub.add_parser("list", help="List applications")
    al.add_argument("--json", action="store_true")
    al.set_defaults(func=cmd_app_list)

    ash = app_sub.add_parser("show", help="Show full JSON for one app")
    ash.add_argument("app", help="App name or UUID")
    ash.set_defaults(func=cmd_app_show)

    ax = app_sub.add_parser(
        "exec",
        help="Run a shell command inside the app's container "
             "(SSH + docker exec under the hood — no REST exec endpoint exists)",
    )
    ax.add_argument("app", help="App name or UUID")
    ax.add_argument("-t", "--tty", action="store_true", help="Allocate a TTY (for interactive tools)")
    ax.add_argument("-v", "--verbose", action="store_true", help="Print the ssh command before running")
    ax.add_argument(
        "command",
        nargs=argparse.REMAINDER,
        help="Command to run inside the container. Prefix with -- to separate from flags.",
    )
    ax.set_defaults(func=cmd_app_exec)

    # env
    sp = sub.add_parser("env", help="Manage application env vars")
    env_sub = sp.add_subparsers(dest="env_cmd", required=True)

    el = env_sub.add_parser("list", help="List env vars for an app")
    el.add_argument("app")
    el.add_argument("--show", action="store_true", help="Show full values (default redacts)")
    el.add_argument("--json", action="store_true")
    el.set_defaults(func=cmd_env_list)

    es = env_sub.add_parser("set", help="Set one or more env vars (upsert)")
    es.add_argument("app")
    es.add_argument("pairs", nargs="+", metavar="KEY=VALUE")
    es.add_argument("--preview", action="store_true", help="Set on preview env instead of production")
    es.add_argument("--verify", action="store_true", help="Read envs back after write and check values match")
    es.add_argument("--deploy", action="store_true", help="Redeploy after setting (required for container to see new values)")
    es.add_argument("--wait", action="store_true", help="With --deploy, block until deployment finishes")
    es.add_argument("--timeout", type=int, default=600, help="Deploy wait timeout in seconds (default 600)")
    es.set_defaults(func=cmd_env_set)

    esync = env_sub.add_parser("sync", help="Upsert env vars from a local .env file")
    esync.add_argument("app")
    esync.add_argument("file", help="Path to .env file")
    esync.add_argument("--prefix", help="Only sync keys with this prefix")
    esync.add_argument("--preview", action="store_true")
    esync.add_argument("--deploy", action="store_true")
    esync.add_argument("--wait", action="store_true")
    esync.add_argument("--timeout", type=int, default=600)
    esync.set_defaults(func=cmd_env_sync)

    # domain
    sp = sub.add_parser("domain", help="Manage app domains")
    dom_sub = sp.add_subparsers(dest="domain_cmd", required=True)

    ds = dom_sub.add_parser("set", help="Set the domain(s) for an app")
    ds.add_argument("app")
    ds.add_argument("url", help='e.g. "https://myapp.example.com" (comma-separate multiple)')
    ds.add_argument(
        "--force-https",
        dest="force_https",
        action=argparse.BooleanOptionalAction,
        default=None,
        help="Enable/disable Coolify's is_force_https_enabled",
    )
    ds.add_argument("--instant-deploy", action="store_true")
    ds.add_argument("--deploy", action="store_true", help="Trigger a deploy after setting")
    ds.add_argument("--wait", action="store_true")
    ds.add_argument("--timeout", type=int, default=600)
    ds.set_defaults(func=cmd_domain_set)

    # tls
    sp = sub.add_parser("tls", help="TLS/HTTPS convenience")
    tls_sub = sp.add_subparsers(dest="tls_cmd", required=True)
    te = tls_sub.add_parser(
        "enable",
        help="Set domain + force_https, redeploy, wait for cert, smoke-test HTTPS",
    )
    te.add_argument("app")
    te.add_argument("--domain", required=True, help='Full https:// URL')
    te.add_argument("--timeout", type=int, default=600)
    te.set_defaults(func=cmd_tls_enable)

    # deploy
    sp = sub.add_parser("deploy", help="Trigger a deploy")
    sp.add_argument("app")
    sp.add_argument("--force", action="store_true", default=True, help="Force rebuild (default true)")
    sp.add_argument("--no-force", dest="force", action="store_false")
    sp.add_argument("--wait", action="store_true", help="Block until deployment finishes")
    sp.add_argument("--timeout", type=int, default=600)
    sp.set_defaults(func=cmd_deploy)

    # server
    sp = sub.add_parser("server", help="Manage servers")
    srv_sub = sp.add_subparsers(dest="server_cmd", required=True)
    sl = srv_sub.add_parser("list", help="List servers")
    sl.add_argument("--json", action="store_true")
    sl.set_defaults(func=cmd_server_list)

    return p


def main() -> None:
    args = build_parser().parse_args()
    _autoload_env_files(args.env_file)
    client = CoolifyClient()
    args.func(client, args)


if __name__ == "__main__":
    main()
