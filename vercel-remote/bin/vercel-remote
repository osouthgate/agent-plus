#!/usr/bin/env python3
"""
vercel-remote — read-first CLI wrapper around the Vercel REST API.

One call returns the full project/deployments/domains/env tree so the agent
doesn't burn context running `vercel list`, `vercel inspect`, `vercel env ls`,
`vercel domains ls` per project.

Commands (all emit JSON; --pretty for indented):
  projects list
  projects resolve <name-or-id>
  overview [--project <name-or-id>] [--limit 10]
  deployments list [--project ...] [--state ready|error|building|queued|canceled] [--limit 20]
  deployments show <deployment-or-url>
  deployments trigger --hook-url <url> [--wait] [--timeout 900]
  logs <deployment-or-url> [--since 1h] [--errors-only] [--limit 100]
  domains list --project <name>
  domains verify <domain> --project <name> [--wait] [--timeout 300]
  env list --project <name> [--env production|preview|development]
  env set <KEY> <VALUE> --project <name> [--env ...] [--wait]
  env remove <KEY> --project <name> [--env ...] [--wait]

Hard safety rules:
  1. Env var VALUES are NEVER written to stdout/stderr. Only names.
  2. All API responses pass through _scrub() before emission to strip known
     secret-bearing keys (passwordProtection.password, meta.githubToken, etc.).
  3. Write operations are explicit. Read-only by default.
  4. Team scoping: every API call appends ?teamId=<VERCEL_TEAM_ID> when set.

Config precedence (highest first):
  1. --token / --team CLI flags
  2. --env-file path
  3. project .env.local / .env (walked up from cwd)
  4. shell env

Requires: VERCEL_TOKEN. Optional: VERCEL_TEAM_ID, VERCEL_PROJECT.
"""

from __future__ import annotations

import argparse
import functools
import json
import os
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any, Callable, Optional


# ──────────────────────────── tool identity ────────────────────────────
# Every JSON payload this tool emits carries a top-level `tool: {name, version}`
# field so agents can self-diagnose version drift from the output alone — no
# extra subprocess call needed. Version is read from the plugin manifest at
# runtime so bumping plugin.json automatically flows through here.

TOOL_NAME = "vercel-remote"


@functools.lru_cache(maxsize=1)
def _plugin_version() -> str:
    """Read the plugin version from `.claude-plugin/plugin.json` relative to
    this file. Returns 'unknown' on any error — never raises."""
    try:
        manifest = Path(__file__).resolve().parent.parent / ".claude-plugin" / "plugin.json"
        data = json.loads(manifest.read_text(encoding="utf-8"))
        return str(data.get("version", "unknown"))
    except (OSError, json.JSONDecodeError):
        return "unknown"


def _tool_meta() -> dict[str, str]:
    return {"name": TOOL_NAME, "version": _plugin_version()}


def _with_tool_meta(payload: Any) -> Any:
    """Inject `tool: {name, version}` at the top of a dict payload. Pass-through
    for non-dict payloads (list, str, None) so single-value responses stay the
    shape they were."""
    if isinstance(payload, dict) and "tool" not in payload:
        return {"tool": _tool_meta(), **payload}
    return payload


# ──────────────────────────── constants ────────────────────────────

API_BASE = "https://api.vercel.com"
USER_AGENT = "vercel-remote/0.1.0 (+https://github.com/osouthgate/agent-plus)"

DEFAULT_OVERVIEW_DEPLOYMENTS = 10
MAX_OVERVIEW_DEPLOYMENTS = 50
DEFAULT_LOGS_LIMIT = 100
DEFAULT_DEPLOYMENTS_LIST_LIMIT = 20

# --wait polling contract (seconds).
WAIT_DEFAULT_DEPLOY_TIMEOUT = 900   # 15 min — builds can run long.
WAIT_DEFAULT_DOMAIN_TIMEOUT = 300   # 5 min — DNS propagation.
WAIT_DEFAULT_ENV_TIMEOUT = 30       # 30s — env changes are fast.
WAIT_POLL_INTERVAL = 5              # 5s default.
WAIT_POLL_INTERVAL_ENV = 2          # 2s for env (fast path).

HTTP_TIMEOUT = 30
HTTP_RETRY_ON = {429, 500, 502, 503, 504}
HTTP_MAX_RETRIES = 3

# Known secret-bearing keys stripped from every response before emit.
# Conservative — prefer over-redaction to leaks. Walk nested dicts/lists.
SECRET_KEYS = frozenset({
    "password",
    "token",
    "githubtoken",
    "gitlabtoken",
    "bitbuckettoken",
    "verceltoken",
    "secret",
    "secretvalue",
    "encryptedvalue",
    "value",  # env var values — always strip
})

# Keys that are safe to keep even though they match a prefix of SECRET_KEYS.
# For example, `valueType` / `valueLength` are metadata, not the value itself.
SECRET_ALLOWLIST = frozenset({
    "valueType",
    "valueLength",
    "passwordProtection",  # the object itself is fine; inner `.password` is scrubbed.
})


# ──────────────────────────── errors ────────────────────────────


class VercelError(Exception):
    """Raised on API errors with a user-friendly message."""


def die(msg: str, *, code: int = 1) -> None:
    sys.stderr.write(f"vercel-remote: {msg}\n")
    sys.exit(code)


# ──────────────────────────── config loading ────────────────────────────


def _find_env_files(start: Path) -> list[Path]:
    """Walk up from `start` collecting .env.local and .env (closest first)."""
    found: list[Path] = []
    cur = start.resolve()
    while True:
        for name in (".env.local", ".env"):
            p = cur / name
            if p.is_file():
                found.append(p)
        if cur.parent == cur:
            break
        cur = cur.parent
    return found


def _parse_env_file(path: Path) -> dict[str, str]:
    out: dict[str, str] = {}
    try:
        for raw in path.read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if "=" not in line:
                continue
            k, v = line.split("=", 1)
            k = k.strip()
            v = v.strip().strip('"').strip("'")
            if k and k.startswith("VERCEL_"):
                out[k] = v
    except OSError:
        pass
    return out


def load_config(*, env_file: Optional[str] = None) -> dict[str, str]:
    """Load VERCEL_* config with layered precedence."""
    cfg: dict[str, str] = {}
    # 4. shell env (lowest).
    for k, v in os.environ.items():
        if k.startswith("VERCEL_"):
            cfg[k] = v
    # 3. project .env.local / .env (walked up).
    for p in _find_env_files(Path.cwd()):
        for k, v in _parse_env_file(p).items():
            cfg[k] = v  # closer wins — but we iterate closest-first, so LATER overwrite would break precedence.
    # Fix precedence: re-read outermost first, then inner overwrites.
    cfg = {}
    for k, v in os.environ.items():
        if k.startswith("VERCEL_"):
            cfg[k] = v
    env_files = _find_env_files(Path.cwd())
    for p in reversed(env_files):  # outermost first, so closest overwrites.
        cfg.update(_parse_env_file(p))
    # 2. explicit --env-file overrides all file discovery.
    if env_file:
        p = Path(env_file)
        if not p.is_file():
            die(f"--env-file not found: {env_file}")
        cfg.update(_parse_env_file(p))
    return cfg


def require_token(cfg: dict[str, str]) -> str:
    token = cfg.get("VERCEL_TOKEN", "").strip()
    if not token:
        die(
            "VERCEL_TOKEN not set.\n"
            "  Set in project .env or .env.local (keys prefixed VERCEL_),\n"
            "  or in ~/.claude/settings.json (env block),\n"
            "  or via shell: export VERCEL_TOKEN=...\n"
            "  Get one: https://vercel.com/account/tokens"
        )
    return token


# ──────────────────────────── scrub ────────────────────────────


def _scrub(obj: Any) -> Any:
    """Recursively strip secret-bearing keys from API responses.

    Rules:
      - Dict keys matching SECRET_KEYS (case-insensitive): replaced with "[REDACTED]".
      - SECRET_ALLOWLIST keys are preserved and recursed into.
      - Lists are walked element-wise. Primitives pass through.

    INVARIANT: no value string from a stripped key ever appears in the output.
    """
    if isinstance(obj, dict):
        out: dict[str, Any] = {}
        for k, v in obj.items():
            k_lower = str(k).lower()
            if k in SECRET_ALLOWLIST:
                out[k] = _scrub(v)
                continue
            if k_lower in SECRET_KEYS:
                out[k] = "[REDACTED]"
                continue
            out[k] = _scrub(v)
        return out
    if isinstance(obj, list):
        return [_scrub(x) for x in obj]
    return obj


# ──────────────────────────── API helper ────────────────────────────


def _api(
    path: str,
    *,
    method: str = "GET",
    body: Optional[dict[str, Any]] = None,
    query: Optional[dict[str, str]] = None,
    cfg: dict[str, str],
    timeout: int = HTTP_TIMEOUT,
) -> Any:
    """Vercel API call. Handles team scoping, auth, retries on 429/5xx.

    Raises VercelError on non-2xx after retries. Caller is responsible for
    passing the parsed JSON through _scrub() before emission.
    """
    token = require_token(cfg)
    team_id = cfg.get("VERCEL_TEAM_ID", "").strip()

    q: dict[str, str] = dict(query or {})
    if team_id and "teamId" not in q:
        q["teamId"] = team_id

    url = API_BASE + path
    if q:
        url += "?" + urllib.parse.urlencode(q)

    data = None
    if body is not None:
        data = json.dumps(body).encode("utf-8")

    headers = {
        "Authorization": f"Bearer {token}",
        "User-Agent": USER_AGENT,
        "Accept": "application/json",
    }
    if data is not None:
        headers["Content-Type"] = "application/json"

    last_err: Optional[str] = None
    for attempt in range(HTTP_MAX_RETRIES):
        req = urllib.request.Request(url, data=data, method=method, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=timeout) as resp:
                raw = resp.read().decode("utf-8")
                if not raw:
                    return {}
                return json.loads(raw)
        except urllib.error.HTTPError as e:
            status = e.code
            try:
                err_body = e.read().decode("utf-8")
            except Exception:
                err_body = ""
            if status in HTTP_RETRY_ON and attempt < HTTP_MAX_RETRIES - 1:
                # Respect Retry-After if present.
                retry_after = e.headers.get("Retry-After") if e.headers else None
                delay = min(30, 2 ** attempt)
                if retry_after:
                    try:
                        delay = min(60, int(retry_after))
                    except ValueError:
                        pass
                time.sleep(delay)
                continue
            # Parse structured error if possible.
            msg = f"HTTP {status} on {method} {path}"
            if err_body:
                try:
                    parsed = json.loads(err_body)
                    err_msg = parsed.get("error", {}).get("message") or err_body
                    msg = f"{msg}: {err_msg}"
                except json.JSONDecodeError:
                    msg = f"{msg}: {err_body[:200]}"
            # Helpful hints for common failures.
            if status == 401:
                msg += "\n  Token invalid or expired. Regenerate: https://vercel.com/account/tokens"
            elif status == 403:
                msg += "\n  Token lacks required scope. Regenerate with appropriate scope."
            elif status == 404 and team_id:
                msg += f"\n  (team scope: teamId={team_id[:8]}...). Check VERCEL_TEAM_ID is correct."
            elif status == 429:
                msg += "\n  Rate-limited by Vercel API. Retry after a few seconds."
            raise VercelError(msg)
        except urllib.error.URLError as e:
            last_err = str(e)
            if attempt < HTTP_MAX_RETRIES - 1:
                time.sleep(2 ** attempt)
                continue
            raise VercelError(f"network error on {method} {path}: {last_err}")
    raise VercelError(f"exhausted retries on {method} {path}")


# ──────────────────────────── resolvers ────────────────────────────


def resolve_project(name_or_id: str, cfg: dict[str, str]) -> dict[str, Any]:
    """Resolve a project by name or ID. Vercel accepts either at /v9/projects/{idOrName}."""
    if not name_or_id:
        # Fall back to VERCEL_PROJECT if set.
        name_or_id = cfg.get("VERCEL_PROJECT", "").strip()
        if not name_or_id:
            die("no project specified — pass --project or set VERCEL_PROJECT")
    try:
        data = _api(f"/v9/projects/{urllib.parse.quote(name_or_id, safe='')}", cfg=cfg)
    except VercelError as e:
        if "HTTP 404" in str(e):
            die(f"project not found: {name_or_id}")
        raise
    return data


def _resolve_deployment_ref(ref: str) -> str:
    """A deployment ref may be an ID (dpl_...) or a URL (my-app-xyz.vercel.app).
    Vercel's /v13/deployments/{idOrUrl} accepts either; we just URL-encode."""
    # Strip https:// if present.
    r = ref.strip()
    for prefix in ("https://", "http://"):
        if r.startswith(prefix):
            r = r[len(prefix):]
    return urllib.parse.quote(r, safe="")


# ──────────────────────────── overview ────────────────────────────


def build_overview(project_ref: str, limit: int, cfg: dict[str, str]) -> dict[str, Any]:
    """Single-shot project snapshot: project + deployments + domains + env names."""
    project = resolve_project(project_ref, cfg)
    project_id = project.get("id") or project.get("name") or project_ref

    # Deployments.
    deps = _api(
        "/v6/deployments",
        query={"projectId": project_id, "limit": str(min(limit, MAX_OVERVIEW_DEPLOYMENTS))},
        cfg=cfg,
    )
    deployments_raw = deps.get("deployments", []) if isinstance(deps, dict) else []
    deployments = []
    for d in deployments_raw:
        meta = d.get("meta", {}) or {}
        deployments.append({
            "uid": d.get("uid"),
            "url": d.get("url"),
            "state": d.get("state") or d.get("readyState"),
            "target": d.get("target"),
            "createdAt": d.get("created") or d.get("createdAt"),
            "readyAt": d.get("ready"),
            "commit": {
                "sha": meta.get("githubCommitSha") or meta.get("gitlabCommitSha"),
                "message": meta.get("githubCommitMessage") or meta.get("gitlabCommitMessage"),
                "author": meta.get("githubCommitAuthorName") or meta.get("gitlabCommitAuthorName"),
                "branch": meta.get("githubCommitRef") or meta.get("gitlabCommitRef"),
            },
        })

    # Domains.
    try:
        dom_resp = _api(f"/v9/projects/{urllib.parse.quote(project_id, safe='')}/domains", cfg=cfg)
    except VercelError:
        dom_resp = {}
    domains_raw = dom_resp.get("domains", []) if isinstance(dom_resp, dict) else []
    domains: list[dict[str, Any]] = []
    for d in domains_raw:
        domains.append({
            "name": d.get("name"),
            "verified": d.get("verified"),
            "gitBranch": d.get("gitBranch"),
            "redirect": d.get("redirect"),
        })
    dom_summary = {
        "total": len(domains),
        "verified": sum(1 for d in domains if d.get("verified")),
        "pending": sum(1 for d in domains if not d.get("verified")),
    }

    # Env var NAMES only.
    env_names = fetch_env_names(project_id, env_target=None, cfg=cfg)

    # Top-level warnings: latest deployment errors, unverified domains.
    warnings: list[str] = []
    latest = deployments[0] if deployments else None
    if latest and latest.get("state") == "ERROR":
        warnings.append(f"latest deployment ({latest.get('uid')}) is in ERROR state")
    if dom_summary["pending"] > 0:
        warnings.append(f"{dom_summary['pending']} domain(s) unverified")

    return {
        "project": {
            "id": project.get("id"),
            "name": project.get("name"),
            "framework": project.get("framework"),
            "updatedAt": project.get("updatedAt"),
        },
        "deployments": deployments,
        "domains": {"summary": dom_summary, "items": domains},
        "envVarNames": env_names,
        "warnings": warnings,
        "caps": {
            "deployments": f"{len(deployments)}/{MAX_OVERVIEW_DEPLOYMENTS} (default {DEFAULT_OVERVIEW_DEPLOYMENTS})",
            "domains": "unbounded",
            "envVarNames": "unbounded",
        },
    }


# ──────────────────────────── env ────────────────────────────


def fetch_env_names(project_id: str, env_target: Optional[str], cfg: dict[str, str]) -> list[str]:
    """Return env var NAMES only. Values are stripped server-side by _scrub and
    we only project the `key` field regardless."""
    query: dict[str, str] = {}
    # Vercel /v10/projects/{id}/env supports target filter via repeated param.
    # urllib.parse.urlencode doesn't easily do repeated, so pass as-is and let
    # the caller filter client-side when needed.
    try:
        resp = _api(
            f"/v10/projects/{urllib.parse.quote(project_id, safe='')}/env",
            query=query,
            cfg=cfg,
        )
    except VercelError:
        return []
    items = resp.get("envs", []) if isinstance(resp, dict) else []
    names: list[str] = []
    for item in items:
        if env_target:
            targets = item.get("target") or []
            if isinstance(targets, str):
                targets = [targets]
            if env_target not in targets:
                continue
        k = item.get("key")
        if k:
            names.append(str(k))
    return sorted(set(names))


# ──────────────────────────── deployments ────────────────────────────


def list_deployments(
    project_ref: Optional[str],
    state: Optional[str],
    limit: int,
    cfg: dict[str, str],
) -> list[dict[str, Any]]:
    query: dict[str, str] = {"limit": str(limit)}
    if project_ref:
        project = resolve_project(project_ref, cfg)
        query["projectId"] = project.get("id") or project.get("name") or project_ref
    if state:
        query["state"] = state.upper()
    resp = _api("/v6/deployments", query=query, cfg=cfg)
    return resp.get("deployments", []) if isinstance(resp, dict) else []


def show_deployment(ref: str, cfg: dict[str, str]) -> dict[str, Any]:
    return _api(f"/v13/deployments/{_resolve_deployment_ref(ref)}", cfg=cfg)


def trigger_deploy_hook(
    hook_url: str,
    *,
    wait: bool,
    timeout: int,
    cfg: dict[str, str],
) -> dict[str, Any]:
    """Trigger a Vercel Deploy Hook (POST <hook-url>). Response includes job.id.

    Deploy Hooks are pre-configured webhook URLs. Docs:
    https://vercel.com/docs/deployments/deploy-hooks

    If --wait, poll the resulting deployment until ready/error/timeout.
    """
    if not hook_url.startswith("https://api.vercel.com/"):
        die(f"--hook-url must be a Vercel deploy hook URL (https://api.vercel.com/...), got: {hook_url[:60]}")
    # Deploy hooks don't require auth — the hook URL itself is the secret.
    req = urllib.request.Request(
        hook_url,
        method="POST",
        headers={"User-Agent": USER_AGENT, "Content-Type": "application/json"},
        data=b"{}",
    )
    try:
        with urllib.request.urlopen(req, timeout=HTTP_TIMEOUT) as resp:
            raw = resp.read().decode("utf-8")
            triggered = json.loads(raw) if raw else {}
    except urllib.error.HTTPError as e:
        body = ""
        try:
            body = e.read().decode("utf-8")[:200]
        except Exception:
            pass
        die(f"deploy hook returned HTTP {e.code}: {body}")
    except urllib.error.URLError as e:
        die(f"deploy hook network error: {e}")

    job = triggered.get("job") or {}
    result = {"triggered": triggered, "status": "triggered"}
    if not wait:
        return result

    # Poll the deployment to completion.
    deployment_id = job.get("id") or triggered.get("id")
    if not deployment_id:
        result["status"] = "triggered_no_poll"
        result["warning"] = "deploy hook response had no job.id — cannot poll"
        return result

    deadline = time.monotonic() + timeout
    last: dict[str, Any] = {}
    while time.monotonic() < deadline:
        try:
            last = _api(f"/v13/deployments/{deployment_id}", cfg=cfg)
        except VercelError as e:
            result["status"] = "poll_error"
            result["error"] = str(e)
            result["lastKnown"] = last
            return result
        state = (last.get("status") or last.get("readyState") or "").upper()
        if state in ("READY", "ERROR", "CANCELED"):
            result["status"] = state.lower()
            result["deployment"] = last
            return result
        time.sleep(WAIT_POLL_INTERVAL)
    result["status"] = "timeout"
    result["lastKnown"] = last
    return result


# ──────────────────────────── logs ────────────────────────────


def fetch_logs(
    ref: str,
    since: Optional[str],
    errors_only: bool,
    limit: int,
    cfg: dict[str, str],
) -> list[dict[str, Any]]:
    """Fetch deployment runtime/build logs. Uses /v2/deployments/{id}/events.

    NOTE: endpoint shape should be verified with curl before shipping — Vercel
    has historically had multiple log endpoints with varying streaming vs.
    poll semantics. Current best-known: /v2/deployments/{id}/events.
    """
    # Normalise ref → deployment ID first (URL → ID).
    dep = show_deployment(ref, cfg)
    dep_id = dep.get("id") or dep.get("uid")
    if not dep_id:
        die(f"could not resolve deployment from ref: {ref}")
    query: dict[str, str] = {"limit": str(limit), "direction": "backward"}
    if since:
        # Vercel accepts `since` as epoch ms.
        query["since"] = _parse_since_to_ms(since)
    resp = _api(f"/v2/deployments/{dep_id}/events", query=query, cfg=cfg)
    events = resp if isinstance(resp, list) else resp.get("events", [])
    out: list[dict[str, Any]] = []
    for e in events:
        entry = {
            "timestamp": e.get("created") or e.get("date"),
            "type": e.get("type"),
            "level": (e.get("level") or e.get("type") or "").lower(),
            "text": (e.get("text") or e.get("payload", {}).get("text") or "")[:500],
            "source": e.get("source"),
        }
        if errors_only and entry["level"] not in ("error", "fatal", "stderr"):
            # Also catch type=error / textual "error" in message.
            if "error" not in entry["text"].lower():
                continue
        out.append(entry)
    return out


def _parse_since_to_ms(since: str) -> str:
    """Parse `1h` / `30m` / `24h` into epoch ms of that-many-ago."""
    s = since.strip().lower()
    if not s:
        return str(int(time.time() * 1000))
    unit = s[-1]
    try:
        n = int(s[:-1])
    except ValueError:
        die(f"invalid --since: {since} (use e.g. 1h, 30m, 24h)")
        return ""
    multipliers = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    if unit not in multipliers:
        die(f"invalid --since unit: {unit} (use s/m/h/d)")
    ms = (int(time.time()) - n * multipliers[unit]) * 1000
    return str(ms)


# ──────────────────────────── domains ────────────────────────────


def list_domains(project_ref: str, cfg: dict[str, str]) -> list[dict[str, Any]]:
    project = resolve_project(project_ref, cfg)
    pid = project.get("id") or project.get("name") or project_ref
    resp = _api(f"/v9/projects/{urllib.parse.quote(pid, safe='')}/domains", cfg=cfg)
    return resp.get("domains", []) if isinstance(resp, dict) else []


def verify_domain(
    domain: str,
    project_ref: str,
    *,
    wait: bool,
    timeout: int,
    cfg: dict[str, str],
) -> dict[str, Any]:
    project = resolve_project(project_ref, cfg)
    pid = project.get("id") or project.get("name") or project_ref
    # Trigger verification.
    try:
        resp = _api(
            f"/v9/projects/{urllib.parse.quote(pid, safe='')}/domains/{urllib.parse.quote(domain, safe='')}/verify",
            method="POST",
            cfg=cfg,
        )
    except VercelError as e:
        die(str(e))
        return {}
    if not wait:
        return {"status": "verification_triggered", "response": resp}
    # Poll.
    deadline = time.monotonic() + timeout
    last: dict[str, Any] = {}
    while time.monotonic() < deadline:
        try:
            last = _api(
                f"/v9/projects/{urllib.parse.quote(pid, safe='')}/domains/{urllib.parse.quote(domain, safe='')}",
                cfg=cfg,
            )
        except VercelError as e:
            return {"status": "poll_error", "error": str(e)}
        if last.get("verified"):
            return {"status": "verified", "domain": last}
        time.sleep(WAIT_POLL_INTERVAL)
    return {"status": "timeout", "lastKnown": last}


# ──────────────────────────── env write ────────────────────────────


def env_set(
    key: str,
    value: str,
    project_ref: str,
    targets: list[str],
    *,
    cfg: dict[str, str],
) -> dict[str, Any]:
    project = resolve_project(project_ref, cfg)
    pid = project.get("id") or project.get("name") or project_ref
    body = {
        "key": key,
        "value": value,
        "target": targets or ["production", "preview", "development"],
        "type": "encrypted",
    }
    try:
        resp = _api(
            f"/v10/projects/{urllib.parse.quote(pid, safe='')}/env",
            method="POST",
            body=body,
            cfg=cfg,
        )
    except VercelError as e:
        msg = str(e)
        if "HTTP 409" in msg or "already exists" in msg.lower():
            die(f"env var {key} already exists — use `env remove` first or `env set --force` (not yet implemented)")
        raise
    # Return a scrubbed view — we NEVER echo the value back.
    return {"status": "set", "key": key, "target": targets}


def env_remove(
    key: str,
    project_ref: str,
    targets: list[str],
    *,
    cfg: dict[str, str],
) -> dict[str, Any]:
    project = resolve_project(project_ref, cfg)
    pid = project.get("id") or project.get("name") or project_ref
    # Find the env var ID for this key (+ optional target filter).
    resp = _api(f"/v10/projects/{urllib.parse.quote(pid, safe='')}/env", cfg=cfg)
    items = resp.get("envs", []) if isinstance(resp, dict) else []
    matches = [e for e in items if e.get("key") == key]
    if targets:
        matches = [e for e in matches if any(t in (e.get("target") or []) for t in targets)]
    if not matches:
        die(f"env var {key} not found (targets={targets or 'any'})")
    removed = []
    for env_item in matches:
        env_id = env_item.get("id")
        if not env_id:
            continue
        _api(
            f"/v9/projects/{urllib.parse.quote(pid, safe='')}/env/{urllib.parse.quote(env_id, safe='')}",
            method="DELETE",
            cfg=cfg,
        )
        removed.append({"id": env_id, "target": env_item.get("target")})
    return {"status": "removed", "key": key, "removed": removed}


# ──────────────────────────── emit ────────────────────────────


def emit_json(obj: Any, *, pretty: bool = False,
              output: Optional[str] = None) -> None:
    scrubbed = _scrub(obj)
    wrapped = _with_tool_meta(scrubbed)
    if output and isinstance(wrapped, dict):
        wrapped = _write_output_file(wrapped, output)
    if pretty:
        print(json.dumps(wrapped, indent=2, sort_keys=False, default=str))
    else:
        print(json.dumps(wrapped, default=str))


def _write_output_file(payload: dict, output_path: str) -> dict:
    """Write the full payload as JSON to `output_path` and return a compact
    summary envelope. Lets the agent offload large responses (deployment logs,
    overview snapshots) to disk instead of pulling them through the model's
    context window."""
    path = Path(output_path).expanduser().resolve()
    path.parent.mkdir(parents=True, exist_ok=True)
    text = json.dumps(payload, indent=2, default=str)
    path.write_text(text, encoding="utf-8")

    summary: dict[str, Any] = {
        "tool": payload.get("tool", _tool_meta()),
        "savedTo": str(path),
        "bytes": len(text.encode("utf-8")),
        "fileLineCount": text.count("\n") + 1,
        "payloadKeys": [k for k in payload.keys() if k != "tool"],
        "payloadShape": _payload_shape(payload),
    }
    lines = payload.get("lines")
    if isinstance(lines, list) and lines:
        preview_n = 10
        summary["preview"] = {
            "totalLines": len(lines),
            "head": lines[:preview_n],
            "tail": lines[-preview_n:] if len(lines) > preview_n * 2 else [],
        }
    return summary


def _payload_shape(payload: dict) -> dict[str, dict[str, Any]]:
    """Shallow type + size map for each top-level key (except `tool`). Lets
    the agent pick where to Read into the file without scanning the whole
    thing — e.g. `{deployments: {type: list, length: 50}}` signals "drill in".
    One level deep only; going deeper reinvents jq."""
    shape: dict[str, dict[str, Any]] = {}
    for k, v in payload.items():
        if k == "tool":
            continue
        if isinstance(v, str):
            shape[k] = {"type": "string", "length": len(v)}
        elif isinstance(v, bool):
            shape[k] = {"type": "boolean"}
        elif isinstance(v, (int, float)):
            shape[k] = {"type": "number"}
        elif isinstance(v, list):
            shape[k] = {"type": "list", "length": len(v)}
        elif isinstance(v, dict):
            shape[k] = {"type": "dict", "keys": len(v)}
        elif v is None:
            shape[k] = {"type": "null"}
        else:
            shape[k] = {"type": type(v).__name__}
    return shape


# ──────────────────────────── CLI ────────────────────────────


def _add_common_args(p: argparse.ArgumentParser) -> None:
    p.add_argument("--token", help="VERCEL_TOKEN (override env)")
    p.add_argument("--team", help="VERCEL_TEAM_ID (override env)")
    p.add_argument("--env-file", help="explicit .env file path")
    p.add_argument("--pretty", action="store_true", help="indent JSON output")
    p.add_argument("--output", metavar="PATH",
                   help=("write the full JSON payload to PATH and print a compact "
                         "summary (savedTo, bytes, payloadKeys, and — for log "
                         "payloads — head/tail previews). Use this when the "
                         "response is large enough that routing it through the "
                         "model's context is wasteful (e.g. deployment logs, "
                         "overview for many deployments)."))


def _cfg_from_args(args: argparse.Namespace) -> dict[str, str]:
    cfg = load_config(env_file=getattr(args, "env_file", None))
    if getattr(args, "token", None):
        cfg["VERCEL_TOKEN"] = args.token
    if getattr(args, "team", None):
        cfg["VERCEL_TEAM_ID"] = args.team
    return cfg


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="vercel-remote",
        description=(
            "Read-first Vercel API wrapper. One call returns a project's "
            "deployments, domains, and env NAMES. Zero env-value leakage."
        ),
        epilog=(
            "Examples:\n"
            "  vercel-remote projects list --pretty\n"
            "  vercel-remote overview --project my-app --json\n"
            "  vercel-remote deployments list --project my-app --state error\n"
            "  vercel-remote logs my-app-xyz.vercel.app --since 1h --errors-only\n"
            "  vercel-remote env list --project my-app --env production\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--version", action="version",
                   version=f"{TOOL_NAME} {_plugin_version()}")
    _add_common_args(p)
    sub = p.add_subparsers(dest="cmd", required=True)

    # projects
    sp = sub.add_parser("projects", help="project listing / resolution")
    sp.add_argument("action", choices=["list", "resolve"])
    sp.add_argument("ref", nargs="?", help="name or ID (for resolve)")
    sp.add_argument("--json", dest="json_out", action="store_true", default=True)

    # overview
    so = sub.add_parser(
        "overview",
        help="one-call project snapshot",
        description=(
            "Single-shot snapshot of a project: deployments (capped at "
            f"{MAX_OVERVIEW_DEPLOYMENTS}, default {DEFAULT_OVERVIEW_DEPLOYMENTS}), "
            "domains with verify summary, env var NAMES (values stripped), "
            "and top-level warnings.\n\n"
            "Example:\n  vercel-remote overview --project my-app --pretty"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    so.add_argument("--project", help="project name or ID (or set VERCEL_PROJECT)")
    so.add_argument("--limit", type=int, default=DEFAULT_OVERVIEW_DEPLOYMENTS)

    # deployments
    sd = sub.add_parser("deployments", help="deployment list / show / trigger")
    sd_sub = sd.add_subparsers(dest="action", required=True)
    sdl = sd_sub.add_parser("list")
    sdl.add_argument("--project", help="project name or ID")
    sdl.add_argument("--state", choices=["ready", "error", "building", "queued", "canceled"])
    sdl.add_argument("--limit", type=int, default=DEFAULT_DEPLOYMENTS_LIST_LIMIT)
    sds = sd_sub.add_parser("show")
    sds.add_argument("ref", help="deployment ID or URL")
    sdt = sd_sub.add_parser(
        "trigger",
        description=(
            "Trigger a deploy via Vercel Deploy Hook (NOT the /v13/deployments upload API).\n"
            "Create a hook at https://vercel.com/<team>/<project>/settings/git.\n\n"
            "Example:\n  vercel-remote deployments trigger --hook-url https://api.vercel.com/... --wait"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sdt.add_argument("--hook-url", required=True, help="Vercel deploy hook URL")
    sdt.add_argument("--wait", action="store_true")
    sdt.add_argument("--timeout", type=int, default=WAIT_DEFAULT_DEPLOY_TIMEOUT,
                     help=f"wait timeout seconds (default {WAIT_DEFAULT_DEPLOY_TIMEOUT})")

    # logs
    slg = sub.add_parser("logs", help="deployment logs")
    slg.add_argument("ref", help="deployment ID or URL")
    slg.add_argument("--since", default=None, help="e.g. 1h, 30m, 24h")
    slg.add_argument("--errors-only", action="store_true")
    slg.add_argument("--limit", type=int, default=DEFAULT_LOGS_LIMIT)

    # domains
    sdm = sub.add_parser("domains", help="domain list / verify")
    sdm_sub = sdm.add_subparsers(dest="action", required=True)
    sdml = sdm_sub.add_parser("list")
    sdml.add_argument("--project", required=True)
    sdmv = sdm_sub.add_parser("verify")
    sdmv.add_argument("domain")
    sdmv.add_argument("--project", required=True)
    sdmv.add_argument("--wait", action="store_true")
    sdmv.add_argument("--timeout", type=int, default=WAIT_DEFAULT_DOMAIN_TIMEOUT)

    # env
    se = sub.add_parser("env", help="env var list / set / remove (NAMES only on list)")
    se_sub = se.add_subparsers(dest="action", required=True)
    sel = se_sub.add_parser("list")
    sel.add_argument("--project", required=True)
    sel.add_argument("--env", choices=["production", "preview", "development"])
    ses = se_sub.add_parser("set")
    ses.add_argument("key")
    ses.add_argument("value")
    ses.add_argument("--project", required=True)
    ses.add_argument("--env", action="append", choices=["production", "preview", "development"], default=[])
    ses.add_argument("--wait", action="store_true")
    ser = se_sub.add_parser("remove")
    ser.add_argument("key")
    ser.add_argument("--project", required=True)
    ser.add_argument("--env", action="append", choices=["production", "preview", "development"], default=[])
    ser.add_argument("--wait", action="store_true")

    return p


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    cfg = _cfg_from_args(args)

    try:
        if args.cmd == "projects":
            if args.action == "list":
                resp = _api("/v9/projects", cfg=cfg)
                projects = resp.get("projects", []) if isinstance(resp, dict) else []
                slim = [
                    {"id": p.get("id"), "name": p.get("name"), "framework": p.get("framework")}
                    for p in projects
                ]
                emit_json(slim, pretty=args.pretty, output=getattr(args, "output", None))
            elif args.action == "resolve":
                if not args.ref:
                    die("projects resolve requires a name-or-id argument")
                emit_json(resolve_project(args.ref, cfg), pretty=args.pretty, output=getattr(args, "output", None))

        elif args.cmd == "overview":
            emit_json(build_overview(args.project or "", args.limit, cfg), pretty=args.pretty, output=getattr(args, "output", None))

        elif args.cmd == "deployments":
            if args.action == "list":
                deps = list_deployments(args.project, args.state, args.limit, cfg)
                emit_json(deps, pretty=args.pretty, output=getattr(args, "output", None))
            elif args.action == "show":
                emit_json(show_deployment(args.ref, cfg), pretty=args.pretty, output=getattr(args, "output", None))
            elif args.action == "trigger":
                emit_json(
                    trigger_deploy_hook(args.hook_url, wait=args.wait, timeout=args.timeout, cfg=cfg),
                    pretty=args.pretty, output=getattr(args, "output", None),
                )

        elif args.cmd == "logs":
            emit_json(
                fetch_logs(args.ref, args.since, args.errors_only, args.limit, cfg),
                pretty=args.pretty, output=getattr(args, "output", None),
            )

        elif args.cmd == "domains":
            if args.action == "list":
                emit_json(list_domains(args.project, cfg), pretty=args.pretty, output=getattr(args, "output", None))
            elif args.action == "verify":
                emit_json(
                    verify_domain(
                        args.domain, args.project,
                        wait=args.wait, timeout=args.timeout, cfg=cfg,
                    ),
                    pretty=args.pretty, output=getattr(args, "output", None),
                )

        elif args.cmd == "env":
            if args.action == "list":
                project = resolve_project(args.project, cfg)
                pid = project.get("id") or project.get("name") or args.project
                names = fetch_env_names(pid, args.env, cfg)
                emit_json({"project": project.get("name"), "env": args.env, "names": names},
                          pretty=args.pretty, output=getattr(args, "output", None))
            elif args.action == "set":
                emit_json(env_set(args.key, args.value, args.project, args.env, cfg=cfg),
                          pretty=args.pretty, output=getattr(args, "output", None))
            elif args.action == "remove":
                emit_json(env_remove(args.key, args.project, args.env, cfg=cfg),
                          pretty=args.pretty, output=getattr(args, "output", None))

        return 0
    except VercelError as e:
        die(str(e))
    except KeyboardInterrupt:
        die("interrupted", code=130)
    return 0


if __name__ == "__main__":
    sys.exit(main())
